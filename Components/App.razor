    <!-- LIMS Early Theme Application (Prevent Flash) -->
    <script>
        (function() {
            try {
                const theme = sessionStorage.getItem('lims-theme') || 'light';
                document.documentElement.setAttribute('data-theme', theme);
            } catch (e) {
                console.error('Failed to apply theme early', e);
            }
        })();
    </script>
    
