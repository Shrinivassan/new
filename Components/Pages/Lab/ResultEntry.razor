    // Row Detail Popup
    private LabResultEntry? SelectedRowEntry { get; set; } = null;
    
    private async Task OpenRowDetail(LabResultEntry row)
    {
        if (row == null) return;
        SelectedRowEntry = row;
        
        try 
        {
            // Update UI properties immediately with what we have
            SyncRowToUI(row);

            // Fetch fully populated details from the API
            var request = new HttpRequestMessage(HttpMethod.Get, $"{appSettings.BaseUrl}labresult/LoadTestResultDetails?testresultid={row.TestResultId}");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var res = await http.SendAsync(request);
            if (res.IsSuccessStatusCode)
            {
                var tt = await res.Content.ReadAsStringAsync();
                var detailedData = JsonConvert.DeserializeObject<TestResultDetailsModel>(tt);
                var detailedRow = detailedData?.Properties?.FirstOrDefault();
                
                if (detailedRow != null)
                {
                    // Update our row reference with basic fetched details that exist in model
                    row.LabProperties = detailedRow;
                    
                    row.RTMCode = detailedRow.RTMCode;

                    // Update our row reference with basic fetched details that exist in model
                    row.ResultValueType = detailedRow.ResultValueType ?? row.ResultValueType;
                    row.NormalValue = detailedRow.NormalValue ?? row.NormalValue;
                    row.SimpleNV = detailedRow.SimpleNormalValues;
                    row.DetailedNV = detailedRow.DetailedNormalValues;
                    row.CalculatedFormula = detailedData.CalculatedFormulas?.FirstOrDefault()?.CalculatedFormula ?? row.CalculatedFormula;
                    row.fixedvalues = detailedRow.DefaultValue ?? row.fixedvalues;
                    row.UnitName = detailedRow.DefaultValue ?? row.UnitName; // Fallback mapping
                    row.RTMCode = detailedRow.RTMCode;

                    row.EditedTextNormalValues = detailedData.TextNormalValues?.ToList();
                    row.EditedDetailedNormalValues = detailedData.DetailedNormalValues?.ToList();
                    
                    // Re-sync after fetch
                    SyncRowToUI(row);
                }
            }
        }
        catch (Exception)
        {
        }
        
        StateHasChanged();
    }

