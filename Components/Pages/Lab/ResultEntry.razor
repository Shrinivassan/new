    private string PrintOption { get; set; } = "LetterHead";

    private bool IsDetailedNormalValuesVisible { get; set; } = false;

    // Row Detail Popup
    private LabResultEntry? SelectedRowEntry { get; set; } = null;

    private async Task OpenRowDetail(LabResultEntry row)
    {
        if (row == null) return;
        SelectedRowEntry = row;
        
        try 
        {
            // Update UI properties immediately with what we have
            SyncRowToUI(row);

            // Fetch fully populated details from the API
            var res = await http.GetAsync($"{appSettings.BaseUrl}labresult/LoadTestResultDetails?testresultid={row.TestResultId}");
            if (res.IsSuccessStatusCode)
            {
                var tt = await res.Content.ReadAsStringAsync();
                var detailedRow = JsonConvert.DeserializeObject<LabResultEntry>(tt);
                if (detailedRow != null)
                {
                    // Update our row reference with fetched details
                    row.ResultValueType = detailedRow.ResultValueType ?? row.ResultValueType;
                    row.NormalValue = detailedRow.NormalValue ?? row.NormalValue;
                    row.SimpleNV = detailedRow.SimpleNV;
                    row.DetailedNV = detailedRow.DetailedNV;
                    row.CalculatedFormula = detailedRow.CalculatedFormula ?? row.CalculatedFormula;
                    row.FixedValues = detailedRow.FixedValues ?? row.FixedValues;
                    row.UnitName = detailedRow.UnitName ?? row.UnitName;
                    row.MachineName = detailedRow.MachineName ?? row.MachineName;
                    row.SampleName = detailedRow.SampleName ?? row.SampleName;
                    
                    // Re-sync after fetch
                    SyncRowToUI(row);
                }
            }
        }
        catch (Exception)
        {
        }
        
        StateHasChanged();
    }

    private void SyncRowToUI(LabResultEntry row)
    {
        ResultType = row.ResultValueType;
        ResultText = row.EnteredResult;
        AlertType = row.ResultHigh ? "High" : (row.ResultLow ? "Low" : "Normal");
        PrintResultsOnly = row.SimpleNV;
        SelectedUnit = row.UnitName;
        NormalValueText = row.NormalValue;

        // Populate modal signatures
        modalEnt = usermaster.FirstOrDefault(x => x.UserCode == row.ResultEnteredBy)?.Name ?? (row.ResultEnteredBy == 1 ? "Admin" : "");
        modalAuth1 = usermaster.FirstOrDefault(x => x.UserCode == row.ResultAuthorizedBy)?.Name ?? (row.ResultAuthorizedBy == 1 ? "Admin" : "");
        modalAuth2 = usermaster.FirstOrDefault(x => x.UserCode == row.ResultAuthorizedBy2)?.Name ?? (row.ResultAuthorizedBy2 == 1 ? "Admin" : "");
    }

    private void CloseRowDetail()
    {
        SelectedRowEntry = null;
    }

    // Fixed Values Popup Properties
    public class LabFixedValueItem
    {
        public int OrdNo { get; set; }
        public string Value { get; set; } = "";
    }

    private bool IsLabFixedValuesVisible { get; set; } = false;
    private string SelectedFixedType { get; set; } = "Appearance";
    private string PreviousFixedType { get; set; } = "";
    private int SelectedFixedValueIndex { get; set; } = 0;
    private int EditingFixedValueIndex { get; set; } = -1;

    private List<LabFixedValueItem> CurrentFixedValuesList { get; set; } = new List<LabFixedValueItem>
    {
        new LabFixedValueItem { OrdNo = 0, Value = "Clear" },
        new LabFixedValueItem { OrdNo = 1, Value = "Cloudy" },
        new LabFixedValueItem { OrdNo = 2, Value = "Turbid" },
        new LabFixedValueItem { OrdNo = 3, Value = "Slightly Cloudy" }
    };

    private void ToggleLabFixedValues()
    {
        IsLabFixedValuesVisible = !IsLabFixedValuesVisible;
    }

    private void AddNewFixedValueRow()
    {
        var nextOrdNo = CurrentFixedValuesList.Count > 0 ? CurrentFixedValuesList.Max(x => x.OrdNo) + 1 : 0;
        var newItem = new LabFixedValueItem { OrdNo = nextOrdNo, Value = "" };
        CurrentFixedValuesList.Add(newItem);
        int newIndex = CurrentFixedValuesList.Count - 1;
        SelectedFixedValueIndex = newIndex;
        SelectedFixedValueIndex = newIndex;
        EditingFixedValueIndex = newIndex;
    }

    private void DeleteSelectedFixedValue()
    {
        if (SelectedFixedValueIndex >= 0 && SelectedFixedValueIndex < CurrentFixedValuesList.Count)
        {
            CurrentFixedValuesList.RemoveAt(SelectedFixedValueIndex);

            EditingFixedValueIndex = -1;
            if (CurrentFixedValuesList.Count == 0)
            {
                SelectedFixedValueIndex = -1;
            }
            else if (SelectedFixedValueIndex >= CurrentFixedValuesList.Count)
            {
                SelectedFixedValueIndex = CurrentFixedValuesList.Count - 1;
            }
        }
    }

    private void OnFixedValueKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == "NumpadEnter")
        {
            AddNewFixedValueRow();
        }
    }

    private void OnFixedTypeChanged(ChangeEventArgs e)
    {
        SelectedFixedType = e.Value?.ToString() ?? "";
        if (SelectedFixedType == "Appearance")
        {
