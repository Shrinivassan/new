    private string GetResultBgClass(LabResultEntry row)
    {
        if (string.IsNullOrWhiteSpace(row.EnteredResult) || !double.TryParse(row.EnteredResult, out double res))
        {
            row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
            return "";
        }

        string nv = row.NormalValue ?? "";
        // Define a dash pattern that covers hyphen, en-dash, and em-dash
        string dash = @"[\-\u2013\u2014]";

        // 1. Check for explicit "Borderline" ranges
        var borderMatch = Regex.Match(nv, @"(\d+\.?\d*)\s*" + dash + @"\s*(\d+\.?\d*)\s*[:\-]?\s*Borderline", RegexOptions.IgnoreCase);
        if (!borderMatch.Success) borderMatch = Regex.Match(nv, @"Borderline\s*[:\-]?\s*(\d+\.?\d*)\s*" + dash + @"\s*(\d+\.?\d*)", RegexOptions.IgnoreCase);
        
        if (borderMatch.Success)
        {
            if (double.TryParse(borderMatch.Groups[1].Value, out double bMin) && 
                double.TryParse(borderMatch.Groups[2].Value, out double bMax))
            {
                if (res >= bMin && res <= bMax)
                {
                    row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
                    return "re-bg-yellow";
                }
            }
        }

        // 2. Check for "Normal" or "Desirable" ranges
        var normalRangeMatch = Regex.Match(nv, @"(\d+\.?\d*)\s*" + dash + @"\s*(\d+\.?\d*)\s*[:\-]?\s*(Normal|Desirable)", RegexOptions.IgnoreCase);
        if (normalRangeMatch.Success)
        {
            if (double.TryParse(normalRangeMatch.Groups[1].Value, out double nMin) && 
                double.TryParse(normalRangeMatch.Groups[2].Value, out double nMax))
            {
                if (res >= nMin && res <= nMax)
                {
                    row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
                    return "re-bg-green";
                }
            }
        }
        else
        {
            normalRangeMatch = Regex.Match(nv, @"(Normal|Desirable)\s*[:\-]?\s*(\d+\.?\d*)\s*" + dash + @"\s*(\d+\.?\d*)", RegexOptions.IgnoreCase);
            if (normalRangeMatch.Success)
            {
                if (double.TryParse(normalRangeMatch.Groups[2].Value, out double nMin) && 
                    double.TryParse(normalRangeMatch.Groups[3].Value, out double nMax))
                {
                    if (res >= nMin && res <= nMax)
                    {
                        row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
                        return "re-bg-green";
                    }
                }
            }
        }

        // 3. Check for Normal/Desirable limits (< X or > X)
        var ltMatch = Regex.Match(nv, @"<\s*(\d+\.?\d*)");
        if (ltMatch.Success && double.TryParse(ltMatch.Groups[1].Value, out double ltLimit))
        {
            if (res < ltLimit)
            {
                row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
                return "re-bg-green";
            }
        }

        var gtMatch = Regex.Match(nv, @">\s*(\d+\.?\d*)");
        if (gtMatch.Success && double.TryParse(gtMatch.Groups[1].Value, out double gtLimit))
        {
            if (res > gtLimit)
            {
                row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
                return "re-bg-green";
            }
        }

        // 4. Fallback to generic min-max range check
        var genericMatch = Regex.Match(nv, @"(\d+\.?\d*)\s*" + dash + @"\s*(\d+\.?\d*)");
        if (genericMatch.Success)
        {
            if (double.TryParse(genericMatch.Groups[1].Value, out double fMin) && 
                double.TryParse(genericMatch.Groups[2].Value, out double fMax))
            {
                if (res > fMax) { row.ResultHigh = true; row.ResultLow = false; row.ResultNormal = false; return "re-bg-red"; }
                if (res < fMin) { row.ResultHigh = false; row.ResultLow = true; row.ResultNormal = false; return "re-bg-red"; }
                
                row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
                return "re-bg-green";
            }
        }

        // 5. Absolute High/Low detection based on any numbers in the string
        var numbers = Regex.Matches(nv, @"\d+\.?\d*").Cast<Match>()
            .Select(m => { double.TryParse(m.Value, out double d); return d; })
            .ToList();

        if (numbers.Any())
        {
            double absMax = numbers.Max();
            double absMin = numbers.Min();
            if (res > absMax) { row.ResultHigh = true; row.ResultLow = false; row.ResultNormal = false; return "re-bg-red"; }
            if (res < absMin) { row.ResultHigh = false; row.ResultLow = true; row.ResultNormal = false; return "re-bg-red"; }
        }

        row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
        return "";
    }

    private async Task FetchDeltaCheck()
    {
        if (string.IsNullOrEmpty(CustCode)) return;
        isDeltaLoading = true;
        StateHasChanged();
        try
        {
            var url = $"http://birdapi.iscansoft.com/api/Request/deltacheck?custcode={CustCode}";
            var request = new HttpRequestMessage(HttpMethod.Get, url);
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var res = await http.SendAsync(request);
            if (res.IsSuccessStatusCode)
            {
                var content = await res.Content.ReadAsStringAsync();
                deltaResults = JsonConvert.DeserializeObject<List<DeltaResult>>(content);
                
                // Calculate missing formula values for previous results
                if (deltaResults != null && deltaResults.Any())
                {
                    CalculatePreviousFormulas();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Delta Check Error: {ex.Message}");
        }
        finally
        {
            isDeltaLoading = false;
            StateHasChanged();
        }
    }

    private void CalculatePreviousFormulas()
    {
        if (deltaResults == null || lre1 == null) return;

        try
        {
            // 1. Build a parameter dictionary from the historical data
            var histParams = new Dictionary<string, object>();
            foreach (var dr in deltaResults)
            {
                if (double.TryParse(dr.Result, out double val))
                {
                    var matchingRow = lre1.FirstOrDefault(x => (x.Col2 ?? "").Trim().ToLower() == (dr.TestName ?? "").Trim().ToLower());
                    if (matchingRow != null)
                    {
                        histParams[matchingRow.TCode.ToString()] = val;
                        histParams[matchingRow.TestResultId.ToString().ToLower()] = val;
                        string safeName = (matchingRow.Col2 ?? "").Replace(" ", "").Replace("(", "").Replace(")", "").Replace("-", "").Replace(".", "");
                        histParams[safeName] = val;
                    }
                }
            }

            // 2. Loop through our master list and calculate any formulas for the previous data
            foreach (var row in lre1)
            {
                if (row.ResultValueType == "Calculated Value" && !string.IsNullOrEmpty(row.CalculatedFormula))
                {
                    // Check if this test already has a result in deltaResults
                    var existingDelta = deltaResults.FirstOrDefault(d => (d.TestName ?? "").Trim().ToLower() == (row.Col2 ?? "").Trim().ToLower());
                    
                    // If it's empty or a GUID, try to calculate it
                    if (existingDelta == null || string.IsNullOrEmpty(existingDelta.Result) || Guid.TryParse(existingDelta.Result, out _))
                    {
                        try
                        {
                            var parts = row.CalculatedFormula.Split('|', StringSplitOptions.RemoveEmptyEntries);
                            var processedFormula = new System.Text.StringBuilder();
                            foreach (var p in parts)
                            {
                                string part = p.Trim();
                                if (Guid.TryParse(part, out _) || int.TryParse(part, out _))
                                    processedFormula.Append($"[{part}]");
                                else
                                    processedFormula.Append(part);
                            }

                            var expr = new Expression(processedFormula.ToString());
                            expr.Parameters = histParams;
                            var res = expr.Evaluate();
                            if (res != null)
                            {
                                string calcVal = res.ToString();
                                if (double.TryParse(calcVal, out double num))
                                    calcVal = Math.Round(num, 2).ToString();

                                if (existingDelta != null)
                                    existingDelta.Result = calcVal;
                                else
                                    deltaResults.Add(new DeltaResult { TestName = row.Col2, Result = calcVal });
                            }
                        }
                        catch { }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error calculating previous formulas: {ex.Message}");
        }
    }

    private void ClearEntry()
    {
        // Reset all entered results in lre1
        foreach (var row in lre1)
        {
            row.EnteredResult = string.Empty;
        }
        StateHasChanged();
    }

    // Save state
    private bool isSaving = false;
    private string saveMessage = "";
    private bool saveError = false;
    private System.Threading.CancellationTokenSource? _toastCts;

    private async Task SaveResults(int level)
    {
        if (isSaving) return;
        if (userCode == 0)
        {
            saveError = true;
            saveMessage = "User session expired. Please log in again.";
            StateHasChanged();
            return;
        }

        isSaving = true;
        saveMessage = "";
        Console.WriteLine($"SaveResults: level={level}, userCode={userCode}, isauth1={isauthorized1}, isauth2={isauthorized2}");
        StateHasChanged();

        try
        {
            bool canProceed = false;

            // Sanitize and Apply Authorization to the FULL master list (lre1)
            foreach (var row in lre1)
            {
                // Sync GUIDs
                if (string.IsNullOrEmpty(row.RequestGUID)) row.RequestGUID = RequestGuid ?? "";
                
                // Result Status Logic: true if entered, else false
                row.Status = !string.IsNullOrWhiteSpace(row.EnteredResult?.Trim());

                if (string.IsNullOrEmpty(row.DefaultUnitValue)) row.DefaultUnitValue = row.UnitName ?? "";
                
                // 1. Clean up NormalValue
                if (row.NormalValue != null) row.NormalValue = row.NormalValue.Replace("Normal 0", "").Trim();

                // 2. Sync RTMCode and handle method inclusion
                var methodObj = method.FirstOrDefault(x => x.RTMCode == row.RTMCode);
                if (methodObj != null && !string.IsNullOrEmpty(methodObj.Name))
                {
                    // If NormalValue is now empty, set it to the method name in parentheses
                    if (string.IsNullOrWhiteSpace(row.NormalValue))
                    {
                        row.NormalValue = $"({methodObj.Name})";
                    }
                    // Otherwise append method if not already present
                    else if (!row.NormalValue.Contains(methodObj.Name))
                    {
                        row.NormalValue = $"{row.NormalValue} / {methodObj.Name}";
                    }
                }
                
                // Sync DefaultUnitsCode from UnitName to ensure they are always consistent
                if (!string.IsNullOrEmpty(row.UnitName))
                {
                    var unit = uom.FirstOrDefault(x => x.Name == row.UnitName);
                    if (unit != null) row.DefaultUnitsCode = unit.UCode;
                }

                // Sync MCCode from MachineName
                if (row.MCCode == 0 && !string.IsNullOrEmpty(row.MachineName))
                {
                    var m = machine.FirstOrDefault(x => x.Name == row.MachineName || x.ShortName == row.MachineName);
                    if (m != null) row.MCCode = m.MCCode;
                }

                // Sync SCode from SampleName (Specimen)
                if (row.SCode == 0 && !string.IsNullOrEmpty(row.SampleName))
                {
                    var s = sample.FirstOrDefault(x => x.Name == row.SampleName || x.ShortName == row.SampleName);
                    if (s != null) row.SCode = s.SCode;
                }

                // Sync RTMCode if still 0 (default to first method if available)
                if (row.RTMCode == 0 && method.Any())
                {
                    row.RTMCode = method.First().RTMCode;
                }

                if (string.IsNullOrEmpty(row.MachineName)) row.MachineName = "Manual";
                
                row.EnteredResult ??= "";
                row.Col2 ??= "";
                row.ResultValueType ??= "Text";

                // Rights enforcement - Applied based on user's highest permission
                if (isauthorized2)
                {
                    if (row.ResultAuthorizedBy2 == 0 || row.ResultAuthorizedBy2 == userCode)
                    {
                canProceed = true;
                        // Final Authorization
                        row.ResultAuthorizedBy2 = userCode;
                        row.IsAuthorized2 = true;
                        row.Status = true;
                        
                        if (row.ResultAuthorizedBy == 0) row.ResultAuthorizedBy = userCode;
                        row.IsAuthorized1 = true;
                        if (row.ResultEnteredBy == 0) row.ResultEnteredBy = userCode;
                    }
                }
                else if (isauthorized1)
                {
                    if (row.ResultAuthorizedBy2 == 0 && (row.ResultAuthorizedBy == 0 || row.ResultAuthorizedBy == userCode))
                    {
                        canProceed = true;
                        // Level 1 Authorization
                        row.ResultAuthorizedBy = userCode;
                        row.IsAuthorized1 = true;
                        row.Status = true;
                        
                        // Chain Fallback: Ensure Entry is "passed"
                        if (row.ResultEnteredBy == 0) row.ResultEnteredBy = userCode;
                    }
                }
                else if (isentered)
                {
                    // Basic Result Entry
                    if (row.ResultAuthorizedBy2 == 0 && (row.ResultAuthorizedBy == 0 || row.ResultAuthorizedBy == userCode))
                    {
                        canProceed = true;
                        if (row.ResultEnteredBy == 0) row.ResultEnteredBy = userCode;
                        row.Status = true;
                    }
                }
            }

            UpdateUserNames();
            StateHasChanged();

            if (!canProceed)
            {
                saveError = true;
                saveMessage = "Insufficient rights or record is locked.";
                isSaving = false;
                StateHasChanged();
                return;
            }

            // Sanitize and sync before sending to backend
            foreach (var row in lre1)
            {
                // Ensure RTMCode is in sync
                if (row.LabProperties != null)
                {
                    if (row.RTMCode > 0) row.LabProperties.RTMCode = row.RTMCode;
                    else if (row.LabProperties.RTMCode > 0) row.RTMCode = row.LabProperties.RTMCode;
                }

                // Fallback: If RTMCode is missing, use the first available method as default
                if (row.RTMCode == 0 && method.Any())
                {
                    row.RTMCode = method.First().RTMCode;
                    if (row.LabProperties != null) row.LabProperties.RTMCode = row.RTMCode;
                }

                if (row.EditedDetailedNormalValues != null)
                {
                    foreach (var dnv in row.EditedDetailedNormalValues)
                    {
                        if (string.IsNullOrEmpty(dnv.AgeFromType))  dnv.AgeFromType  = "Years";
                        if (string.IsNullOrEmpty(dnv.AgeToType))    dnv.AgeToType    = "Years";
                        if (string.IsNullOrEmpty(dnv.AgeRangeType)) dnv.AgeRangeType = "Normal";
                        if (string.IsNullOrEmpty(dnv.sex))          dnv.sex          = "Both";
                        if (string.IsNullOrEmpty(dnv.RangeType))    dnv.RangeType    = "Normal";
                    }
                }
            }

            // Reverting to raw array as "Path: $" and "BytePositionInLine: 1" confirm backend expects List<LabResultEntry> at root
            var settings = new JsonSerializerSettings { 
                ContractResolver = new Newtonsoft.Json.Serialization.CamelCasePropertyNamesContractResolver() 
            };
            var json = JsonConvert.SerializeObject(lre1, settings);
            
            Console.WriteLine($"--- SAVE RESULTS PAYLOAD LOG ---");
            Console.WriteLine($"URL: {appSettings.BaseUrl}LabResult/SaveResultEntry");
            Console.WriteLine($"Payload snapshot: {(json.Length > 500 ? json.Substring(0, 500) + "..." : json)}");
            Console.WriteLine($"---------------------------------");
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");

            var request = new HttpRequestMessage(HttpMethod.Post,
                $"{appSettings.BaseUrl}LabResult/SaveResultEntry")
            {
                Content = content
            };
            
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var res = await http.SendAsync(request);

            if (res.IsSuccessStatusCode)
            {
                saveError = false;
                saveMessage = "Results saved successfully.";
                
                // Keep the current in-memory lre1 (already has the edited values).
                // Do NOT call LoadResults() here — it would overwrite the edited values
                // with a stale server snapshot before the DB write is fully visible.
                
                // Re-calculate signatures and formulas on the current data
                UpdateUserNames();
                await RunCalculations();
                
                // Force UI refresh
                StateHasChanged(); 
            }
            else
            {
                var errContent = await res.Content.ReadAsStringAsync();
                saveError = true;
                saveMessage = $"Save failed: {res.StatusCode} - {errContent}";
                Console.WriteLine($"Backend Save Error: {errContent}");
            }
        }
        catch (Exception ex)
        {
            saveError = true;
            saveMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();

            // Auto-dismiss toast after 3 seconds
            _toastCts?.Cancel();
            _toastCts = new System.Threading.CancellationTokenSource();
            var token = _toastCts.Token;
            _ = Task.Delay(3000, token).ContinueWith(_ =>
            {
                if (!token.IsCancellationRequested)
                {
                    saveMessage = "";
                    InvokeAsync(StateHasChanged);
                }
            }, token);
        }
    }

