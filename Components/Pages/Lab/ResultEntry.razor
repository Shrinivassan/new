    private void ToggleDetailedNormalValues()
    {
        IsDetailedNormalValuesVisible = !IsDetailedNormalValuesVisible;
    }

    private void OnDetailedNVModalChanged(ChangeEventArgs e)
    {
        if (SelectedRowEntry != null)
        {
            DetailedNormalRange = (bool)(e.Value ?? false);
            SelectedRowEntry.DetailedNV = DetailedNormalRange;
            
            if (SelectedRowEntry.LabProperties == null)
                SelectedRowEntry.LabProperties = new Lab_Result_Properties { TestResultID = SelectedRowEntry.TestResultId };
            
            SelectedRowEntry.LabProperties.ShowAgedBased = DetailedNormalRange;
        }
    }

    private void OnMethodChanged(ChangeEventArgs e)
    {
        if (SelectedRowEntry == null) return;
        if (int.TryParse(e.Value?.ToString(), out int rtmCode))
        {
            SelectedRowEntry.RTMCode = rtmCode;
            
            // Sync with properties
            if (SelectedRowEntry.LabProperties != null)
                SelectedRowEntry.LabProperties.RTMCode = rtmCode;

            // Trigger normal value refresh to include/update the method name
            if (DetailedNormalRange) UpdateNormalValueFromDetailedRanges();
            else UpdateNormalValueFromMethodOnly(rtmCode);
        }
    }

    private void UpdateNormalValueFromMethodOnly(int rtmCode)
    {
        if (SelectedRowEntry == null) return;
        var m = method.FirstOrDefault(x => x.RTMCode == rtmCode);
        if (m == null) return;

        string mName = $"({m.Name})";
        string current = SelectedRowEntry.NormalValue ?? "";

        // Remove any existing parenthesized method names to prevent duplicates
        // (Simple regex-like logic: find " / (...)" and remove it)
        if (current.Contains(" / ("))
        {
            int idx = current.LastIndexOf(" / (");
            current = current.Substring(0, idx).Trim();
        }
        else if (current.StartsWith("(") && current.EndsWith(")"))
        {
            current = "";
        }

        if (string.IsNullOrWhiteSpace(current)) SelectedRowEntry.NormalValue = mName;
        else SelectedRowEntry.NormalValue = $"{current} / {mName}";
    }

    private void UpdateNormalValueFromDetailedRanges()
    {
        if (SelectedRowEntry == null || SelectedRowEntry.EditedDetailedNormalValues == null || !SelectedRowEntry.EditedDetailedNormalValues.Any())
            return;

        var ranges = SelectedRowEntry.EditedDetailedNormalValues
            .OrderBy(x => x.sex)
            .ThenBy(x => x.AgeFrom)
            .Select(x => $"{x.sex}: {x.RangeFrom}-{x.RangeTo} ({x.AgeFrom}-{x.AgeTo} {x.AgeFromType})")
            .ToList();

        string rangeStr = string.Join(" / ", ranges);
        
        // Append Method name if available
        if (SelectedRowEntry.RTMCode > 0)
        {
            var m = method.FirstOrDefault(x => x.RTMCode == SelectedRowEntry.RTMCode);
            if (m != null)
            {
                rangeStr = $"{rangeStr} / ({m.Name})";
            }
        }

        SelectedRowEntry.NormalValue = rangeStr;
    }

    private void UpdateRowSettings()
    {
        if (SelectedRowEntry == null) return;

        if (DetailedNormalRange)
        {
            UpdateNormalValueFromDetailedRanges();
        }
        
        SelectedRowEntry.ResultValueType = ResultType;
        
        // For fixed types, sync from the local ResultText variable
        if (ResultType == "Fixed Type")
        {
            SelectedRowEntry.EnteredResult = ResultText;
        }
        // For other types, SelectedRowEntry.EnteredResult is already bound in the UI.

        SelectedRowEntry.ResultHigh = (AlertType == "High");
        SelectedRowEntry.ResultLow = (AlertType == "Low");
        SelectedRowEntry.ResultNormal = (AlertType == "Normal");
        SelectedRowEntry.SimpleNV = PrintResultsOnly;
        SelectedRowEntry.DetailedNV = DetailedNormalRange;
        // SelectedRowEntry.UnitName is already bound in the UI.
        // SelectedRowEntry.NormalValue is already bound in the UI.
        SelectedRowEntry.IsAuthorized1 = IsAuthorizedRow;
        SelectedRowEntry.Status = true; // Mark as edited

        if (SelectedRowEntry.LabProperties == null)
            SelectedRowEntry.LabProperties = new Lab_Result_Properties { TestResultID = SelectedRowEntry.TestResultId };

        // Ensure RTMCode is synced to properties during Apply
        SelectedRowEntry.LabProperties.RTMCode = SelectedRowEntry.RTMCode;
        SelectedRowEntry.LabProperties.DetailedNormalValues = DetailedNormalRange;

        var props = SelectedRowEntry.LabProperties;
        props.DecimalValue = DecimalValue;
        props.ShowAlertOnHigherLower = ShowAlertLowerHigher;
        props.FooterMessage = FooterMessageText;
        props.PrintConclusionInReport = PrintConclusionInReport;
        props.ConclusionforFixedText = ConclusionText;
        props.ShowAgedBased = DetailedNormalRange;
        props.IsGraph = IsGraphValue;
        
        // Sync RTMCode from the row (which is bound in the UI) to properties
        props.RTMCode = SelectedRowEntry.RTMCode;

        SelectedRowEntry.Status = true;

        // Close panel after update
        IsDetailedNormalValuesVisible = false;
        _ = RunCalculations();
        StateHasChanged();
    }

    private void SetNormalValue(string val)
    {
        NormalValueText = val;
        StateHasChanged();
    }

    private void AddNewDetailedRange()
    {
        if (SelectedRowEntry != null)
        {
            DetailedNormalRange = true; // Auto-enable when adding a range
            SelectedRowEntry.DetailedNV = true;
            
            if (SelectedRowEntry.EditedDetailedNormalValues == null)
                SelectedRowEntry.EditedDetailedNormalValues = new List<Lab_Result_DetailedNormalValues>();
            
            SelectedRowEntry.EditedDetailedNormalValues.Add(new Lab_Result_DetailedNormalValues
            {
                TRDNID = Guid.NewGuid(),
                TestResultID = SelectedRowEntry.TestResultId,
                sex = "Both",
                RangeType = "Normal",
                AgeFromType = "Years",
                AgeToType = "Years",
                AgeRangeType = "Normal"
            });
        }
    }

    private void SetDetailedNormalValue(Lab_Result_DetailedNormalValues dnv)
    {
        if (dnv == null || SelectedRowEntry == null) return;

        // Track which row is selected (for highlight)
        SelectedDnvId = dnv.TRDNID;

        // Build a formatted normal value string from the selected range
        var fromStr = dnv.AgeFrom == 0 ? "" : dnv.AgeFrom.ToString();
        var toStr = dnv.AgeTo == 0 ? "" : dnv.AgeTo.ToString();
        var rangeStr = (!string.IsNullOrEmpty(fromStr) && !string.IsNullOrEmpty(toStr))
            ? $"{fromStr} - {toStr}"
            : fromStr + toStr;

        // Apply to the UI fields
        NormalRangeInput1 = fromStr;
        NormalRangeInput2 = toStr;
        NormalValueText = rangeStr;

        // Also write back to the model so it persists on Apply
        SelectedRowEntry.NormalValue = rangeStr;

        // Highlight the selected row by marking it (optional visual feedback)
        FixedNormalValueSelect = rangeStr;

        StateHasChanged();
    }

    private readonly string[] gridColumns = { "col2", "run", "result", "unit", "normal", "machine", "sample" };

    private async Task HandleGridKeydown(KeyboardEventArgs e, int rowIndex, string colName)
    {
        if (e.Key == "Enter" || e.Key == "NumpadEnter")
        {
            int nextRowIndex = rowIndex + 1;

            if (nextRowIndex < lre.Count)
            {
                string nextId = $"txt-{nextRowIndex}-{colName}";
                await JSRuntime.InvokeVoidAsync("gridNavigation.focusNext", nextId);
            }
            // If it's the last row, we do nothing and let the user use the mouse as requested.
        }
    }

    private void OnResultValueTypeChanged(ChangeEventArgs e)
    {
        if (SelectedRowEntry != null)
        {
            var newType = e.Value?.ToString() ?? "Text";
            if (SelectedRowEntry.ResultValueType != newType)
            {
                SelectedRowEntry.ResultValueType = newType;
                // Clear old result when type changes to avoid stale data (e.g. number kept in fixed type)
                if (newType != "Title" && newType != "SubTitle")
                {
                    SelectedRowEntry.EnteredResult = "";
                }
            }
            StateHasChanged();
        }
    }

    private void ApplyDeltaResult(LabResultEntry item, string value)
    {
        if (canEditResults && item != null)
        {
            item.EnteredResult = value;
            _ = RunCalculations();
            StateHasChanged();
        }
    }

    private void SetAlert(string type)
    {
        if (SelectedRowEntry == null) return;
        SelectedRowEntry.ResultNormal = (type == "Normal");
        SelectedRowEntry.ResultHigh = (type == "High");
        SelectedRowEntry.ResultLow = (type == "Low");
        StateHasChanged();
    }

    private void SetGroupOption(string type)
    {
        if (SelectedRowEntry == null) return;
        
        CurrentGroupOption = type;
        if (SelectedRowEntry.LabProperties == null)
            SelectedRowEntry.LabProperties = new Lab_Result_Properties { TestResultID = SelectedRowEntry.TestResultId };

        SelectedRowEntry.LabProperties.GroupValuesbySpecialField = (type == "Special");
        SelectedRowEntry.LabProperties.GroupValuesbySex = (type == "Sex");
