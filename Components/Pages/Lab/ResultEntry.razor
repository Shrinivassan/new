    private string GetResultBgClass(LabResultEntry row)
    {
        if (string.IsNullOrWhiteSpace(row.EnteredResult) || !double.TryParse(row.EnteredResult, out double res))
        {
            row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
            return "";
        }

        string normalVal = row.NormalValue ?? "";

        // Support standard range parsing "min-max"
        var rangeMatch = System.Text.RegularExpressions.Regex.Match(normalVal, @"(\d+\.?\d*)\s*-\s*(\d+\.?\d*)");
        if (rangeMatch.Success)
        {
            double min = double.Parse(rangeMatch.Groups[1].Value);
            double max = double.Parse(rangeMatch.Groups[2].Value);
            
            if (res > max) { row.ResultHigh = true; row.ResultLow = false; row.ResultNormal = false; return "re-bg-red"; }
            if (res < min) { row.ResultHigh = false; row.ResultLow = true; row.ResultNormal = false; return "re-bg-red"; }
            
            row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
            if (res == min || res == max) return "re-bg-yellow";
            
            return "re-bg-green";
        }
        
        // Handle "< 200"
        if (normalVal.Contains("<"))
        {
            var valMatch = System.Text.RegularExpressions.Regex.Match(normalVal, @"(\d+\.?\d*)");
            if (valMatch.Success && double.TryParse(valMatch.Groups[1].Value, out double limit))
            {
                if (res > limit) { row.ResultHigh = true; row.ResultLow = false; row.ResultNormal = false; return "re-bg-red"; }
                row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
                if (res == limit) return "re-bg-yellow";
                return "re-bg-green";
            }
        }
        
        // Handle "> 240"
        if (normalVal.Contains(">"))
        {
            var valMatch = System.Text.RegularExpressions.Regex.Match(normalVal, @"(\d+\.?\d*)");
            if (valMatch.Success && double.TryParse(valMatch.Groups[1].Value, out double limit))
            {
                if (res < limit) { row.ResultHigh = false; row.ResultLow = true; row.ResultNormal = false; return "re-bg-red"; }
                row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
                if (res == limit) return "re-bg-yellow";
                return "re-bg-green";
            }
        }

        row.ResultHigh = false; row.ResultLow = false; row.ResultNormal = true;
        return "";
    }

    private async Task FetchDeltaCheck()
    {
        if (string.IsNullOrEmpty(CustCode)) return;
        isDeltaLoading = true;
        StateHasChanged();
        try
        {
            var url = $"http://birdapi.iscansoft.com/api/Request/deltacheck?custcode={CustCode}";
            var request = new HttpRequestMessage(HttpMethod.Get, url);
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var res = await http.SendAsync(request);
            if (res.IsSuccessStatusCode)
            {
                var content = await res.Content.ReadAsStringAsync();
                deltaResults = JsonConvert.DeserializeObject<List<DeltaResult>>(content);
                
                // Calculate missing formula values for previous results
                if (deltaResults != null && deltaResults.Any())
                {
                    CalculatePreviousFormulas();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Delta Check Error: {ex.Message}");
        }
        finally
        {
            isDeltaLoading = false;
            StateHasChanged();
        }
    }

    private void CalculatePreviousFormulas()
    {
        if (deltaResults == null || lre1 == null) return;

        try
        {
            // 1. Build a parameter dictionary from the historical data
            var histParams = new Dictionary<string, object>();
            foreach (var dr in deltaResults)
            {
                if (double.TryParse(dr.Result, out double val))
                {
                    var matchingRow = lre1.FirstOrDefault(x => (x.Col2 ?? "").Trim().ToLower() == (dr.TestName ?? "").Trim().ToLower());
                    if (matchingRow != null)
                    {
                        histParams[matchingRow.TCode.ToString()] = val;
                        histParams[matchingRow.TestResultId.ToString().ToLower()] = val;
                        string safeName = (matchingRow.Col2 ?? "").Replace(" ", "").Replace("(", "").Replace(")", "").Replace("-", "").Replace(".", "");
                        histParams[safeName] = val;
                    }
                }
            }

            // 2. Loop through our master list and calculate any formulas for the previous data
            foreach (var row in lre1)
            {
                if (row.ResultValueType == "Calculated Value" && !string.IsNullOrEmpty(row.CalculatedFormula))
                {
                    // Check if this test already has a result in deltaResults
                    var existingDelta = deltaResults.FirstOrDefault(d => (d.TestName ?? "").Trim().ToLower() == (row.Col2 ?? "").Trim().ToLower());
                    
                    // If it's empty or a GUID, try to calculate it
                    if (existingDelta == null || string.IsNullOrEmpty(existingDelta.Result) || Guid.TryParse(existingDelta.Result, out _))
                    {
                        try
                        {
                            var parts = row.CalculatedFormula.Split('|', StringSplitOptions.RemoveEmptyEntries);
                            var processedFormula = new System.Text.StringBuilder();
                            foreach (var p in parts)
                            {
                                string part = p.Trim();
                                if (Guid.TryParse(part, out _) || int.TryParse(part, out _))
                                    processedFormula.Append($"[{part}]");
                                else
                                    processedFormula.Append(part);
                            }

                            var expr = new Expression(processedFormula.ToString());
                            expr.Parameters = histParams;
                            var res = expr.Evaluate();
                            if (res != null)
                            {
                                string calcVal = res.ToString();
                                if (double.TryParse(calcVal, out double num))
                                    calcVal = Math.Round(num, 2).ToString();

                                if (existingDelta != null)
                                    existingDelta.Result = calcVal;
                                else
                                    deltaResults.Add(new DeltaResult { TestName = row.Col2, Result = calcVal });
                            }
                        }
                        catch { }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error calculating previous formulas: {ex.Message}");
        }
    }

