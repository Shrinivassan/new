    // Top Bar properties
    private int SelectedGroupCode { get; set; } = 0;   // 0 = All Groups

    // Group list built from lre1
    public class GroupItem
    {
        public int GCode { get; set; }
        public string GroupName { get; set; } = "";
    }
    private List<GroupItem> groupList = new();

    private void OnGroupChanged(ChangeEventArgs e)
    {
        SelectedGroupCode = int.TryParse(e.Value?.ToString(), out var code) ? code : 0;
        ApplyGroupFilter();
    }

    private void ApplyGroupFilter()
    {
        if (SelectedGroupCode == 0)
        {
            // All Groups — restore full lre and full billed test list
            lre = lre1;
        }
        else
        {
            // Filter result rows to selected group only
            lre = lre1.Where(x => x.GCode == SelectedGroupCode).ToList();
        }

        // Rebuild billed test selections scoped to the current group
        billedTestSelections = BuildBilledTestSelections(SelectedGroupCode);
        StateHasChanged();
    }

    /// <summary>
    /// Returns distinct TCode+TestName items from lre1, optionally scoped to a group.
    /// groupCode == 0 means all groups.
    /// </summary>
    private List<BilledTestItem> BuildBilledTestSelections(int groupCode)
    {
        var source = groupCode == 0
            ? lre1
            : lre1.Where(x => x.GCode == groupCode).ToList();

        return source
            .Where(x => x.TCode > 0 && !string.IsNullOrWhiteSpace(x.TestName))
            .GroupBy(x => x.TCode)                          // deduplicate by TCode
            .Select(g => new BilledTestItem
            {
                TCode    = g.Key,
                TestName = g.First().TestName!,
                IsSelected = true
            })
            .OrderBy(b => b.TestName)
            .ToList();
    }

