        var url = $"{appSettings.BaseUrl}labresult/loadresultentry?requestGuid={RequestGuid}&t={DateTime.Now.Ticks}";
        var request = new HttpRequestMessage(HttpMethod.Get, url);
        if (!string.IsNullOrEmpty(token))
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var res = await http.SendAsync(request);
        if (res.IsSuccessStatusCode)
        {
            var tt =await res.Content.ReadAsStringAsync();
            Console.WriteLine($"LOADED DATA RAW: {tt.Substring(0, Math.Min(tt.Length, 500))}..."); 

            re = JsonConvert.DeserializeObject<ResultEntryModel>(tt) ?? new();
            if (re.Results != null && re.Results.Any())
            {
                var firstRaw = tt.Contains("[") ? tt.Substring(tt.IndexOf("[") + 1, 500) : "";
                Console.WriteLine($"DEBUG - First row JSON snapshot: {firstRaw}");
            }

            lre1 = re.Results ?? new List<LabResultEntry>();
            lre1 = lre1.OrderBy(x => x.GroupOrder).ThenBy(x=>x.OrderNo).ThenBy(x => x.SLNo).ToList();
            lre = lre1;
            
            // Update CustCode from loaded data if not provided via URL
            if (string.IsNullOrEmpty(CustCode) && lre1.Any())
            {
                CustCode = lre1.FirstOrDefault()?.CustCode ?? "";
            }

            uom=re.Units ?? new List<UOM_MASTER>();
            sample=re.Samples ?? new List<Sample_Master>();
            machine=re.Machines ?? new List<Machine_Master>();
            method = re.Methods ?? new List<REPORT_METHOD>();
            // Build group list — distinct GCode + GroupName from lre1
            groupList = lre1
                .Where(x => x.GCode > 0 && !string.IsNullOrWhiteSpace(x.GroupName))
                .GroupBy(x => x.GCode)
                .Select(g => new GroupItem { GCode = g.Key, GroupName = g.First().GroupName! })
                .OrderBy(g => g.GroupName)
                .ToList();

            // Build billed test list scoped to current group (default: All Groups)
            billedTestSelections = BuildBilledTestSelections(SelectedGroupCode);

            // Trigger calculations for any pre-filled data
            _ = RunCalculations();
            
            UpdateUserNames();
        }else
        {
            var tt =await res.Content.ReadAsStringAsync();
        }
        StateHasChanged();
    }


    private List<DeltaResult>? deltaResults;
