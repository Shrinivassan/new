    private async Task RunCalculations()
    {
        await Task.Delay(20); 
        try
        {
            var parameters = new Dictionary<string, object>();
            
            foreach (var row in lre1)
            {
                if (double.TryParse(row.EnteredResult, out double val))
                {
                    string tc = row.TCode.ToString();
                    parameters[tc] = val;

                    // Also map by ID and safe name for backward compatibility
                    parameters[row.TestResultId.ToString().ToLower()] = val;
                    if (!string.IsNullOrEmpty(row.Col2))
                    {
                        string safeName = row.Col2.Replace(" ", "").Replace("(", "").Replace(")", "").Replace("-", "").Replace(".", "");
                        parameters[safeName] = val;
                    }
                }
            }

            bool changed = false;
            foreach (var row in lre1)
            {
                if (row.ResultValueType == "Calculated Value" && !string.IsNullOrEmpty(row.CalculatedFormula))
                {
                    try
                    {
                        // Logic for "1 | / | 2" where 1 and 2 are TCodes
                        var parts = row.CalculatedFormula.Split('|', StringSplitOptions.RemoveEmptyEntries);
                        var processedFormula = new System.Text.StringBuilder();

                        foreach (var p in parts)
                        {
                            string part = p.Trim();
                            bool isGuid = Guid.TryParse(part, out _);
                            bool isInt = int.TryParse(part, out _);

                            if (isGuid || isInt)
                            {
                                // If it's a GUID or TCode, treat it as a parameter
                                processedFormula.Append($"[{part}]");
                            }
                            else
                            {
                                // Otherwise append as operator (/, *, +, -, (, ) etc.)
                                processedFormula.Append(part);
                            }
                        }

                        var expr = new Expression(processedFormula.ToString());
                        expr.Parameters = parameters;
                        var res = expr.Evaluate();
                        if (res != null)
                        {
                            string newResult = res.ToString();
                            if (double.TryParse(newResult, out double num))
                                newResult = Math.Round(num, 2).ToString();

                            if (row.EnteredResult != newResult)
                            {
                                row.EnteredResult = newResult;
                                changed = true;
                            }
                        }
                    }
                    catch (Exception)
                    {
                    }
                }
            }
            if (changed) await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

