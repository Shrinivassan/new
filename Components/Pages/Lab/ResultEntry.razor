    // Comments Tab Properties
    private string FooterMessageText { get; set; } = "";
    private bool PrintConclusionInReport { get; set; } = false;
    private string ConclusionText { get; set; } = "";

    private string BottomSample { get; set; } = "";

    // Bottom Bar Properties
    private string PageSetupValue { get; set; } = "General";
