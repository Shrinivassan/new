<script>
    window.initDraggablePopup = function(headerId, panelId) {
        var header = document.getElementById(headerId);
        var panel = document.getElementById(panelId);
        if (!header || !panel || header.dataset.dragInitialized) return;
        
        header.dataset.dragInitialized = "true";
        var isDragging = false;
        var startX, startY, initialTop, initialRight;
        
        header.style.cursor = 'grab';
        
        header.onmousedown = function (e) {
            if(e.target.closest('button')) return;
            isDragging = true;
            header.style.cursor = 'grabbing';
            startX = e.clientX;
            startY = e.clientY;
            
            var style = window.getComputedStyle(panel);
            initialTop = parseInt(style.top, 10) || 10;
            initialRight = parseInt(style.right, 10) || 16;
            
            document.onmousemove = function(e2) {
                if(isDragging) {
                    var dx = e2.clientX - startX;
                    var dy = e2.clientY - startY;
                    panel.style.top = (initialTop + dy) + 'px';
                    panel.style.right = (initialRight - dx) + 'px';
                    e2.preventDefault();
                }
            };
            document.onmouseup = function() {
                isDragging = false;
                header.style.cursor = 'grab';
                document.onmousemove = null;
                document.onmouseup = null;
            };
        };
    };

    window.gridNavigation = {
        focusNext: function (nextId) {
            setTimeout(function() {
                var element = document.getElementById(nextId);
                if (element) {
                    element.focus();
                    if (element.tagName === 'INPUT' || element.tagName === 'TEXTAREA') {
                        element.select();
                    }
                }
            }, 10);
        }
    };
</script>

@code {
    [SupplyParameterFromQuery(Name = "requestGuid")]
    public string RequestGuid { get; set; } = "";

    [SupplyParameterFromQuery(Name = "custcode")]
    public string CustCode { get; set; } = "";

    // Top Bar properties
    private int SelectedGroupCode { get; set; } = 0;   // 0 = All Groups

    // Group list built from lre1
    public class GroupItem
    {
        public int GCode { get; set; }
        public string GroupName { get; set; } = "";
    }
    private List<GroupItem> groupList = new();

    private void OnGroupChanged(ChangeEventArgs e)
    {
        SelectedGroupCode = int.TryParse(e.Value?.ToString(), out var code) ? code : 0;
        ApplyGroupFilter();
    }

    private void ApplyGroupFilter()
    {
        if (SelectedGroupCode == 0)
        {
            // All Groups — restore full lre and full billed test list
            lre = lre1;
        }
        else
        {
            // Filter result rows to selected group only
            lre = lre1.Where(x => x.GCode == SelectedGroupCode).ToList();
        }

        // Rebuild billed test selections scoped to the current group
        billedTestSelections = BuildBilledTestSelections(SelectedGroupCode);
        StateHasChanged();
    }

    /// <summary>
    /// Returns distinct TCode+TestName items from lre1, optionally scoped to a group.
    /// groupCode == 0 means all groups.
    /// </summary>
    private List<BilledTestItem> BuildBilledTestSelections(int groupCode)
    {
        var source = groupCode == 0
            ? lre1
            : lre1.Where(x => x.GCode == groupCode).ToList();

        return source
            .Where(x => x.TCode > 0 && !string.IsNullOrWhiteSpace(x.TestName))
            .GroupBy(x => x.TCode)                          // deduplicate by TCode
            .Select(g => new BilledTestItem
            {
                TCode    = g.Key,
                TestName = g.First().TestName!,
                IsSelected = true
            })
            .OrderBy(b => b.TestName)
            .ToList();
    }

    // Sample Row properties
    private string SampleIdPrefix { get; set; } = "AAM";
    private string SampleIdMiddle { get; set; } = "";
    private string SampleIdSuffix { get; set; } = "";
    private bool IsSampleDateEnabled { get; set; } = true;
    private DateTime? SampleDate { get; set; } = DateTime.Today;
    private DateTime? SampleTime { get; set; } = DateTime.Now;

    // Tabs
    private string ActiveTab { get; set; } = "Reading";
    private string RightTab { get; set; } = "Settings";

    // Table Data Object (Bound to inputs to avoid fake data, but matches screenshot)
    public class TestItem
    {
        public string Description { get; set; } = "";
        public string Run { get; set; } = "";
        public string Result { get; set; } = "";
        public string Units { get; set; } = "";
        public string NormalValues { get; set; } = "";
        public string MachineName { get; set; } = "Machine";
        public string Specimen { get; set; } = "Specimen";
        public string Status { get; set; } = "";
    }

    // Instance of a test entry for binding
    private TestItem NewTest { get; set; } = new TestItem();

    // Right Panel Properties
    private string ResultType { get; set; } = "Text & Number";
    private string ResultText { get; set; } = "";
    private string AlertType { get; set; } = "Normal";
    private bool PrintResultsOnly { get; set; } = false;
