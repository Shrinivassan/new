    private void UpdateUserNames()
    {
        if (usermaster != null && usermaster.Any() && lre1 != null && lre1.Any())
        {
            // Aggregating IDs from all rows to find any recorded authorization
            int entId = lre1.Where(x => x.ResultEnteredBy > 0).Select(x => x.ResultEnteredBy).FirstOrDefault();
            int auth1Id = lre1.Where(x => x.ResultAuthorizedBy > 0).Select(x => x.ResultAuthorizedBy).FirstOrDefault();
            int auth2Id = lre1.Where(x => x.ResultAuthorizedBy2 > 0).Select(x => x.ResultAuthorizedBy2).FirstOrDefault();
            
            // Try to find ANY non-zero ID if the aggregation failed
            if (entId == 0) entId = lre1.Max(x => x.ResultEnteredBy);
            if (auth1Id == 0) auth1Id = lre1.Max(x => x.ResultAuthorizedBy);
            if (auth2Id == 0) auth2Id = lre1.Max(x => x.ResultAuthorizedBy2);

            // Only update if we found a valid ID, otherwise keep the previous known name to prevent flickering
            if (entId > 0)
                ent1 = usermaster.Where(x => x.UserCode == entId).Select(x => x.Name).FirstOrDefault() ?? (entId == 1 ? "Admin" : "");
            
            if (auth1Id > 0)
                auth1 = usermaster.Where(x => x.UserCode == auth1Id).Select(x => x.Name).FirstOrDefault() ?? (auth1Id == 1 ? "Admin" : "");
            
            if (auth2Id > 0)
                auth2 = usermaster.Where(x => x.UserCode == auth2Id).Select(x => x.Name).FirstOrDefault() ?? (auth2Id == 1 ? "Admin" : "");
            
            isAuth2Finished = lre1.Any(x => x.IsAuthorized2 || x.ResultAuthorizedBy2 > 0);
            
        StateHasChanged();
        }
    }
