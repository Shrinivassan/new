            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowError($"Error: {ex.Message}");
        }
    }

    private async Task SaveResultAsync()
    {
        if (!isentered && !isauthorized)
        {
            await NotificationService.ShowError("You do not have rights to save the record.");
            return;
        }

        // Validation logic
        if (string.IsNullOrEmpty(saveModel.ReportingMethod) || string.IsNullOrEmpty(saveModel.Sample))
        {
            showValidationErrors = true;
            await NotificationService.ShowWarning("Please fill all required fields.");
            StateHasChanged();
            return;
        }

        showValidationErrors = false;

        try
        {
            // Prepare the bulk request container
            var requestsToSave = new List<SaveCultureResultRequestDto>();

            // Iterate through all tab states that have been initialized/loaded
            foreach (var stateEntry in TabStates)
            {
                var state = stateEntry.Value;
                if (!state.DataLoaded) continue; // Skip tabs the user never opened

                var sm = state.saveModel;
                var sections = state.SectionResults;

                // 1. Sync UI state if this is the ACTIVE tab
                if (ActiveCultureTab != null)
                {
                    var currentKey = $"{ActiveCultureTab.ResultCultureGUID}-{ActiveCultureTab.TCode}-{ActiveCultureTab.OrderNo}";
                    if (stateEntry.Key == currentKey)
                    {
                        sm.IsGrowth = IsGrowth;
                        // EnteredBy/AuthorizedBy are already synced back in SelectTab or set here
                        if (isentered && sm.EnteredByCode == null) sm.EnteredByCode = currentUser?.UserCode;
                    }
                }

                // 2. Prepare Isolation Rows for this tab
                sm.IsolationRows.Clear();
                var allRows = sections.Values
                                .SelectMany(x => x)
                                .GroupBy(r => (r.AntibioticName ?? "").Trim())
                                .Select(g => {
                                    var merged = g.First();
                                    foreach(var other in g.Skip(1))
                                    {
                                        if (!string.IsNullOrEmpty(other.Isolation_A)) { merged.Isolation_A = other.Isolation_A; merged.DiskContentA = other.DiskContentA; merged.MMA1 = other.MMA1; }
                                        if (!string.IsNullOrEmpty(other.Isolation_B)) { merged.Isolation_B = other.Isolation_B; merged.DiskContentB = other.DiskContentB; merged.MMA2 = other.MMA2; }
                                        if (!string.IsNullOrEmpty(other.Isolation_C)) { merged.Isolation_C = other.Isolation_C; merged.DiskContentC = other.DiskContentC; merged.MMA3 = other.MMA3; }
                                    }
                                    return merged;
                                })
                                .ToList();

                int sno = 1;
                foreach (var item in allRows)
                {
                    item.Sno = sno;
                    item.ActualSno = sno;
                    item.ColumnName = item.AntibioticName; 
                    item.ReportStatus = sm.ReportStatus ?? "Final Report";
                    item.TCode = sm.TCode ?? 0;
                    sm.IsolationRows.Add(item);
                    sno++;
                }

                // 3. Set mandatory metadata
                sm.RequestGUID = RequestGuid;
                sm.UserCode = currentUser?.UserCode;
                sm.ComputerCode = 1;
                
                if (sm.RECode == null || sm.RECode == 0) sm.RECode = 0;
                if (sm.RTMCode == null || sm.RTMCode == 0) sm.RTMCode = 1;
                if (sm.CFCode == null || sm.CFCode == 0) sm.CFCode = 1;

                sm.IsIsolationA = sections["A"].Any();
                sm.IsIsolationB = sections["B"].Any();
                sm.IsIsolationC = sections["C"].Any();

                requestsToSave.Add(sm);
            }

            if (!requestsToSave.Any())
            {
                await NotificationService.ShowWarning("No data to save.");
                return;
            }

            // 4. Finalize mapping and send as a bulk list
            foreach (var sm in requestsToSave)
            {
                sm.FooterText = sm.NoteMessage;
                sm.Description = sm.Comments ;
                if (sm.SampleDate == null) sm.SampleDate = sm.SampleReceivedDate;
            }

            var json = JsonConvert.SerializeObject(requestsToSave, new JsonSerializerSettings 
            { 
                NullValueHandling = NullValueHandling.Include,
                ContractResolver = new Newtonsoft.Json.Serialization.CamelCasePropertyNamesContractResolver(),
                Formatting = Formatting.Indented 
            });
            
            Console.WriteLine("====== SAVE PAYLOAD ======");
            Console.WriteLine(json);
            Console.WriteLine("==========================");

            var req_content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
            var request = new HttpRequestMessage(HttpMethod.Post, $"{AppSettings.BaseUrl}Culture/save");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            request.Content = req_content;

            var res = await http.SendAsync(request);
            if (res.IsSuccessStatusCode)
            {
                await NotificationService.ShowSuccess("Culture results saved successfully!");
                TabStates.Clear(); 
                await LoadTabsAsync(); 
            }
            else
            {
                var errorText = await res.Content.ReadAsStringAsync();
                await NotificationService.ShowError($"Failed to save: {errorText}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception in SaveResultAsync: {ex.Message}");
            await NotificationService.ShowError($"Error: {ex.Message}");
        }
    }

