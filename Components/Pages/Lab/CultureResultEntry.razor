                        <label class="cre-label">Select Culture</label>
                        <select class="cre-select">
                            <option>-- Select Culture --</option>
                        </select>
                    </div>
                    
                    <div class="cre-field-group align-top">
                        <label class="cre-label">Report Status</label>
                        <div class="cre-radio-group">
                            <label class="cre-radio-label">
                                <input type="radio" name="reportStatus" checked />
                                <span class="cre-radio-mark"></span> Preliminary
                            </label>
                            <label class="cre-radio-label">
                                <input type="radio" name="reportStatus" />
                                <span class="cre-radio-mark"></span> Supplementary
                            </label>
                            <label class="cre-radio-label">
                                <input type="radio" name="reportStatus" />
                                <span class="cre-radio-mark"></span> Final Report
                            </label>
                        </div>
                    </div>

                    <div class="cre-field-group align-top">
                        <label class="cre-label">Growth</label>
                        <div class="cre-radio-group">
                            <label class="cre-radio-label">
                                <input type="radio" name="growth" />
                                <span class="cre-radio-mark"></span> No Growth
                            </label>
                            <label class="cre-radio-label">
                                <input type="radio" name="growth" />
                                <span class="cre-radio-mark"></span> Growth
                            </label>
                        </div>
                    </div>

                    <div class="cre-field-group">
                        <label class="cre-label">Reporting Method</label>
                        <select class="cre-select">
                            <option>-- Select Method --</option>
                        </select>
                    </div>

                    <div class="cre-field-group">
                        <label class="cre-label">Sample</label>
                        <select class="cre-select">
                            <option>-- Select Sample --</option>
                        </select>
                    </div>

                    <div class="cre-field-group align-top">
                        <label class="cre-label">Direct Smear</label>
                        <textarea class="cre-textarea" rows="2"></textarea>
                    </div>

                    <div class="cre-field-group align-top">
                        <label class="cre-label">Growth Grade</label>
                        <textarea class="cre-textarea" rows="2"></textarea>
                    </div>
                </div>

                <!-- Middle Column -->
                <div class="cre-form-column">
                    <div class="cre-field-group">
                        <label class="cre-label">Sample Date</label>
                        <div class="cre-datetime-group">
                            <input type="date" class="cre-input" />
                            <input type="time" class="cre-input" />
                        </div>
                    </div>

                    <div class="cre-field-group">
                        <label class="cre-label">Reported Date</label>
                        <div class="cre-datetime-group">
                            <input type="date" class="cre-input" />
                            <input type="time" class="cre-input" />
                        </div>
                    </div>

                    <div class="cre-field-group">
                        <label class="cre-label">Smear for AFB</label>
                        <input type="text" class="cre-input" />
                    </div>

                    <div class="cre-field-group">
                        <label class="cre-label">PUS Cells</label>
                        <input type="text" class="cre-input" />
                    </div>

                    <div class="cre-field-group">
                        <label class="cre-label">Gram's Staining</label>
                        <input type="text" class="cre-input" />
                    </div>

                    <div class="cre-field-group align-top">
                        <label class="cre-label">Diagnosis</label>
                        <textarea class="cre-textarea" rows="3"></textarea>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="cre-form-column">
                    <div class="cre-user-info-box">
                        <div class="cre-user-row">
                            <span class="cre-label-user">Entered by</span>
                            <span class="separator">:</span>
                            <span class="cre-value-user">--</span>
                        </div>
                        <div class="cre-user-row">
                            <span class="cre-label-user">Authorized by</span>
                            <span class="separator">:</span>
                            <span class="cre-value-user">--</span>
                        </div>
                    </div>

                    <div class="cre-vitek-panel">
                        <div class="cre-vitek-header">Vitek Results</div>
                        <div class="cre-vitek-table-wrap">
                            <table class="cre-table cre-table-sm">
                                <thead>
                                    <tr>
                                        <th>Sample</th>
                                        <th>Organism</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>&nbsp;</td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                    <tr>
                                        <td>&nbsp;</td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="cre-vitek-actions">
                            <button class="cre-btn-link">Load to (A)</button>
                            <button class="cre-btn-link">Load to (B)</button>
                            <button class="cre-btn-link">Load to (C)</button>
