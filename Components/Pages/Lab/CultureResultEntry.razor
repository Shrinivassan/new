    private async Task PrintReportAsync()
    {
        try
        {
            if (string.IsNullOrEmpty(RequestGuid) || CultureTabs == null || !CultureTabs.Any()) return;

            var reportRequest = new CultureReportRequestDto();
            reportRequest.Specimens = new List<CultureReportSpecimenDto>();

            foreach (var tab in CultureTabs)
            {
                var specimen = new CultureReportSpecimenDto
                {
                    ClientID = AppSettings.ClientId,
                    ReportName = "CultureReport",
                    RequestGUID = RequestGuid,
                    DataSource = "DataSet1",
                    TCode = new List<string> { tab.TCode.ToString() },
                    Parameters = new List<CultureReportParameterDto>
                    {
                        new CultureReportParameterDto { Name = "RequestGUID", Values = new List<string> { RequestGuid } },
                        new CultureReportParameterDto { Name = "TCode", Values = new List<string> { tab.TCode.ToString() } },
                        new CultureReportParameterDto { Name = "ReportStatus", Values = new List<string> { tab.ReportStatus ?? "Preliminary" } },
                        new CultureReportParameterDto { Name = "IsLetterHead", Values = new List<string> { isLetterHead.ToString().ToLower() } },
                        new CultureReportParameterDto { Name = "PageTop", Values = new List<string> { "100" } },
                        new CultureReportParameterDto { Name = "PageBottom", Values = new List<string> { "50" } }
                    }
                };
                reportRequest.Specimens.Add(specimen);
            }

            var response = await http.PostAsJsonAsync("https://birdapi.iscansoft.com/api/CultureReport/CultureReportMulti", reportRequest);
            if (response.IsSuccessStatusCode)
            {
                var base64Result = await response.Content.ReadAsStringAsync();
                if (!string.IsNullOrEmpty(base64Result))
                {
                    reportstring = base64Result.Trim('"'); // Remove potential quotes
                    
                    // Populate reportrequest for ReportViewer
                    reportrequest = new PreNatalRequest
                    {
                        RequestGUID = Guid.TryParse(RequestGuid, out var g) ? g : Guid.Empty,
                        PatientName = billData?.customer?.Name ?? "",
                        RequestSnoPrint = billData?.Request_Master?.RequestSnoPrint ?? "",
                        SkyCode = "Culture"
                    };

                    isviewer = true;
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error printing report: {ex.Message}");
        }
    }

