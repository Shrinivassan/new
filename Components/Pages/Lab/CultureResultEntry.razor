    private async Task LoadDataAsync()
    {
        if (ActiveCultureTab == null) return;
        var guidToUse = ActiveCultureTab.ResultCultureGUID ?? "";

        try
        {
            // Load Culture Entry Result Data
            var cultureReq = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}Culture/entry?resultCultureGuid={guidToUse}");
            if (!string.IsNullOrEmpty(token))
                cultureReq.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var cultureRes = await http.SendAsync(cultureReq);
            if (cultureRes.IsSuccessStatusCode)
            {
                var cultureContent = await cultureRes.Content.ReadAsStringAsync();
                var jsonResponse = Newtonsoft.Json.Linq.JObject.Parse(cultureContent);
                var data = jsonResponse["data"];
                var e = (data != null && data.HasValues) ? data : jsonResponse;
                
                // Look into the "master" object for main fields
                var m = e["master"];
                if (m != null)
                {
                    saveModel.ReportStatus     = m["reportStatus"]?.ToString();
                    saveModel.IsGrowth         = m["isGrowth"]?.ToObject<bool?>();
                    saveModel.ReportingMethod  = m["reportingMethod"]?.ToString();
                    saveModel.Sample           = m["sample"]?.ToString();
                    saveModel.Bacteria         = m["bacteria"]?.ToString();
                    saveModel.GrowthGrade      = m["growthGrade"]?.ToString();
                    saveModel.SmearAFB         = m["smearAFB"]?.ToString();
                    saveModel.PUSCells         = m["pusCells"]?.ToString();
                    saveModel.GramsStaining    = m["gramsStaining"]?.ToString();
                    saveModel.Diagnosis        = m["diagnosis"]?.ToString();
                    saveModel.RECode           = m["reCode"]?.ToObject<decimal?>();
                    
                    // Mapping Organisms (JSON 'organismsGrown' is the first section)
                    saveModel.OrganismsGrownA  = m["organismsGrown"]?.ToString();
                    saveModel.OrganismsGrownB  = m["organismsGrownB"]?.ToString();
                    saveModel.OrganismsGrownC  = m["organismsGrownC"]?.ToString();
                    
                    // Mapping Colony Counts
                    saveModel.ColonyCountA     = m["colonyCount"]?.ToString();
                    saveModel.ColonyCountB     = m["colonyCountB"]?.ToString();
                    saveModel.ColonyCountC     = m["colonyCountC"]?.ToString();
                    
                    // Mapping Comments
                    saveModel.CommentsA        = m["commentsA"]?.ToString();
                    saveModel.CommentsB        = m["commentsB"]?.ToString();
                    saveModel.CommentsC        = m["commentsC"]?.ToString();
                    saveModel.Comments         = m["comments"]?.ToString();
                    saveModel.NoteMessage      = m["footerText"]?.ToString();

                    saveModel.IsAuthorized = m["isAuthorized"]?.ToObject<bool?>();
                    saveModel.EnteredByCode = m["resultEnteredBy"]?.ToObject<int?>();
                    saveModel.AuthorizedByCode = m["resultAuthorizedby"]?.ToObject<int?>();

                    if (usermaster != null && usermaster.Count > 0)
                    {
                        if (saveModel.EnteredByCode.HasValue)
                        {
                            EnteredByName = usermaster.FirstOrDefault(x => x.UserCode == saveModel.EnteredByCode.Value)?.Name ?? "--";
                        }
                        if (saveModel.AuthorizedByCode.HasValue)
                        {
                            AuthorizedByName = usermaster.FirstOrDefault(x => x.UserCode == saveModel.AuthorizedByCode.Value)?.Name ?? "--";
                        }
                    }

                    // Dates
                    if (DateTime.TryParse(m["sampleReceivedDate"]?.ToString(), out var sd)) saveModel.SampleReceivedDate = sd;
                    if (DateTime.TryParse(m["cultureReportedDate"]?.ToString(), out var rd)) saveModel.CultureReportedDate = rd;

                    // Important: Explicitly set identifying properties for updates
                    saveModel.ResultCultureGUID = guidToUse;
                    saveModel.TCode = ActiveCultureTab.TCode;
                    saveModel.RequestGUID = RequestGuid;

                    // Sync Growth toggle for UI
                    IsGrowth = saveModel.IsGrowth ?? false;
                }
                else
                {
                    // If no master found, at least reset form basic state
                    saveModel = new SaveCultureResultRequestDto 
                    { 
                        ResultCultureGUID = ActiveCultureTab.ResultCultureGUID ?? "", 
                        RequestGUID = RequestGuid,
                        TCode = ActiveCultureTab.TCode
                    };
                    IsGrowth = false;
                }

                // 3. Restore Isolation Rows from the "iso" array
                SectionResults["A"] = new List<CultureIsolationRowDto>();
                SectionResults["B"] = new List<CultureIsolationRowDto>();
                SectionResults["C"] = new List<CultureIsolationRowDto>();

                var isoArray = (e["iso"] ?? e["isolationRows"] ?? e["IsolationRows"]) as Newtonsoft.Json.Linq.JArray;
                if (isoArray != null && isoArray.Count > 0)
                {
                    // 1. Load all rows into a flat list
                    var flatList = new List<CultureIsolationRowDto>();
                    foreach (var rowToken in isoArray)
                    {
                        var row = new CultureIsolationRowDto
                        {
                            LCDIIID        = (rowToken["lcdiiid"] ?? rowToken["LCDIIID"]) != null && Guid.TryParse((rowToken["lcdiiid"] ?? rowToken["LCDIIID"])?.ToString(), out var g) ? g : null,
                            AntibioticName = (rowToken["columnName"] ?? rowToken["ColumnName"] ?? rowToken["antibioticName"] ?? rowToken["AntibioticName"] ?? rowToken["abName"])?.ToString()?.Trim(),
                            ABCode         = (rowToken["abCode"] ?? rowToken["ABCode"])?.ToObject<int?>(),
                            TCode          = (rowToken["tCode"] ?? rowToken["TCode"])?.ToObject<int?>(),
                            Sno            = (rowToken["sno"] ?? rowToken["Sno"])?.ToObject<int?>(),
                            ActualSno      = (rowToken["actualSno"] ?? rowToken["ActualSno"])?.ToObject<int?>(),
                            ColumnName     = (rowToken["columnName"] ?? rowToken["ColumnName"])?.ToString()?.Trim(),
                            ReportStatus   = (rowToken["reportStatus"] ?? rowToken["ReportStatus"])?.ToString(),
                            
                            Isolation_A    = (rowToken["isolation_A"] ?? rowToken["Isolation_A"] ?? rowToken["isolation_a"] ?? rowToken["isolationA"] ?? rowToken["IsolationA"])?.ToString(),
                            DiskContentA   = (rowToken["diskContentA"] ?? rowToken["DiskContentA"] ?? rowToken["diskcontenta"] ?? rowToken["diskA"])?.ToString(),
                            MMA1           = (rowToken["mma1"] ?? rowToken["MMA1"] ?? rowToken["mmA1"] ?? rowToken["mm1"])?.ToString(),
                            
                            Isolation_B    = (rowToken["isolation_B"] ?? rowToken["Isolation_B"] ?? rowToken["isolation_b"] ?? rowToken["isolationB"] ?? rowToken["IsolationB"])?.ToString(),
                            DiskContentB   = (rowToken["diskContentB"] ?? rowToken["DiskContentB"] ?? rowToken["diskcontentb"] ?? rowToken["diskB"])?.ToString(),
                            MMA2           = (rowToken["mma2"] ?? rowToken["MMA2"] ?? rowToken["mmA2"] ?? rowToken["mm2"])?.ToString(),
                            
                            Isolation_C    = (rowToken["isolation_C"] ?? rowToken["Isolation_C"] ?? rowToken["isolation_c"] ?? rowToken["isolationC"] ?? rowToken["IsolationC"])?.ToString(),
                            DiskContentC   = (rowToken["diskContentC"] ?? rowToken["DiskContentC"] ?? rowToken["diskcontentc"] ?? rowToken["diskC"])?.ToString(),
                            MMA3           = (rowToken["mma3"] ?? rowToken["MMA3"] ?? rowToken["mmA3"] ?? rowToken["mm3"])?.ToString(),
                        };

                        // Fallback: If AntibioticName is still null but ABCode is present, look it up in the master list
                        if (string.IsNullOrEmpty(row.AntibioticName) && row.ABCode.HasValue)
                        {
                            row.AntibioticName = AntibioticsMasterList.FirstOrDefault(a => a.ABCode == row.ABCode.Value)?.Name;
                        }

                        // Ensure ColumnName is also set if it's the antibiotic name
                        if (string.IsNullOrEmpty(row.ColumnName)) row.ColumnName = row.AntibioticName;

                        flatList.Add(row);
                    }

                    // 2. Merge duplicate rows by name to clean up any legacy pollution
                    var mergedRows = flatList
                                        .GroupBy(r => r.AntibioticName ?? "")
                                        .Select(g => {
                                            var merged = g.First();
                                            foreach(var other in g.Skip(1))
                                            {
                                                if (!string.IsNullOrEmpty(other.Isolation_A)) { merged.Isolation_A = other.Isolation_A; merged.DiskContentA = other.DiskContentA; merged.MMA1 = other.MMA1; }
                                                if (!string.IsNullOrEmpty(other.Isolation_B)) { merged.Isolation_B = other.Isolation_B; merged.DiskContentB = other.DiskContentB; merged.MMA2 = other.MMA2; }
                                                if (!string.IsNullOrEmpty(other.Isolation_C)) { merged.Isolation_C = other.Isolation_C; merged.DiskContentC = other.DiskContentC; merged.MMA3 = other.MMA3; }
                                            }
                                            return merged;
                                        })
                                        .ToList();

                    // 3. Add to appropriate UI grid based on which column has data
                    foreach(var row in mergedRows)
                    {
                        if (!string.IsNullOrEmpty(row.Isolation_A)) SectionResults["A"].Add(row);
                        if (!string.IsNullOrEmpty(row.Isolation_B)) SectionResults["B"].Add(row);
                        if (!string.IsNullOrEmpty(row.Isolation_C)) SectionResults["C"].Add(row);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in LoadDataAsync: {ex.Message}");
        }
    }

    private async Task AuthorizeResultAsync()
    {
        if (currentUser == null || !isauthorized || ActiveCultureTab == null) return;

        try
        {
            var req = new AuthorizeCultureRequestDto
            {
                ResultCultureGUID = ActiveCultureTab.ResultCultureGUID ?? "",
                AuthorizedByCode = currentUser.UserCode,
                ReportStatus = "Final Report"
            };

            var request = new HttpRequestMessage(HttpMethod.Post, $"{AppSettings.BaseUrl}Culture/authorize?requestGuid={RequestGuid}");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
                
            request.Content = new StringContent(JsonConvert.SerializeObject(req), System.Text.Encoding.UTF8, "application/json");

            var res = await http.SendAsync(request);
            if (res.IsSuccessStatusCode)
            {
                await NotificationService.ShowSuccess("Culture result authorized successfully!");
                TabStates.Clear(); 
                await LoadTabsAsync(); // Refresh state
            }
            else
            {
                var errorText = await res.Content.ReadAsStringAsync();
                await NotificationService.ShowError($"Failed to authorize: {errorText}");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowError($"Error: {ex.Message}");
        }
    }

