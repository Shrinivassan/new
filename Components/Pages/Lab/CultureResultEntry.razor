@page "/culture-result-entry"
@using Lims.Components.Model
@using LIMS.Model
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using System.Net.Http.Headers
@using Newtonsoft.Json
@inject HttpClient http
@inject IJSRuntime JSRuntime
@inject LIMS.Model.AppSettings AppSettings
@inject ProtectedSessionStorage _sessionStorage
@inject NavigationManager NavigationManager
@inject Lims.Components.Data.NotificationService NotificationService
@rendermode InteractiveServer
@using Syncfusion.Blazor.Popups
@using Lims.Components.Pages

<div class="cre-container">
    <!-- Header -->
    <div class="cre-header-section">
        <div class="cre-breadcrumb">
            <i class="fas fa-home"></i> 
            <span class="cre-text-muted">Lab</span> 
            <i class="fas fa-chevron-right separator"></i> 
            <span class="active">Culture Result Entry</span>
        </div>
        <div class="cre-header-right">
            <!-- Any top level actions -->
        </div>
    </div>

    <!-- Tabs Navigation -->
    @if (CultureTabs != null && CultureTabs.Any())
    {
        <div class="cre-tabs-nav">
            @{
                int tabIdx = 1;
            }
            @foreach (var tab in CultureTabs)
            {
                var currentIdx = tabIdx++;
                <div class="cre-tab-card @(ActiveCultureTab == tab ? "active" : "")" 
                     @onclick="() => SelectTab(tab)">
                    <div class="cre-tab-index-box">@currentIdx</div>
                    <div class="cre-tab-info">
                        <div class="cre-tab-label">CULTURE TYPE</div>
                        <div class="cre-tab-title">@(tab.TestName?.ToUpper() ?? "UNKNOWN")</div>
                    </div>
                    @if (tab.IsAuthorized == true)
                    {
                        <div class="cre-tab-status">
                            <i class="fas fa-check-circle"></i>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="cre-loading-container">
            <div class="cre-spinner"></div>
            <div class="cre-loading-text">Searching for culture tests...</div>
        </div>
    }

    <!-- Patient Info Banner -->
    <div class="cre-panel-card cre-patient-banner">
        <div class="cre-patient-details">
            <span class="cre-highlight-text cre-bold">@(billData?.customer?.Name ?? "--Patient Name--")</span>
            <span class="cre-soft-text">(@(billData?.customer?.AgeYears.ToString() ?? "--")Yrs/@(billData?.customer?.Gender ?? "--"))</span>
        </div>
        <div class="cre-ref-details">
            <span class="cre-label-inline">Ref.by :</span>
            <span class="cre-value">@(billData?.Request_Master?.Reference ?? "--")</span>
        </div>
        <div class="cre-sid-details">
            <span class="cre-label-inline">SID.No :</span>
            <span class="cre-value cre-highlight-text">@(billData?.Request_Master?.RequestSnoPrint ?? "--/--/----")</span>
        </div>

    </div>

    <!-- Main Content Area -->
    <div class="cre-main-content" @key="@($"{ActiveCultureTab?.ResultCultureGUID}-{ActiveCultureTab?.TCode}")">
        <!-- Top Section: 3 Columns -->
        <div class="cre-panel-card cre-top-section">
            <div class="cre-top-grid">
                <!-- Left Column -->
                <div class="cre-form-column">
                    @* Removed Select Culture dropdown as it is replaced by the tab navigation above *@
                    
                    <div class="cre-field-group align-top">
                        <label class="cre-label">Report Status</label>
                        <div class="cre-radio-group">
                            <label class="cre-radio-label">
                                <input type="radio" name="reportStatus" checked="@(saveModel.ReportStatus == "Preliminary")" @onchange="@(() => saveModel.ReportStatus = "Preliminary")" />
                                <span class="cre-radio-mark"></span> Preliminary
                            </label>
                            <label class="cre-radio-label">
                                <input type="radio" name="reportStatus" checked="@(saveModel.ReportStatus == "Supplementary")" @onchange="@(() => saveModel.ReportStatus = "Supplementary")" />
                                <span class="cre-radio-mark"></span> Supplementary
                            </label>
                            <label class="cre-radio-label">
                                <input type="radio" name="reportStatus" checked="@(saveModel.ReportStatus == "Final Report")" @onchange="@(() => saveModel.ReportStatus = "Final Report")" />
                                <span class="cre-radio-mark"></span> Final Report
                            </label>
                        </div>
                    </div>

                    <div class="cre-field-group align-top">
                        <label class="cre-label">Growth</label>
                        <div class="cre-radio-group">
                            <label class="cre-radio-label">
                                <input type="radio" name="growth" value="No Growth" checked="@(!IsGrowth)" @onchange="@(e => OnGrowthChange(false))" />
                                <span class="cre-radio-mark"></span> No Growth
                            </label>
                            <label class="cre-radio-label">
                                <input type="radio" name="growth" value="Growth" checked="@IsGrowth" @onchange="@(e => OnGrowthChange(true))" />
                                <span class="cre-radio-mark"></span> Growth
                            </label>
                        </div>
                    </div>

                    <div class="cre-field-group">
                        <label class="cre-label">Reporting Method <span class="text-danger">*</span></label>
                        <div class="cre-input-container">
                            <input type="text" class="cre-input @(showValidationErrors && string.IsNullOrEmpty(saveModel.ReportingMethod) ? "cre-input-error" : "")" @bind="saveModel.ReportingMethod" />
                        </div>
                    </div>

                    <div class="cre-field-group">
                        <label class="cre-label">Sample <span class="text-danger">*</span></label>
                        <div class="cre-input-container">
                            <select class="cre-select @(showValidationErrors && string.IsNullOrEmpty(saveModel.Sample) ? "cre-select-error" : "")" @bind="saveModel.Sample">
                                <option value="">-- Select Sample --</option>
                                @foreach(var sample in SamplesList)
                                {
                                    <option value="@sample.Name">@sample.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="cre-field-group align-top">
                        <label class="cre-label">Direct Smear</label>
                        <textarea class="cre-textarea" rows="2" @bind="saveModel.Bacteria"></textarea>
                    </div>
                </div>

                <!-- Middle Column -->
                <div class="cre-form-column">
                    <div class="cre-field-group">
                        <label class="cre-label">Sample Date</label>
                        <div class="cre-datetime-group">
                            <input type="date" class="cre-input" @bind="saveModel.SampleReceivedDate" />
                        </div>
                    </div>

                    <div class="cre-field-group">
                        <label class="cre-label">Reported Date</label>
                        <div class="cre-datetime-group">
                            <input type="date" class="cre-input" @bind="saveModel.CultureReportedDate" />
                        </div>
                    </div>

                    <div class="cre-field-group">
                        <label class="cre-label">Smear for AFB</label>
                        <input type="text" class="cre-input" @bind="saveModel.SmearAFB" />
                    </div>

                    <div class="cre-field-group">
                        <label class="cre-label">PUS Cells</label>
                        <input type="text" class="cre-input" @bind="saveModel.PUSCells" />
                    </div>

                    <div class="cre-field-group align-top">
                        <label class="cre-label">Gram's Staining</label>
                        <textarea class="cre-textarea" rows="2" @bind="saveModel.GramsStaining"></textarea>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="cre-form-column">
                    <div class="cre-user-info-box">
                        <div class="cre-user-row">
                            <span class="cre-label-user">Entered by</span>
                            <span class="separator">:</span>
                            <span class="cre-value-user">@EnteredByName</span>
                        </div>
                        <div class="cre-user-row">
                            <span class="cre-label-user">Authorized by</span>
                            <span class="separator">:</span>
                            <span class="cre-value-user">@AuthorizedByName</span>
                        </div>
                    </div>

                    <div class="cre-field-group align-top">
                        <label class="cre-label">Growth Grade</label>
                        <textarea class="cre-textarea" rows="2" @bind="saveModel.GrowthGrade"></textarea>
                    </div>

                    <div class="cre-field-group align-top">
                        <label class="cre-label">Diagnosis</label>
                        <textarea class="cre-textarea" rows="3" @bind="saveModel.Diagnosis"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Organism Section -->
        @if (IsGrowth)
        {
        <div class="cre-panel-card slide-down-fade-in">
            <div class="cre-panel-header">
                <div class="cre-panel-title">
                    <i class="fas fa-bacterium"></i> Organisms & Sensitivity
                </div>
            </div>
            
            <div class="cre-organism-section">
                <!-- Organism Grid (Full Width) -->
                <div class="cre-organism-container" style="margin-bottom: 20px;">
                    <div class="cre-organism-grid">
                        <div class="cre-org-header-row">
                            <div class="cre-org-empty"></div>
                            <div class="cre-org-col-header cre-bg-a">SECTION A</div>
                            <div class="cre-org-col-header cre-bg-b">SECTION B</div>
                            <div class="cre-org-col-header cre-bg-c">SECTION C</div>
                        </div>
                        
                        <div class="cre-org-row">
                            <div class="cre-label cre-text-danger">Organism Grown</div>
                            <div>
                                <select class="cre-select" @bind="saveModel.OrganismsGrownA">
                                    <option value="">-- Select Organism --</option>
                                    @foreach(var org in OrganismsList)
                                    {
                                        <option value="@org.Name">@org.Name</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <select class="cre-select" @bind="saveModel.OrganismsGrownB">
                                    <option value="">-- Select Organism --</option>
                                    @foreach(var org in OrganismsList)
                                    {
                                        <option value="@org.Name">@org.Name</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <select class="cre-select" @bind="saveModel.OrganismsGrownC">
                                    <option value="">-- Select Organism --</option>
                                    @foreach(var org in OrganismsList)
                                    {
                                        <option value="@org.Name">@org.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="cre-org-row">
                            <div class="cre-label cre-text-danger">Colony Count</div>
                            <div><input type="text" class="cre-input" placeholder="Count..." @bind="saveModel.ColonyCountA" /></div>
                            <div><input type="text" class="cre-input" placeholder="Count..." @bind="saveModel.ColonyCountB" /></div>
                            <div><input type="text" class="cre-input" placeholder="Count..." @bind="saveModel.ColonyCountC" /></div>
                        </div>

                        <div class="cre-org-row">
                            <div class="cre-label cre-text-danger">Comments</div>
                            <div><input type="text" class="cre-input" placeholder="Notes..." @bind="saveModel.CommentsA" /></div>
                            <div><input type="text" class="cre-input" placeholder="Notes..." @bind="saveModel.CommentsB" /></div>
                            <div class="cre-expand-wrapper">
                                <input type="text" class="cre-input" placeholder="Notes..." @bind="saveModel.CommentsC" />
                                <a href="#" class="cre-link-expand">Expand</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="cre-drag-drop-area" style="display: flex; gap: 20px; align-items: flex-start;">
                    <!-- Draggable List (Near Table) -->
                    <div class="cre-draggable-list" style="width: 220px; border: 1px solid #e2e8f0; border-radius: 8px; padding: 12px; background: #fff; position: sticky; top: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.04);">
                        <div class="cre-label" style="margin-bottom: 8px; color: #4f46e5; border-bottom: 1px solid #f1f5f9; padding-bottom: 8px;">Available Antibiotics</div>
                        
                        <!-- Search Box -->
                        <div style="position: relative; margin-bottom: 12px;">
                            <i class="fas fa-search" style="position: absolute; left: 8px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 0.7rem;"></i>
                            <input type="text" class="cre-input" placeholder="Search..." 
                                   @bind="searchTerm" @bind:event="oninput" 
                                   style="padding-left: 28px; font-size: 0.72rem; height: 32px;" />
                        </div>

                        <div style="max-height: 400px; overflow-y: auto; padding-right: 4px;">
                            @foreach(var anti in AvailableAntibiotics.Where(a => 
                                (string.IsNullOrEmpty(searchTerm) || a.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
                                !SectionResults[activeTab].Any(r => r.AntibioticName == a)))
                            {
                                <div draggable="true" 
                                     @ondragstart="@(() => HandleDragStart(anti))" 
                                     style="padding: 8px 12px; margin-bottom: 8px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; cursor: grab; font-size: 0.75rem; transition: all 0.2s ease;"
                                     class="cre-drag-item">
                                    <i class="fas fa-grip-vertical" style="color: #94a3b8; margin-right: 8px;"></i> @anti
                                </div>
                            }
                        </div>
                    </div>

                    <div style="flex: 1; min-width: 0;">
                        <!-- Tab Header -->
                        <div class="cre-tab-header" style="display: flex; gap: 4px; margin-bottom: 0;">
                            <button class="cre-tab-btn @(activeTab == "A" ? "active cre-bg-a" : "")" @onclick="@(() => SetActiveTab("A"))">SECTION A</button>
                            <button class="cre-tab-btn @(activeTab == "B" ? "active cre-bg-b" : "")" @onclick="@(() => SetActiveTab("B"))">SECTION B</button>
                            <button class="cre-tab-btn @(activeTab == "C" ? "active cre-bg-c" : "")" @onclick="@(() => SetActiveTab("C"))">SECTION C</button>
                        </div>

                        <!-- Sensitivity Table Area -->
                        <div class="cre-sensitivity-wrapper" style="position: relative;">
                            
                            <!-- S-I-R Drop Overlay -->
                            @if (DraggedAntibiotic != null && isDraggingOverTable)
                            {
                                <div class="cre-drop-overlay" 
                                     @ondragleave="@(() => isDraggingOverTable = false)"
                                     @ondragover:preventDefault="true">
                                    <div class="cre-overlay-content">
                                        <div class="cre-overlay-title">SELECT SENSITIVITY: @DraggedAntibiotic.ToUpper()</div>
                                        <div class="cre-overlay-options">
                                            <div class="cre-option-btn opt-s" 
                                                 @ondragenter="@(() => {})" @ondragenter:preventDefault="true"
                                                 @ondragover="@(() => {})" @ondragover:preventDefault="true"
                                                 @ondrop="@(() => HandleOptionDrop("S"))" @ondrop:preventDefault="true">
                                                <span class="opt-label">S</span>
                                                <span class="opt-desc">Sensitive</span>
                                            </div>
                                            <div class="cre-option-btn opt-i" 
                                                 @ondragenter="@(() => {})" @ondragenter:preventDefault="true"
                                                 @ondragover="@(() => {})" @ondragover:preventDefault="true"
                                                 @ondrop="@(() => HandleOptionDrop("I"))" @ondrop:preventDefault="true">
                                                <span class="opt-label">I</span>
                                                <span class="opt-desc">Intermediate</span>
                                            </div>
                                            <div class="cre-option-btn opt-r" 
                                                 @ondragenter="@(() => {})" @ondragenter:preventDefault="true"
                                                 @ondragover="@(() => {})" @ondragover:preventDefault="true"
                                                 @ondrop="@(() => HandleOptionDrop("R"))" @ondrop:preventDefault="true">
                                                <span class="opt-label">R</span>
                                                <span class="opt-desc">Resistant</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            <div class="cre-table-wrap" 
                                 @ondragenter="@(() => isDraggingOverTable = true)"
                                 @ondragover:preventDefault="true">
                                <table class="cre-table cre-table-bordered">
                                    <thead>
                                        <tr>
                                            <th class="cre-col-group" style="width: 50px;">#</th>
                                            <th class="cre-col-antibiotic">Antibiotic</th>
                                            <th style="width: 100px;">Disk</th>
                                            <th style="width: 100px;">MM / MIC</th>
                                            <th style="width: 50px;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (!SectionResults[activeTab].Any())
                                        {
                                            <tr>
                                                <td colspan="5" style="padding: 40px; color: #94a3b8; font-style: italic; background: #fdfdfd;">
                                                    <i class="fas fa-arrow-left" style="margin-right: 10px;"></i>
                                                    Drag an antibiotic here and choose S, I, or R
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            int idx = 1;
                                            @foreach (var res in SectionResults[activeTab])
                                            {
                                                <tr>
                                                    <td>@idx</td>
                                                    <td style="text-align: left;">
                                                        <div style="display: flex; align-items: center; gap: 8px;">
                                                            @{
                                                                string sensitivity = activeTab == "A" ? res.Isolation_A : (activeTab == "B" ? res.Isolation_B : res.Isolation_C);
                                                            }
                                                            <span class="cre-res-badge badge-@(sensitivity?.ToLower())">@sensitivity</span>
                                                            <span style="font-weight: 600;">@res.AntibioticName</span>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        @if (activeTab == "A")
                                                        {
                                                            <input type="text" class="cre-input text-center" @bind="res.DiskContentA" placeholder="-" />
                                                        }
                                                        else if (activeTab == "B")
                                                        {
                                                            <input type="text" class="cre-input text-center" @bind="res.DiskContentB" placeholder="-" />
                                                        }
                                                        else if (activeTab == "C")
                                                        {
                                                            <input type="text" class="cre-input text-center" @bind="res.DiskContentC" placeholder="-" />
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (activeTab == "A")
                                                        {
                                                            <input type="text" class="cre-input text-center" @bind="res.MMA1" placeholder="-" />
                                                        }
                                                        else if (activeTab == "B")
                                                        {
                                                            <input type="text" class="cre-input text-center" @bind="res.MMA2" placeholder="-" />
                                                        }
                                                        else if (activeTab == "C")
                                                        {
                                                            <input type="text" class="cre-input text-center" @bind="res.MMA3" placeholder="-" />
                                                        }
                                                    </td>
                                                    <td>
                                                        <button class="cre-btn-icon-danger" @onclick="@(() => RemoveAntibiotic(res))">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                                idx++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        }

        <!-- Footer Notes & Comments (Always Visible) -->
        <div class="cre-panel-card" style="margin-top: 15px;">
            <div class="cre-notes-section">
                <div class="cre-note-col">
                    <div class="cre-field-group">
                        <label class="cre-label cre-text-danger">Note Message</label>
                        <textarea class="cre-textarea" rows="2" placeholder="Enter message..." @bind="saveModel.NoteMessage"></textarea>
                    </div>
                </div>
                <div class="cre-note-col">
                    <div class="cre-field-group">
                        <label class="cre-label cre-text-danger">Comments</label>
                        <textarea class="cre-textarea" rows="2" placeholder="Additional comments..." @bind="saveModel.Comments"></textarea>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sticky Bottom Bar -->
    <div class="cre-bottom-bar">
        <div class="cre-bottom-left">
            <span class="cre-label-bold">Page Setup</span>
            <select class="cre-select" style="width: 140px;">
                <option>General</option>
            </select>
            
            <div class="cre-footer-divider"></div>
            
            <label class="cre-radio-label">
                <input type="radio" name="printType" checked="@(isLetterHead)" @onchange="@(() => isLetterHead = true)" />
                <span class="cre-radio-mark"></span> Print in Letter Head
            </label>
            <label class="cre-radio-label">
                <input type="radio" name="printType" checked="@(!isLetterHead)" @onchange="@(() => isLetterHead = false)" />
                <span class="cre-radio-mark"></span> Print White Sheet
            </label>
        </div>
        <div class="cre-bottom-right">
            @if (CanShowSaveButton())
            {
                <button class="cre-btn cre-btn-primary" @onclick="SaveResultAsync"><i class="fas fa-save"></i> Save</button>
            }
            
            @if (AreAllTabsAuthorized)
            {
                <button class="cre-btn cre-btn-outline" @onclick="PrintReportAsync"><i class="fas fa-print"></i> Print</button>
            }
            
            @if (isauthorized)
            {
                <button class="cre-btn cre-btn-outline @(saveModel.IsAuthorized == true ? "cre-btn-success" : "")" 
                        @onclick="AuthorizeResultAsync" disabled="@(saveModel.IsAuthorized == true)">
                    <i class="fas fa-user-check"></i> @(saveModel.IsAuthorized == true ? "Authorized" : "Authorize")
                </button>
            }
            @if (isauthorized && saveModel.IsAuthorized == true)
            {
                <button class="cre-btn cre-btn-danger" @onclick="RevokeResultAsync">
                    <i class="fas fa-undo"></i> Revoke
                </button>
            }

            <button class="cre-btn cre-btn-danger" @onclick="NavigateBack"><i class="fas fa-times"></i> Close</button>
        </div>
    </div>
</div>

<SfDialog Visible="@isviewer" Width="80%" Header="Result" Height="80%" IsModal="true" ShowCloseIcon="true">
    <DialogTemplates>
        <Header>Culture Report</Header>
        <Content>
            <ReportViewer Reportstring="@reportstring" pnr="@reportrequest"></ReportViewer>
        </Content>
    </DialogTemplates>
    <DialogEvents OnClose="CloseViewer"></DialogEvents>
</SfDialog>

@code {
    [SupplyParameterFromQuery(Name = "requestGuid")]
    public string RequestGuid { get; set; } = "";

    private string token = "";
    private BillRequest billData;
    private bool IsGrowth = false;
    private SaveCultureResultRequestDto saveModel = new SaveCultureResultRequestDto();
    private UserAuth currentUser;

    private List<CultureTestListDto> CultureTabs = new();
    private CultureTestListDto ActiveCultureTab;

    private bool isentered = false;
    private bool isauthorized = false;
    private string EnteredByName = "--";
    private string AuthorizedByName = "--";
    private bool showValidationErrors = false;
    private IList<LIMS.Model.User_Master> usermaster = new List<LIMS.Model.User_Master>();

    private bool AreAllTabsAuthorized => CultureTabs.Any() && CultureTabs.All(t => t.IsAuthorized == true);

    // Report viewing state
    private bool isviewer = false;
    private string reportstring = "";
    private PreNatalRequest reportrequest = new();
    private bool isLetterHead = true;

    // Tab and Result State
    private string activeTab = "A"; // Default Section
    private bool isDraggingOverTable = false;

    private Dictionary<string, List<CultureIsolationRowDto>> SectionResults = new()
    {
        { "A", new List<CultureIsolationRowDto>() },
        { "B", new List<CultureIsolationRowDto>() },
        { "C", new List<CultureIsolationRowDto>() }
    };

    // Drag and Drop Variables
    private List<string> AvailableAntibiotics = new();
    private string DraggedAntibiotic = null;
    private string searchTerm = "";
    
    // Master Lists
    private List<CultureOrganismDto> OrganismsList = new();
    private List<Antibiotics> AntibioticsMasterList = new();
    private List<Sample_Master> SamplesList = new();

    private void HandleDragStart(string item)
    {
        DraggedAntibiotic = item;
    }

    private void HandleOptionDrop(string sensitivity)
    {
        if (!string.IsNullOrEmpty(DraggedAntibiotic))
        {
            var anti = AntibioticsMasterList.FirstOrDefault(a => a.Name == DraggedAntibiotic);

            // 1. Check if this antibiotic already exists in ANY of the section lists (Trim names for safety)
            var currentDragged = DraggedAntibiotic?.Trim();
            var existingRow = SectionResults.Values
                                .SelectMany(x => x)
                                .FirstOrDefault(r => (r.AntibioticName ?? "").Trim().Equals(currentDragged, StringComparison.OrdinalIgnoreCase));

            if (existingRow != null)
            {
                // Reuse the existing object and update the sensitivity for the current active section
                if (activeTab == "A") existingRow.Isolation_A = sensitivity;
                else if (activeTab == "B") existingRow.Isolation_B = sensitivity;
                else if (activeTab == "C") existingRow.Isolation_C = sensitivity;

                // Add it to the current tab's list if it's not already there
                if (!SectionResults[activeTab].Contains(existingRow))
                {
                    SectionResults[activeTab].Add(existingRow);
                }
            }
            else
            {
                // Create a new row if it doesn't exist anywhere
                var newRow = new CultureIsolationRowDto 
                { 
                    AntibioticName = DraggedAntibiotic,
                    ABCode = anti != null ? (int?)anti.ABCode : null,
                    ColumnName = activeTab
                };

                if (activeTab == "A") newRow.Isolation_A = sensitivity;
                else if (activeTab == "B") newRow.Isolation_B = sensitivity;
                else if (activeTab == "C") newRow.Isolation_C = sensitivity;

                // Also ensure ColumnName is set to the antibiotic name for the database
                newRow.ColumnName = DraggedAntibiotic;

                SectionResults[activeTab].Add(newRow);
            }

            DraggedAntibiotic = null;
            isDraggingOverTable = false;
            StateHasChanged();
        }
    }

    private void RemoveAntibiotic(CultureIsolationRowDto item)
    {
        // Clear section-specific data from the object before removing the association
        if (activeTab == "A")
        {
            item.Isolation_A = null;
            item.DiskContentA = null;
            item.MMA1 = null;
        }
        else if (activeTab == "B")
        {
            item.Isolation_B = null;
            item.DiskContentB = null;
            item.MMA2 = null;
        }
        else if (activeTab == "C")
        {
            item.Isolation_C = null;
            item.DiskContentC = null;
            item.MMA3 = null;
        }

        SectionResults[activeTab].Remove(item);
        StateHasChanged();
    }

