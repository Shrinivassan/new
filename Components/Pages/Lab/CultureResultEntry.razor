    {
        if (ActiveCultureTab == null || string.IsNullOrEmpty(ActiveCultureTab.ResultCultureGUID)) return;

        try
        {
            var request = new HttpRequestMessage(HttpMethod.Post, $"{AppSettings.BaseUrl}Culture/revoke?resultCultureGuid={ActiveCultureTab.ResultCultureGUID}&requestGuid={RequestGuid}");
            if (!string.IsNullOrEmpty(token))
