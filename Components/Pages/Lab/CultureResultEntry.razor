                                </tr>
                                <tr class="cre-sub-header">
                                    <th></th>
                                    <th></th>
                                    <th class="cre-bg-a">Disk</th>
                                    <th class="cre-bg-a">Res</th>
                                    <th class="cre-bg-a">MM</th>
                                    <th class="cre-bg-b">Disk</th>
                                    <th class="cre-bg-b">Res</th>
                                    <th class="cre-bg-b">MM</th>
                                    <th class="cre-bg-c">Disk</th>
                                    <th class="cre-bg-c">Res</th>
                                    <th class="cre-bg-c">MM</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td></td>
                                    <td><select class="cre-select"><option>-- Select Antibiotic --</option></select></td>
                                    <td class="cre-bg-a"></td><td class="cre-bg-a"></td><td class="cre-bg-a"></td>
                                    <td class="cre-bg-b"></td><td class="cre-bg-b"></td><td class="cre-bg-b"></td>
                                    <td class="cre-bg-c"></td><td class="cre-bg-c"></td><td class="cre-bg-c"></td>
                                </tr>
                                <tr>
                                    <td></td>
                                    <td></td>
                                    <td class="cre-bg-a"></td><td class="cre-bg-a"></td><td class="cre-bg-a"></td>
                                    <td class="cre-bg-b"></td><td class="cre-bg-b"></td><td class="cre-bg-b"></td>
                                    <td class="cre-bg-c"></td><td class="cre-bg-c"></td><td class="cre-bg-c"></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Footer Notes Section -->
                <div class="cre-notes-section">
                    <div class="cre-note-col">
                        <div class="cre-field-group">
                            <label class="cre-label cre-text-danger">Note</label>
                            <select class="cre-select">
                                <option>-- Select Note --</option>
                            </select>
                        </div>
                    </div>
                    <div class="cre-note-col">
                        <div class="cre-field-group">
                            <label class="cre-label cre-text-danger">Note Message</label>
                            <textarea class="cre-textarea" rows="2" placeholder="Enter message..."></textarea>
                        </div>
                    </div>
                    <div class="cre-note-col">
                        <div class="cre-field-group">
                            <label class="cre-label cre-text-danger">Comments</label>
                            <textarea class="cre-textarea" rows="2" placeholder="Additional comments..."></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sticky Bottom Bar -->
    <div class="cre-bottom-bar">
        <div class="cre-bottom-left">
            <span class="cre-label-bold">Page Setup</span>
            <select class="cre-select" style="width: 140px;">
                <option>General</option>
            </select>
            
            <div class="cre-footer-divider"></div>
            
            <label class="cre-radio-label">
                <input type="radio" name="printType" checked />
                <span class="cre-radio-mark"></span> Print in Letter Head
            </label>
            <label class="cre-radio-label">
                <input type="radio" name="printType" />
                <span class="cre-radio-mark"></span> Print White Sheet
            </label>
        </div>
        <div class="cre-bottom-right">
            <button class="cre-btn cre-btn-primary"><i class="fas fa-save"></i> Save</button>
            <button class="cre-btn cre-btn-outline"><i class="fas fa-eye"></i> Preview</button>
            <button class="cre-btn cre-btn-outline"><i class="fas fa-print"></i> Print</button>
            <button class="cre-btn cre-btn-danger" @onclick="NavigateBack"><i class="fas fa-times"></i> Close</button>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "requestGuid")]
    public string RequestGuid { get; set; } = "";

    private string token = "";
    private BillRequest billData;

    protected override async Task OnInitializedAsync()
    {
        if (!http.DefaultRequestHeaders.Contains("X-Tenant-ID"))
        {
            http.DefaultRequestHeaders.Add("X-Tenant-ID", AppSettings.ClientId);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var tkn = await _sessionStorage.GetAsync<UserAuth>("claim");
            if (tkn.Success && tkn.Value != null && !string.IsNullOrEmpty(tkn.Value.token))
            {
                token = tkn.Value.token;
                await LoadDataAsync();
                StateHasChanged();
            }
        }
    }

    private async Task LoadDataAsync()
    {
        if (string.IsNullOrEmpty(RequestGuid)) return;

        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}request/EditBill?rid={RequestGuid}");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var res = await http.SendAsync(request);
            if (res.IsSuccessStatusCode)
            {
                var content = await res.Content.ReadAsStringAsync();
                billData = JsonConvert.DeserializeObject<BillRequest>(content);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading culture details: {ex.Message}");
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/result-search");
    }
}
