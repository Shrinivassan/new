    private async Task LoadTabsAsync()
    {
        if (string.IsNullOrEmpty(RequestGuid)) return;
        
        try
        {
            // 1. Fetch Existing Results (may be empty if no results saved yet)
            var req = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}Culture/tests?requestGuid={RequestGuid}");
            if (!string.IsNullOrEmpty(token))
                req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var res = await http.SendAsync(req);
            List<CultureTestListDto> savedTabs = new();
            if (res.IsSuccessStatusCode)
            {
                var content = await res.Content.ReadAsStringAsync();
                var jsonResponse = Newtonsoft.Json.Linq.JObject.Parse(content);
                savedTabs = jsonResponse["data"]?.ToObject<List<CultureTestListDto>>() ?? new();
            }

            // 2. Fetch Ordered Tests (Source of truth for names and what tests are required)
            var nameReq = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}Culture/request-tests?requestGuid={RequestGuid}");
            if (!string.IsNullOrEmpty(token))
                nameReq.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var nameRes = await http.SendAsync(nameReq);
            List<TestCodeNameDto> orderedNames = new();
            if (nameRes.IsSuccessStatusCode)
            {
                var nameContent = await nameRes.Content.ReadAsStringAsync();
                var namesResponse = Newtonsoft.Json.Linq.JObject.Parse(nameContent);
                orderedNames = namesResponse["data"]?.ToObject<List<TestCodeNameDto>>() ?? new();
            }

            // 3. Merge: Every ordered test must have a tab.
            var finalTabs = new List<CultureTestListDto>();
            int fallbackOrder = 1;

            if (orderedNames != null && orderedNames.Any())
            {
                foreach (var ordered in orderedNames)
                {
                    var saved = savedTabs.FirstOrDefault(t => t.TCode == ordered.TCode);
                    if (saved != null)
                    {
                        saved.TestName = ordered.TestName; // Precision name
                        finalTabs.Add(saved);
                    }
                    else
                    {
                        // Create tab for test that hasn't been started yet
                        finalTabs.Add(new CultureTestListDto
                        {
                            TCode = ordered.TCode,
                            TestName = ordered.TestName,
                            OrderNo = fallbackOrder++,
                            ResultStatus = false
                        });
                    }
                }
            }
            else
            {
                // If special names endpoint empty, use what we have from main endpoint
                finalTabs = savedTabs;
            }

            CultureTabs = finalTabs.OrderBy(t => t.OrderNo).ToList();
            
            // 4. Selection Logic
            if (ActiveCultureTab == null && CultureTabs.Any())
            {
                await SelectTab(CultureTabs.First());
            }
            else if (ActiveCultureTab != null)
            {
                // Find current tab in new list to maintain selection
                var prevOrderNo = ActiveCultureTab.OrderNo;
                var prevTCode = ActiveCultureTab.TCode;
                var prevGuid = ActiveCultureTab.ResultCultureGUID;

                ActiveCultureTab = CultureTabs.FirstOrDefault(t => t.OrderNo == prevOrderNo && t.TCode == prevTCode && t.ResultCultureGUID == prevGuid) 
                                    ?? CultureTabs.FirstOrDefault(t => t.OrderNo == prevOrderNo && t.TCode == prevTCode)
                                    ?? CultureTabs.First();
                
                await SelectTab(ActiveCultureTab);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in LoadTabs: {ex.Message}");
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task SelectTab(CultureTestListDto tab)
    {
        if (tab == null) return;
        
        // --- Sync current UI state back to the previous tab's state ---
        if (ActiveCultureTab != null)
        {
            var prevKey = $"{ActiveCultureTab.ResultCultureGUID}-{ActiveCultureTab.TCode}-{ActiveCultureTab.OrderNo}";
            if (TabStates.ContainsKey(prevKey))
            {
                var prevState = TabStates[prevKey];
                prevState.IsGrowth = IsGrowth;
                prevState.EnteredByName = EnteredByName;
                prevState.AuthorizedByName = AuthorizedByName;
                // saveModel and SectionResults are already references to the state's objects, so they are updated auto.
            }
        }

        ActiveCultureTab = tab;
        
        // Key includes OrderNo to strictly separate duplicate test types (same TCode)
        var key = $"{tab.ResultCultureGUID}-{tab.TCode}-{tab.OrderNo}";
        if (!TabStates.ContainsKey(key))
            TabStates[key] = new TabState();
            
        var state = TabStates[key];

        // Link the UI variables to this tab's state reference
        saveModel = state.saveModel;
        SectionResults = state.SectionResults;
        IsGrowth = state.IsGrowth;
        EnteredByName = state.EnteredByName;
        AuthorizedByName = state.AuthorizedByName;

        if (!state.DataLoaded)
        {
            var isValidGuid = !string.IsNullOrEmpty(tab.ResultCultureGUID) && 
                              tab.ResultCultureGUID != "00000000-0000-0000-0000-000000000000" && 
                              tab.ResultCultureGUID != "0";
                              
            if (isValidGuid)
            {
                await LoadDataAsync();
            }
            else
            {
                saveModel.ResultCultureGUID = "";
                saveModel.RequestGUID = RequestGuid;
                saveModel.TCode = tab.TCode;
            }
            
            // Mark loaded and sync back reference reassignments (since LoadDataAsync might instantiate new objects)
            state.DataLoaded = true;
            state.saveModel = saveModel;
            state.SectionResults = SectionResults;
            state.IsGrowth = IsGrowth;
            state.EnteredByName = EnteredByName;
            state.AuthorizedByName = AuthorizedByName;
        }

        StateHasChanged();
    }

