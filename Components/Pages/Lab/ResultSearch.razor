@code {
    // Session key for persisting filter state
    private const string FilterStateKey = "ResultSearch_FilterState";

    // Data class to hold all filter state for serialization
    private class FilterState
    {
        public DateTime FromDate { get; set; }
        public DateTime ToDate { get; set; }
        public string SidFrom { get; set; } = "";
        public string SidTo { get; set; } = "";
        public string MainDept { get; set; } = "Lab";
        public string PatientSearch { get; set; } = "";
        public string MobileSearch { get; set; } = "";
        public string SelectedDepartment { get; set; } = "";
        public string TestNameSearch { get; set; } = "";
        public string ReportType { get; set; } = "Lab";
        public string ReferredBySearch { get; set; } = "";
        public string PathologyNo { get; set; } = "";
        public string ResultStatus { get; set; } = "Pending";
        public bool ShowAllTestInEntry { get; set; }
        public bool ShowTAT { get; set; }
        public int BranchID { get; set; }
        public bool IsFilterOpen { get; set; } = true;
        public bool HasResults { get; set; }
    }

    // Auth & Branch
    private string token = "";
    private int branchID = 0;
    private List<Branch_Master> branches = new();

    // Filters
    private bool isFilterOpen = true;
    private DateTime fromDate = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
    private DateTime toDate = DateTime.Now;
    private string sidFrom = "";
    private string sidTo = "";
    private string mainDept = "Lab";
    private string patientSearch = "";
    private string mobileSearch = "";
    private string selectedDepartment = "";
    private string testNameSearch = "";
    private string reportType = "Lab";
    private string referredBySearch = "";
    private int selectedDoctorCode = 0;
    private List<Doctor_Master> doctors = new();
    private string pathologyNo = "";
    private string resultStatus = "Pending";
    private bool showAllTestInEntry = false;
    private bool showTAT = false;
    private string entryType = "ResultEntry";

    // Bottom bar
    private int authorizedUser = 0;
    private bool isInterimReport = false;
    private string pageSetup = "General";
    private bool printInLetterHead = true;
    private bool printWhiteSheet = false;
    private List<User_Master> authorizedUsers = new();

    // State
    private bool isLoading = false;
    private int selectedRowIndex = -1;
    private List<ViewResultSearch> allResults = new();
    private List<ViewResultSearch> filteredResults = new();
    private List<TestDetailItem> selectedTestDetails = new();

    // Local model for test details
    public class TestDetailItem
    {
        public string TestName { get; set; } = "";
        public bool IsPending { get; set; }
        public bool IsSelected { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!http.DefaultRequestHeaders.Contains("X-Tenant-ID"))
        {
            http.DefaultRequestHeaders.Add("X-Tenant-ID", AppSettings.ClientId);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var tkn = await _sessionStorage.GetAsync<UserAuth>("claim");
            if (tkn.Success && tkn.Value != null && !string.IsNullOrEmpty(tkn.Value.token))
            {
                token = tkn.Value.token;
                try
                {
                    var json = System.Text.Json.JsonSerializer.Serialize(tkn.Value);
                    var doc = System.Text.Json.JsonDocument.Parse(json);
                    if (doc.RootElement.TryGetProperty("BranchCode", out var branchCodeProp))
                    {
                        branchID = branchCodeProp.GetInt32();
                    }
                }
                catch { }

                await LoadBranchesAsync();
                await LoadAuthorizedUsersAsync();
                await LoadDoctorsAsync();

                // Restore filter state if user navigated back from result entry
                await RestoreFilterStateAsync();

                StateHasChanged();
            }
        }
    }

    private async Task RestoreFilterStateAsync()
    {
        try
        {
            var saved = await _sessionStorage.GetAsync<FilterState>(FilterStateKey);
            if (saved.Success && saved.Value != null)
            {
                var s = saved.Value;
                fromDate = s.FromDate;
                toDate = s.ToDate;
                sidFrom = s.SidFrom;
                sidTo = s.SidTo;
                mainDept = s.MainDept;
                patientSearch = s.PatientSearch;
                mobileSearch = s.MobileSearch;
                selectedDepartment = s.SelectedDepartment;
                testNameSearch = s.TestNameSearch;
                reportType = s.ReportType;
                referredBySearch = s.ReferredBySearch;
                pathologyNo = s.PathologyNo;
                resultStatus = s.ResultStatus;
                showAllTestInEntry = s.ShowAllTestInEntry;
                showTAT = s.ShowTAT;
                isFilterOpen = s.IsFilterOpen;

                // Override branchID from saved state only if the branches list has it
                if (branches.Any(b => b.BHCode == s.BranchID))
                    branchID = s.BranchID;

                // If there were results before navigation, reload them automatically
                if (s.HasResults)
                    await SearchResults();

                // Clear the saved state so it doesn't restore again on fresh visit
                await _sessionStorage.DeleteAsync(FilterStateKey);
            }
        }
        catch { }
    }

    private async Task SaveFilterStateAsync()
    {
        try
        {
            var state = new FilterState
            {
                FromDate = fromDate,
                ToDate = toDate,
                SidFrom = sidFrom,
                SidTo = sidTo,
                MainDept = mainDept,
                PatientSearch = patientSearch,
                MobileSearch = mobileSearch,
                SelectedDepartment = selectedDepartment,
                TestNameSearch = testNameSearch,
                ReportType = reportType,
                ReferredBySearch = referredBySearch,
                PathologyNo = pathologyNo,
                ResultStatus = resultStatus,
                ShowAllTestInEntry = showAllTestInEntry,
                ShowTAT = showTAT,
                BranchID = branchID,
                IsFilterOpen = isFilterOpen,
                HasResults = filteredResults.Any()
            };
            await _sessionStorage.SetAsync(FilterStateKey, state);
        }
        catch { }
    }

    private async Task LoadBranchesAsync()
    {
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}request/branches");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var res = await http.SendAsync(request);
            if (res.IsSuccessStatusCode)
            {
                branches = await res.Content.ReadFromJsonAsync<List<Branch_Master>>() ?? new();
                if (!branches.Any(b => b.BHCode == 0))
                    branches.Insert(0, new Branch_Master { BHCode = 0, Name = "All Branches" });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading branches: {ex.Message}");
        }
    }

    private async Task LoadAuthorizedUsersAsync()
    {
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}request/users");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var res = await http.SendAsync(request);
            if (res.IsSuccessStatusCode)
            {
                authorizedUsers = await res.Content.ReadFromJsonAsync<List<User_Master>>() ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading users: {ex.Message}");
        }
    }

    private async Task LoadDoctorsAsync()
    {
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}request/doctors");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var res = await http.SendAsync(request);
            if (res.IsSuccessStatusCode)
            {
                doctors = await res.Content.ReadFromJsonAsync<List<Doctor_Master>>() ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading doctors: {ex.Message}");
        }
    }

    private async Task SearchResults()
    {
        try
        {
            isLoading = true;
            selectedRowIndex = -1;
            selectedTestDetails.Clear();
            StateHasChanged();

            string sd = fromDate.ToString("yyyy-MM-dd") + " 00:00:00";
            string ed = toDate.ToString("yyyy-MM-dd") + " 23:59:59";

            string apiUrl = $"{AppSettings.BaseUrl}request/ViewResultSearch?DCode={branchID}" +
                            $"&fromdate={Uri.EscapeDataString(sd)}" +
                            $"&todate={Uri.EscapeDataString(ed)}";

            if (selectedDoctorCode != 0)
            {
                apiUrl += $"&refcode={selectedDoctorCode}";
            }

            // Status, MainDept, and Type are handled client-side in ApplyFilters 
            // to avoid backend parameter mismatch issues that might cause 0 results.

            var request = new HttpRequestMessage(HttpMethod.Get, apiUrl);

            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var res = await http.SendAsync(request);
            if (res.IsSuccessStatusCode)
            {
                var content = await res.Content.ReadAsStringAsync();
                var bills = JsonConvert.DeserializeObject<List<ViewResultSearch>>(content);

                if (bills != null)
                {
                    allResults = bills.ToList();
                    ApplyFilters();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error searching results: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilters()
    {
        var filtered = allResults.AsEnumerable();

        // Main Dept filter
        if (mainDept == "Lab")
            filtered = filtered.Where(x => x.IsLab);
        else if (mainDept == "Scan")
            filtered = filtered.Where(x => x.IsScan);

        // Report Type filter
        if (reportType == "Lab")
            filtered = filtered.Where(x => x.IsLab && !x.IsCulture);
        else if (reportType == "Culture")
            filtered = filtered.Where(x => x.IsCulture);
        else if (reportType == "Scan")
            filtered = filtered.Where(x => x.IsScan);

        // SID range filter
        if (!string.IsNullOrEmpty(sidFrom) && int.TryParse(sidFrom, out int sFrom))
            filtered = filtered.Where(x => x.RequestSNo >= sFrom);
        if (!string.IsNullOrEmpty(sidTo) && int.TryParse(sidTo, out int sTo))
            filtered = filtered.Where(x => x.RequestSNo <= sTo);

        // Patient name filter
        if (!string.IsNullOrWhiteSpace(patientSearch))
            filtered = filtered.Where(x => (x.Name ?? "").ToLower().Contains(patientSearch.ToLower()));

        // Mobile filter
        if (!string.IsNullOrWhiteSpace(mobileSearch))
            filtered = filtered.Where(x => (x.Mobile ?? "").Contains(mobileSearch));

        // Referred By filter
        if (!string.IsNullOrWhiteSpace(referredBySearch))
            filtered = filtered.Where(x => (x.Doctor ?? "").ToLower().Contains(referredBySearch.ToLower()));

        // Pathology No filter
        if (!string.IsNullOrWhiteSpace(pathologyNo))
            filtered = filtered.Where(x => (x.BillNoPrint ?? "").Contains(pathologyNo));

        // Test name filter
        if (!string.IsNullOrWhiteSpace(testNameSearch))
            filtered = filtered.Where(x => (x.TestShortName ?? "").ToLower().Contains(testNameSearch.ToLower()));

        // Status filter - Ensure strict separation
        if (resultStatus == "Pending")
            filtered = filtered.Where(x => IsRecordPending(x));
        else if (resultStatus == "Finished")
            filtered = filtered.Where(x => IsRecordFinished(x) && !IsRecordPending(x));

        filteredResults = filtered
            .OrderByDescending(x => x.RequestDateTime)
            .ThenByDescending(x => x.RequestSNo)
            .ToList();
    }

    private bool IsRecordPending(ViewResultSearch item)
    {
        // Use ResultStatus string: empty or "0" or "false" means pending
        return string.IsNullOrWhiteSpace(item.ResultStatus) || 
               item.ResultStatus == "0" || 
               item.ResultStatus.ToLower() == "false";
    }

    private bool IsRecordFinished(ViewResultSearch item)
    {
        // anything not "0", not empty, and not "false" is considered finished
        return !IsRecordPending(item);
    }

    private string GetRecordStatus(ViewResultSearch item)
    {
        bool pending = IsRecordPending(item);
        if (pending) return "Pending";
        return "Finished";
    }

    private bool isLoadingTests = false;

    private async Task SelectRow(int index, ViewResultSearch item)
    {
        selectedRowIndex = index;
        selectedTestDetails.Clear();
        isLoadingTests = true;
        StateHasChanged();

        try
        {
            // Call EditBill API to get request details with TCode
            var request = new HttpRequestMessage(HttpMethod.Get,
                $"{AppSettings.BaseUrl}request/EditBill?rid={item.RequestGUID}");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var res = await http.SendAsync(request);
            if (res.IsSuccessStatusCode)
            {
                var content = await res.Content.ReadAsStringAsync();
                var billData = JsonConvert.DeserializeObject<BillRequest>(content);

                if (billData?.Request_Details != null && billData.Request_Details.Count > 0)
                {
                    // Get test codes to fetch test names
                    var testCodes = billData.Request_Details.Select(d => d.TCode).ToList();
                    var codesString = string.Join(",", testCodes);

                    // Fetch test names from API
                    var testRequest = new HttpRequestMessage(HttpMethod.Get,
                        $"{AppSettings.BaseUrl}request/testlistbytcode?tcode={Uri.EscapeDataString(codesString)}");
                    if (!string.IsNullOrEmpty(token))
                        testRequest.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

                    var testRes = await http.SendAsync(testRequest);
                    var testList = new List<Test_Master>();

                    if (testRes.IsSuccessStatusCode)
                    {
                        var testContent = await testRes.Content.ReadAsStringAsync();
                        testList = JsonConvert.DeserializeObject<List<Test_Master>>(testContent) ?? new();
                    }

                    // Build test detail items with actual name and status
                    foreach (var detail in billData.Request_Details)
                    {
                        var testName = testList.FirstOrDefault(t => t.TCode == detail.TCode)?.Name ?? $"Test #{detail.TCode}";
                        var isPending = !detail.ResultStatus;

                        selectedTestDetails.Add(new TestDetailItem
                        {
                            TestName = testName,
                            IsPending = isPending,
                            IsSelected = true
                        });
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading test details: {ex.Message}");
        }
        finally
        {
            isLoadingTests = false;
            StateHasChanged();
        }
    }

    private void ClearFilters()
    {
        fromDate = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
        toDate = DateTime.Now;
        sidFrom = "";
        sidTo = "";
        mainDept = "Lab";
        patientSearch = "";
        mobileSearch = "";
        selectedDepartment = "";
        testNameSearch = "";
        reportType = "Lab";
        referredBySearch = "";
        pathologyNo = "";
        resultStatus = "Pending";
        showAllTestInEntry = false;
        showTAT = false;
        selectedRowIndex = -1;
        filteredResults.Clear();
        selectedTestDetails.Clear();
        allResults.Clear();
        StateHasChanged();
    }

    private void ToggleFilter()
    {
        isFilterOpen = !isFilterOpen;
    }

    private int GetActiveFilterCount()
    {
        int count = 0;
        if (branchID != 0) count++;
        if (!string.IsNullOrWhiteSpace(sidFrom)) count++;
        if (!string.IsNullOrWhiteSpace(sidTo)) count++;
        if (!string.IsNullOrWhiteSpace(patientSearch)) count++;
        if (!string.IsNullOrWhiteSpace(mobileSearch)) count++;
        if (!string.IsNullOrWhiteSpace(selectedDepartment)) count++;
        if (!string.IsNullOrWhiteSpace(testNameSearch)) count++;
        if (!string.IsNullOrWhiteSpace(referredBySearch)) count++;
        if (!string.IsNullOrWhiteSpace(pathologyNo)) count++;
        if (showAllTestInEntry) count++;
        if (showTAT) count++;
        return count;
    }

   

    private string PathologyNo
    {
        get
        {
            if (selectedRowIndex >= 0 && selectedRowIndex < filteredResults.Count)
                return filteredResults[selectedRowIndex].BillNoPrint ?? "";
            return "";
        }
    }

    private async Task NavigateToEntry(ViewResultSearch item)
    {
        // Save filter state before leaving so we can restore on return
        await SaveFilterStateAsync();

        if (reportType == "Culture")
        {
            NavigationManager.NavigateTo($"/culture-result-entry?requestGuid={item.RequestGUID}&custcode={item.CustCode}");
        }
        else if (reportType == "Lab")
        {
            NavigationManager.NavigateTo($"/result-entry?requestGuid={item.RequestGUID}&custcode={item.CustCode}");
        }
    }
}
