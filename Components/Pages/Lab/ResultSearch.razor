@page "/result-search"
@inject HttpClient http
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage _sessionStorage
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@using Lims.Components.Model
@using LIMS.Model
@using Newtonsoft.Json
@using System.Net.Http.Headers
@inject LIMS.Model.AppSettings AppSettings
@rendermode InteractiveServer

<PageTitle>Result Search - LIMS</PageTitle>

<div class="rs-container">
    <!-- Modern Page Header -->
    <div class="lab-header-section">
        <div class="lab-header-top">
            <div class="lab-breadcrumb">
                <i class="fas fa-home"></i> <span>Lab</span> 
                <i class="fas fa-chevron-right separator"></i> 
                <span class="active">Result Search</span>
            </div>
        </div>
        
      
    </div>

    <!-- Styles for Modern Header -->
    <style>
        .lab-header-section {
            border-radius: 10px;
            padding: 8px 14px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
            margin-bottom: 10px;
            border: 1px solid #eef2f6;
            position: relative;
            overflow: hidden;
        }

        /* Subtle background pattern/gradient */
        .lab-header-section::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 300px;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(67, 97, 238, 0.03));
            pointer-events: none;
        }

        .lab-header-top {
            margin-bottom: 0;
        }

        .lab-breadcrumb {
            font-size: 13px;
            color: #6c757d;
            font-weight: 500;
            display: flex;
            align-items: center;
        }

        .lab-breadcrumb i.fa-home {
            color: #4361ee;
            margin-right: 6px;
            font-size: 14px;
        }

        .lab-breadcrumb .separator {
            font-size: 9px;
            margin: 0 10px;
            color: #ced4da;
        }

        .lab-breadcrumb .active {
            color: #2b2b2b;
            font-weight: 600;
        }

        .lab-header-main {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .lab-header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .lab-icon-box {
            background: linear-gradient(135deg, #4361ee 0%, #3f37c9 100%);
            color: #ffffff;
            width: 56px;
            height: 56px;
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 24px;
            box-shadow: 0 8px 16px rgba(67, 97, 238, 0.25);
        }

        .lab-page-title {
            font-size: 22px;
            font-weight: 700;
            color: #1a1d20;
            margin: 0 0 4px 0;
            letter-spacing: -0.3px;
        }

        .lab-page-subtitle {
            font-size: 14px;
            color: #6c757d;
            margin: 0;
        }

        .lab-header-right {
            display: flex;
            align-items: center;
        }

        .lab-action-group {
            display: flex;
            gap: 12px;
        }

        .lab-entry-badge {
            display: flex;
            align-items: center;
            background-color: #f8f9fc;
            border: 1px solid #e3e6f0;
            border-radius: 8px;
            padding: 8px 16px;
            gap: 8px;
            transition: all 0.2s;
        }

        .lab-entry-badge:hover {
            border-color: #4361ee;
            background-color: #f0f4ff;
        }

        .lab-entry-badge i {
            color: #4361ee;
            font-size: 14px;
        }

        .lab-entry-badge .lbl {
            font-size: 13px;
            color: #495057;
            font-weight: 600;
        }

        .lab-select-minimal {
            background: transparent;
            border: none;
            color: #2b2b2b;
            font-weight: 700;
            font-size: 14px;
            padding: 0;
            outline: none;
            cursor: pointer;
            width: 105px;
        }
        
        .lab-select-minimal:focus {
            outline: none;
        }

        @@media (max-width: 768px) {
            .lab-header-main {
                flex-direction: column;
                align-items: flex-start;
                gap: 20px;
            }
            .lab-header-right {
                width: 100%;
            }
            .lab-entry-badge {
                width: 100%;
                justify-content: space-between;
            }
            .lab-select-minimal {
                text-align: right;
                width: auto;
            }
        }
    </style>

    <!-- Compact Filter Card -->
    <style>
        /* ===== MODERN PREMIUM FILTER CARD ===== */
        .cfc-card {
            background: #fff;
            border: 1px solid #e7ebf4;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
            margin-bottom: 12px;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .cfc-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 16px;
            background: linear-gradient(to right, #f8faff, #ffffff);
            border-bottom: 1px solid #f0f3f8;
            cursor: pointer;
            user-select: none;
            position: relative;
        }

        .cfc-header::after {
            content: '';
            position: absolute;
            left: 0;
            top: 25%;
            height: 50%;
            width: 4px;
            background: #4361ee;
            border-radius: 0 4px 4px 0;
        }

        .cfc-header-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .cfc-header-left i {
            font-size: 12px;
            color: #4361ee;
            background: rgba(67, 97, 238, 0.08);
            width: 24px;
            height: 24px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .cfc-header-left span {
            font-size: 12.5px;
            font-weight: 750;
            color: #1e2a4a;
            letter-spacing: 0.3px;
        }

        .cfc-header-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .cfc-clear-btn {
            background: #fff;
            border: 1px solid #e2e8f0;
            color: #ef4444;
            font-size: 10.5px;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: all 0.2s;
        }

        .cfc-clear-btn:hover {
            background: #fef2f2;
            border-color: #fee2e2;
        }

        .cfc-chevron {
            color: #94a3b8;
            font-size: 11px;
            background: #f8fafc;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.25s;
        }

        .cfc-chevron.up {
            transform: rotate(180deg);
            background: #eef2ff;
            color: #4361ee;
        }

        /* Body */
        .cfc-body {
            padding: 12px 18px;
            display: block;
            overflow: hidden;
            transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s;
            max-height: 800px;
            opacity: 1;
            background: #fff;
        }

        .cfc-body.closed {
            max-height: 0;
            padding-top: 0;
            padding-bottom: 0;
            opacity: 0;
            pointer-events: none;
        }

        /* Grouping Sections */
        .cfc-section {
            padding-bottom: 8px;
            margin-bottom: 8px;
            border-bottom: 1px solid #f1f4f9;
        }

        .cfc-section:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .cfc-section-title {
            display: flex;
            align-items: center;
            gap: 7px;
            margin-bottom: 6px;
        }

        .cfc-section-title i {
            font-size: 10px;
            color: #94a3b8;
        }

        .cfc-section-title span {
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        /* Filter grid rows */
        .cfc-row {
            display: flex;
            flex-wrap: wrap;
            gap: 8px 14px;
            align-items: flex-end;
        }

        /* Individual field */
        .cfc-field {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .cfc-label {
            font-size: 10.5px;
            font-weight: 600;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .cfc-label i {
            color: #94a3b8;
            font-size: 10px;
            opacity: 0.7;
        }

        .cfc-input,
        .cfc-select {
            height: 28px;
            padding: 0 10px;
            font-size: 11.5px;
            border: 1.5px solid #edf2f7;
            border-radius: 8px;
            background: #f8fafc;
            color: #2d3748;
            outline: none;
            transition: all 0.2s;
            width: 100%;
            box-sizing: border-box;
            font-weight: 500;
        }

        .cfc-input:hover,
        .cfc-select:hover {
            border-color: #cbd5e0;
            background: #fff;
        }

        .cfc-input:focus,
        .cfc-select:focus {
            border-color: #4361ee;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
        }

        /* Pill radio group */
        .cfc-pill-group {
            display: flex;
            gap: 6px;
            background: #f1f4f9;
            padding: 3px;
            border-radius: 10px;
            width: fit-content;
        }

        .cfc-pill {
            display: flex;
        }

        .cfc-pill input[type=radio] {
            display: none;
        }

        .cfc-pill-label {
            font-size: 10.5px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 7px;
            color: #64748b;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
            line-height: 1;
        }

        .cfc-pill input[type=radio]:checked + .cfc-pill-label {
            background: #fff;
            color: #4361ee;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
        }

        /* Status Pills - Special styling */
        .cfc-status-group {
            background: #f8fafc;
            border: 1px solid #edf2f7;
            padding: 3px;
        }

        .cfc-status-pill input[type=radio][value=Pending]:checked + .cfc-pill-label {
            background: #fff7ed;
            color: #ea580c;
        }

        .cfc-status-pill input[type=radio][value=Finished]:checked + .cfc-pill-label {
            background: #f0fdf4;
            color: #16a34a;
        }

        /* Checkbox style */
        .cfc-check {
            display: flex;
            align-items: center;
        }

        .cfc-check input[type=checkbox] {
            display: none;
        }

        .cfc-check-label {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 10.5px;
            font-weight: 650;
            color: #64748b;
            cursor: pointer;
            padding: 4px 10px;
            background: #f8fafc;
            border: 1.5px solid #edf2f7;
            border-radius: 8px;
            transition: all 0.2s;
        }

        .cfc-check-label i {
            font-size: 9px;
            color: #94a3b8;
        }

        .cfc-check input[type=checkbox]:checked + .cfc-check-label {
            border-color: #4361ee;
            background: #f0f3ff;
            color: #4361ee;
        }

        .cfc-check input[type=checkbox]:checked + .cfc-check-label i {
            color: #4361ee;
        }

        /* Footer Action Area */
        .cfc-footer {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 20px 12px 20px;
            margin-top: -6px;
            background: #fff;
        }

        .cfc-view-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #4361ee;
            color: #fff;
            border: none;
            border-radius: 9px;
            padding: 6px 18px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 12px rgba(67, 97, 238, 0.25);
        }

        .cfc-view-btn:hover:not(:disabled) {
            background: #3651d4;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(67, 97, 238, 0.35);
        }

        .cfc-view-btn:active:not(:disabled) {
            transform: translateY(0);
        }

        .cfc-view-btn:disabled {
            background: #cbd5e0;
            box-shadow: none;
            cursor: not-allowed;
        }

        .cfc-spinner {
            width: 12px;
            height: 12px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: cfc-spin 0.7s linear infinite;
        }

        @@keyframes cfc-spin {
            to { transform: rotate(360deg); }
        }

        /* Widths */
        .cfc-w-20 { flex: 0 0 calc(20% - 13px); }
        .cfc-w-15 { flex: 0 0 calc(15% - 14px); }
        .cfc-w-25 { flex: 0 0 calc(25% - 12px); }
        .cfc-w-12 { flex: 0 0 calc(12.5% - 14px); }
        .cfc-w-auto { flex: 1; }

        @@media (max-width: 1200px) {
            .cfc-w-20, .cfc-w-15, .cfc-w-25, .cfc-w-12 {
                flex: 0 0 calc(33.33% - 12px);
            }
        }
        @@media (max-width: 768px) {
            .cfc-w-20, .cfc-w-15, .cfc-w-25, .cfc-w-12 {
                flex: 0 0 calc(50% - 8px);
            }
        }

    </style>

    <div class="cfc-card">
        <!-- Header -->
        <div class="cfc-header" @onclick="ToggleFilter">
            <div class="cfc-header-left">
                <i class="fas fa-search"></i>
                <span>SEARCH FILTERS</span>
            </div>
            <div class="cfc-header-right">
                @if (isFilterOpen)
                {
                    <button class="cfc-clear-btn" @onclick="ClearFilters" @onclick:stopPropagation="true">
                        <i class="fas fa-undo"></i> Reset
                    </button>
                }
                <div class="cfc-chevron @(isFilterOpen ? "up" : "")">
                    <i class="fas fa-chevron-down"></i>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="cfc-body @(isFilterOpen ? "" : "closed")">
            
            <!-- Section 1: Timeline & Identifiers -->
            <div class="cfc-section">
                <div class="cfc-section-title">
                    <i class="fas fa-history"></i>
                    <span>Timeline & Case Info</span>
                </div>
                <div class="cfc-row">
                    <div class="cfc-field cfc-w-15">
                        <span class="cfc-label"><i class="far fa-calendar-alt"></i> From Date</span>
                        <input type="date" class="cfc-input" @bind="fromDate" />
                    </div>
                    <div class="cfc-field cfc-w-15">
                        <span class="cfc-label"><i class="far fa-calendar-alt"></i> To Date</span>
                        <input type="date" class="cfc-input" @bind="toDate" />
                    </div>
                    <div class="cfc-field cfc-w-15">
                        <span class="cfc-label"><i class="fas fa-hashtag"></i> Case No (SID)</span>
                        <div style="display: flex; gap: 5px;">
                            <input type="text" class="cfc-input" placeholder="Start" @bind="sidFrom" />
                            <input type="text" class="cfc-input" placeholder="End" @bind="sidTo" />
                        </div>
                    </div>
                    <div class="cfc-field cfc-w-15">
                        <span class="cfc-label"><i class="fas fa-microscope"></i> Pathology No</span>
                        <input type="text" class="cfc-input" placeholder="Path No" @bind="pathologyNo" />
                    </div>
                </div>
            </div>

            <!-- Section 2: Patient Info -->
            <div class="cfc-section">
                <div class="cfc-section-title">
                    <i class="fas fa-user-injured"></i>
                    <span>Patient Details</span>
                </div>
                <div class="cfc-row">
                    <div class="cfc-field cfc-w-25">
                        <span class="cfc-label"><i class="far fa-user"></i> Patient Name</span>
                        <input type="text" class="cfc-input" placeholder="Search by name..." @bind="patientSearch" />
                    </div>
                    <div class="cfc-field cfc-w-20">
                        <span class="cfc-label"><i class="fas fa-mobile-alt"></i> Mobile Number</span>
                        <input type="text" class="cfc-input" placeholder="Search by mobile..." @bind="mobileSearch" />
                    </div>
                </div>
            </div>

            <!-- Section 3: Clinical Information -->
            <div class="cfc-section">
                <div class="cfc-section-title">
                    <i class="fas fa-hospital-alt"></i>
                    <span>Clinical Filters</span>
                </div>
                <div class="cfc-row">
                    <div class="cfc-field cfc-w-20">
                        <span class="cfc-label"><i class="fas fa-sitemap"></i> Branch</span>
                        <select class="cfc-select" @bind="branchID">
                            @foreach (var b in branches)
                            {
                                <option value="@b.BHCode">@b.Name</option>
                            }
                        </select>
                    </div>
                    <div class="cfc-field cfc-w-20">
                        <span class="cfc-label"><i class="fas fa-layer-group"></i> Department</span>
                        <select class="cfc-select" @bind="selectedDepartment">
                            <option value="">All Departments</option>
                        </select>
                    </div>
                    <div class="cfc-field cfc-w-20">
                        <span class="cfc-label"><i class="fas fa-notes-medical"></i> Test Name</span>
                        <input type="text" class="cfc-input" placeholder="Filter by test..." @bind="testNameSearch" />
                    </div>
                    <div class="cfc-field cfc-w-20">
                        <span class="cfc-label"><i class="fas fa-user-md"></i> Referred By</span>
                        <select class="cfc-select" @bind="selectedDoctorCode">
                            <option value="0">All Doctors</option>
                            @foreach (var dr in doctors)
                            {
                                <option value="@dr.DCode">@dr.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- Section 4: Advanced Options -->
            <div class="cfc-section" style="background: #fbfcfe; margin: 0 -18px; padding: 10px 18px;">
                <div class="cfc-row" style="align-items: center; gap: 24px;">
                    <div class="cfc-field">
                        <span class="cfc-label">Main Dept</span>
                        <div class="cfc-pill-group">
                            <label class="cfc-pill">
                                <input type="radio" name="mainDept" value="Lab" @onchange="@(() => mainDept = "Lab")" checked="@(mainDept == "Lab")" />
                                <span class="cfc-pill-label">Lab</span>
                            </label>
                            <label class="cfc-pill">
                                <input type="radio" name="mainDept" value="Scan" @onchange="@(() => mainDept = "Scan")" checked="@(mainDept == "Scan")" />
                                <span class="cfc-pill-label">Scan</span>
                            </label>
                        </div>
                    </div>

                    <div class="cfc-field">
                        <span class="cfc-label">Type</span>
                        <div class="cfc-pill-group">
                            <label class="cfc-pill">
                                <input type="radio" name="reportType" value="Lab" @onchange="@(() => reportType = "Lab")" checked="@(reportType == "Lab")" />
                                <span class="cfc-pill-label">Lab</span>
                            </label>
                            <label class="cfc-pill">
                                <input type="radio" name="reportType" value="Culture" @onchange="@(() => reportType = "Culture")" checked="@(reportType == "Culture")" />
                                <span class="cfc-pill-label">Culture</span>
                            </label>
                            <label class="cfc-pill">
                                <input type="radio" name="reportType" value="Scan" @onchange="@(() => reportType = "Scan")" checked="@(reportType == "Scan")" />
                                <span class="cfc-pill-label">Scan</span>
                            </label>
                        </div>
                    </div>

                    <div class="cfc-field">
                        <span class="cfc-label">Status</span>
                        <div class="cfc-pill-group cfc-status-group">
                            <label class="cfc-pill cfc-status-pill">
                                <input type="radio" name="status" value="Pending" @onchange="@(() => resultStatus = "Pending")" checked="@(resultStatus == "Pending")" />
                                <span class="cfc-pill-label">Pending</span>
                            </label>
                            <label class="cfc-pill cfc-status-pill">
                                <input type="radio" name="status" value="Finished" @onchange="@(() => resultStatus = "Finished")" checked="@(resultStatus == "Finished")" />
                                <span class="cfc-pill-label">Finished</span>
                            </label>
                        </div>
                    </div>

                    <div class="cfc-field" style="margin-left: auto;">
                        <div class="cfc-row" style="gap: 12px;">
                            <label class="cfc-check">
                                <input type="checkbox" @bind="showAllTestInEntry" />
                                <span class="cfc-check-label"><i class="fas fa-tasks"></i> All Tests</span>
                            </label>
                            <label class="cfc-check">
                                <input type="checkbox" @bind="showTAT" />
                                <span class="cfc-check-label"><i class="far fa-clock"></i> TAT</span>
                            </label>
                        </div>
                    </div>
            <!-- Footer inside Body for proper collapse -->
            <div class="cfc-footer">
                <button class="cfc-view-btn" @onclick="SearchResults" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="cfc-spinner"></span>
                        <span>Processing...</span>
                    }
                    else
                    {
                        <i class="fas fa-search"></i>
                        <span>Apply Filters</span>
                    }
                </button>
            </div>
        </div>
    </div>
    </div>
</div>


    <!-- Main Content Area -->
    <div class="rs-content-area @(selectedRowIndex >= 0 ? "has-selection" : "")">
        <!-- Results Table -->
        <div class="rs-results-panel">
            <div class="rs-panel-card">
                <div class="rs-panel-header">
                    <div class="rs-panel-title">
                        <i class="fas fa-list-alt"></i> Results
                    </div>
                    <span class="rs-count-badge">Count : @filteredResults.Count</span>
                </div>
                <div class="rs-table-wrap">
                    <table class="rs-table">
                        <thead>
                            <tr>
                                <th>Sno</th>
                                <th>Case No</th>
                                <th>Date</th>
                                <th>REG</th>
                                <th>Patient Name</th>
                                <th>Referred By</th>
                                <th>Status</th>
                                <th>Pathology No</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (filteredResults.Any())
                            {
                                @for (int i = 0; i < filteredResults.Count; i++)
                                {
                                    var item = filteredResults[i];
                                    var idx = i;
                                    var isSelected = selectedRowIndex == idx;
                                    <tr class="@(isSelected ? "rs-row-selected" : "")" @onclick="@(() => SelectRow(idx, item))" @ondblclick="@(() => NavigateToEntry(item))" style="cursor: pointer;" title="Double-click to enter results">
                                        <td>@(idx + 1)</td>
                                        <td class="rs-td-bold">@item.RequestSNo</td>
                                        <td>@item.RequestDateTime.ToString("dd/MM/yyyy")</td>
                                        <td class="rs-td-reg">@item.CustCode</td>
                                        <td class="rs-td-name">@item.Name</td>
                                        <td>@item.Doctor</td>
                                         <td>
                                            @{
                                                var displayStatus = GetRecordStatus(item);
                                                var statusClass = displayStatus.ToLower() switch {
                                                    "pending" => "rs-status-pending",
                                                    "finished" => "rs-status-finished",
                                                    "partial" => "rs-status-partial",
                                                    _ => "rs-status-pending"
                                                };
                                            }
                                            <span class="rs-status @statusClass">@displayStatus</span>
                                        </td>
                                        <td>@item.BillNoPrint</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="rs-empty">
                                        <div class="rs-empty-state">
                                            <i class="fas fa-flask"></i>
                                            <p>@(isLoading ? "Loading results..." : "No results found. Adjust filters and click View.")</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Side Panel -->
        @if (selectedRowIndex >= 0 && selectedRowIndex < filteredResults.Count)
        {
            <div class="rs-side-panel">
                <!-- Test Details -->
                <div class="rs-panel-card rs-test-card">
                    <div class="rs-panel-header" style="display: flex; justify-content: space-between; align-items: center;">
                        <div class="rs-panel-title">
                            <i class="fas fa-vials"></i> Test Details
                        </div>
                  
                    </div>
                    <div class="rs-table-wrap rs-test-table-wrap">
                        <table class="rs-table rs-test-table">
                            <thead>
                                <tr>
                                    <th class="rs-col-sel">Sel</th>
                                    <th>Test Name</th>
                                    <th class="rs-col-status">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (isLoadingTests)
                                {
                                    <tr>
                                        <td colspan="3" class="rs-empty-sm">
                                            <span class="rs-spinner" style="display:inline-block;margin-right:8px;"></span>
                                            Loading tests...
                                        </td>
                                    </tr>
                                }
                                else if (selectedTestDetails.Any())
                                {
                                    @foreach (var test in selectedTestDetails)
                                    {
                                        <tr>
                                            <td>
                                                <input type="checkbox" class="rs-test-check" @bind="test.IsSelected" />
                                            </td>
                                            <td class="rs-td-testname">@test.TestName</td>
                                            <td>
                                                <span class="rs-status @(test.IsPending ? "rs-status-pending" : "rs-status-finished")">
                                                    @(test.IsPending ? "Pending" : "Finished")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="rs-empty-sm">Select a row to view tests</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Statement Links -->
                <!-- <div class="rs-panel-card rs-statement-card">
                    <div class="rs-panel-header">
                        <div class="rs-panel-title">
                            <i class="fas fa-file-alt"></i> Statement
                        </div>
                    </div>
                    <div class="rs-statement-links">
                        <button class="rs-statement-btn" @onclick="PrintRegister">
                            <span class="rs-stmt-num">1</span> Print Register
                        </button>
                        <button class="rs-statement-btn" @onclick="PendingScanCases">
                            <span class="rs-stmt-num">2</span> Pending Scan Cases
                        </button>
                        <button class="rs-statement-btn" @onclick="PrintOutsourceList">
                            <span class="rs-stmt-num">3</span> Print Outsource List
                        </button>
                        <button class="rs-statement-btn" @onclick="PrintSummary">
                            <span class="rs-stmt-num">4</span> Print Summary
