                        <button class="rs-statement-btn" @onclick="PrintUserWiseSummary">
                            <span class="rs-stmt-num">5</span> Print User Wise Summary
                        </button>
                    </div>
                </div> -->
            </div>
        }
    </div>

    <!-- Bottom Action Bar -->
    <!-- <div class="rs-bottom-bar">
        <div class="rs-bottom-left">
            <div class="rs-field-inline">
                <label class="rs-label-sm">Authorized User</label>
                <select class="rs-select rs-select-sm" @bind="authorizedUser">
                    <option value="">Select Authorized User</option>
                    @foreach (var user in authorizedUsers)
                    {
                        <option value="@user.UserCode">@user.Name</option>
