    private async Task ReloadAsync()
    {
        try
        {
            Guid pnid = prd.prm.PNID == Guid.Empty ? Guid.NewGuid() : prd.prm.PNID;
            var res = await
            http.GetAsync($"{appSettings.BaseUrl}genetics/prenatalreload?rid={Uri.EscapeDataString(prd.prm.RequestGUID.ToString())}");
            if (res.IsSuccessStatusCode)
            {
                prd = await res.Content.ReadFromJsonAsync<PreNatalResultData>();
                prd.prm.PNID = pnid;
                prd.prd.ToList().ForEach(x => x.PNID = pnid);

                rdet1 = prd.prd.Where(x => x.Title == "Result Table").ToList();
                rdet2 = prd.prd.Where(x => x.Title == "Result Table 2").ToList();
                rdetBiochemical = prd.prd.Where(x => !string.IsNullOrEmpty(x.BiochemicalMarker)).ToList();
            }
            StateHasChanged();

        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message.ToString());

        }
    }

    private bool isMachineResultDialogVisible = false;
    private List<MachineResultItem> machineResultsList = new();

    private async Task GetMachineResultsAsync()
    {
        errorMessage = null;
        if (prenatalrequest == null || prenatalrequest.RequestGUID == Guid.Empty)
        {
            errorMessage = "No request selected for machine results.";
            return;
        }

        try
        {
            var url = $"{appSettings.BaseUrl}MachineInterface/GetResultbyid?rguid={prenatalrequest.RequestGUID}";
            if (!http.DefaultRequestHeaders.Contains("X-Tenant-ID"))
                http.DefaultRequestHeaders.Add("X-Tenant-ID", appSettings.ClientId);
            var res = await http.GetAsync(url);
            
            if (res.IsSuccessStatusCode)
            {
                var allMachineResults = await res.Content.ReadFromJsonAsync<List<MachineResultItem>>() ?? new();

                Console.WriteLine("--- Machine Results Debug ---");
                Console.WriteLine($"Total results fetched: {allMachineResults.Count}");
                foreach (var item in allMachineResults)
                {
                    Console.WriteLine($"Raw - Param: {item.ParameterName}, Value: {item.ParameterValue}, SampleNo: {item.SampleNo}");
                }
                
                // Use all machine results without filtering by assigned codes
                machineResultsList = allMachineResults;
                
                if (machineResultsList != null && machineResultsList.Count > 0)
                {
                    isMachineResultDialogVisible = true;
                    StateHasChanged();
                }
                else
                {
                    errorMessage = "No machine results found for this request that match assigned machine codes.";
                }
            }
            else
            {
                errorMessage = $"Failed to get machine results: {res.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error fetching machine results: {ex.Message}";
        }
    }

    private async Task AddMachineResultsToGrid()
    {
        if (machineResultsList != null && machineResultsList.Count > 0 && prd?.prd != null)
        {
            bool updated = false;
            foreach (var item in machineResultsList)
            {
                // Update or add to rdet1 (Result Table)
                // First try to match by MachineCode
                var row1 = rdet1.FirstOrDefault(x => string.Equals(x.MachineCode, item.ParameterName, StringComparison.OrdinalIgnoreCase));
                
                // If no match by MachineCode, try to match by BiochemicalMarker (e.g., "Placental Growth Factor (PIGF)" contains "PIGF")
                if (row1 == null)
                {
                    row1 = rdet1.FirstOrDefault(x => x.BiochemicalMarker != null && 
                           (x.BiochemicalMarker.Contains(item.ParameterName, StringComparison.OrdinalIgnoreCase) || 
                            x.BiochemicalMarker.EndsWith($"({item.ParameterName})", StringComparison.OrdinalIgnoreCase)));
                }
                
                if (row1 != null)
                {
                    row1.Concentration = item.ParameterValue;
                    updated = true;
                }
                else
                {
                    var newRow = new PreNatal_Result_Details
                    {
                        PNDetailsID = Guid.NewGuid(),
                        Title = "Result Table",
                        MachineCode = item.ParameterName,
                        Concentration = item.ParameterValue,
                        PNID = prd.prm.PNID,
                        BiochemicalMarker = item.ParameterName,
                        // Set other default fields if necessary
                    };
                    prd.prd.Add(newRow);
                    rdet1.Add(newRow);
                    updated = true;
                }

                // Update rdet2 (Result Table 2) if matching RiskValueMachineCode or CutOffMachineCode exists
                var rowsToUpdateRisk = rdet2.Where(x => string.Equals(x.RiskValueMachineCode, item.ParameterName, StringComparison.OrdinalIgnoreCase)).ToList();
                foreach(var r in rowsToUpdateRisk)
                {
                    r.RiskValue = item.ParameterValue;
                    updated = true;
                }

                var rowsToUpdateCutOff = rdet2.Where(x => string.Equals(x.CutOffMachineCode, item.ParameterName, StringComparison.OrdinalIgnoreCase)).ToList();
                foreach(var r in rowsToUpdateCutOff)
                {
                    r.CutOff = item.ParameterValue;
                    updated = true;
                }

                // Fallback to legacy MachineCode matching for rdet2
                var row2Default = rdet2.FirstOrDefault(x => string.Equals(x.MachineCode, item.ParameterName, StringComparison.OrdinalIgnoreCase));
                if (row2Default != null)
                {
                    row2Default.RiskValue = item.ParameterValue;
                    updated = true;
                }
            }
            
            if (updated)
            {
                 if(grd1 != null) await grd1.Refresh();
                 if(grd2 != null) await grd2.Refresh();
            }
        }
        isMachineResultDialogVisible = false;
        StateHasChanged();
    }

