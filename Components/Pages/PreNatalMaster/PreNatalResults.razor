    private async Task DeleteFile(string key, int uploadno)
    {
        if (string.IsNullOrEmpty(key))
        {
            Console.WriteLine("No file key provided.");
            return;
        }
        string client = (await sessionStorage.GetAsync<string>("MainBranch")).Value ?? "General";
        // Encode key to safely include in query string
        var encodedKey = Uri.EscapeDataString(key);

        // Call DELETE API
        var response = await http.DeleteAsync($"{appSettings.BaseUrl}files/delete?client={client}&key={encodedKey}");

        if (response.IsSuccessStatusCode)
        {
            switch (uploadno)
            {
                case 1: prd.prm.Filepath1 = ""; break;
                case 2: prd.prm.Filepath2 = ""; break;
            }
            Console.WriteLine("File deleted successfully!");
            await NotificationService.ShowSuccess("File deleted successfully!");
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Delete failed: {response.StatusCode} - {error}");
        }

        StateHasChanged();
    }
