@code {
    // Notification System
    public enum NotificationType { Success, Error, Warning, Info }
    SfGrid<PreNatal_Test_Result_Master> grd1;
    public class Notification
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Title { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
        public NotificationType Type { get; set; }
        public bool IsRemoving { get; set; }
        public Timer? AutoRemoveTimer { get; set; }
    }

    private List<Notification> notifications = new();

    // Original code variables
    IList<Test_Master> tm = new List<Test_Master>();
    PreNatal_Test_Master pntm = new PreNatal_Test_Master();
    string searchtest = string.Empty;
    // private Syncfusion.Blazor.DropDowns.SfComboBox<string, Test_Master>? _testCombo;
    PreNatal_Test_Result_Master ptrm1 = new PreNatal_Test_Result_Master();
    IList<PreNatal_Test_Result_Master> ptrm = new List<PreNatal_Test_Result_Master>();
    string token = string.Empty;
    private System.Timers.Timer? debounceTimer;
    private bool isSaving = false;


    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (first)
        {
            http.DefaultRequestHeaders.Add("X-Tenant-ID", AppSettings.ClientId);
            debounceTimer = new System.Timers.Timer(10);
            debounceTimer.Elapsed += async (s, e) => await OnDebounceTimerElapsed();
            debounceTimer.AutoReset = false;

            var tkn = await _sessionStorage.GetAsync<UserAuth>("claim");
            if (tkn.Success && tkn.Value != null)
            {
                token = tkn.Value.token;
            }

            var savedDataResult = await _sessionStorage.GetAsync<PreNatalMasterData>("preNatalData");
            if (savedDataResult.Success && savedDataResult.Value != null)
            {
                var savedData = savedDataResult.Value;
                pntm = savedData.ptm ?? new();
                ptrm = new List<PreNatal_Test_Result_Master>(savedData.ptrm ?? new List<PreNatal_Test_Result_Master>());
                searchtest = tm.FirstOrDefault(t => t.TCode == pntm.TCode)?.Name ?? string.Empty;

                if (savedData.ptrm?.Any() == true)
                {
                    ShowNotification("Session Restored", "Previous session data has been loaded successfully.", NotificationType.Info);
                }
            }
            StateHasChanged();
        }

    }

    // Enhanced Notification Methods
    private void ShowNotification(string message, NotificationType type = NotificationType.Info, int autoRemoveSeconds = 5)
    {
        ShowNotification(string.Empty, message, type, autoRemoveSeconds);
    }

    private void ShowNotification(string title, string message, NotificationType type = NotificationType.Info, int autoRemoveSeconds = 5)
    {
        var notification = new Notification
        {
            Title = title,
            Message = message,
            Type = type
        };

        notifications.Add(notification);

        if (autoRemoveSeconds > 0)
        {
            notification.AutoRemoveTimer = new Timer(async _ => await AutoRemoveNotification(notification.Id), 
                null, autoRemoveSeconds * 1000, Timeout.Infinite);
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task AutoRemoveNotification(string notificationId)
    {
        var notification = notifications.FirstOrDefault(n => n.Id == notificationId);
        if (notification != null)
        {
            notification.IsRemoving = true;
            await InvokeAsync(StateHasChanged);

            await Task.Delay(300); // Wait for animation

            notifications.Remove(notification);
            notification.AutoRemoveTimer?.Dispose();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RemoveNotification(string notificationId)
    {
        var notification = notifications.FirstOrDefault(n => n.Id == notificationId);
        if (notification != null)
        {
            notification.AutoRemoveTimer?.Dispose();
            notification.IsRemoving = true;
            await InvokeAsync(StateHasChanged);

            await Task.Delay(300);

            notifications.Remove(notification);
            await InvokeAsync(StateHasChanged);
        }
    }

    // Original code methods with enhanced notifications

    private async Task SearchTests()
    {
        if (string.IsNullOrWhiteSpace(searchtest))
        {
            tm.Clear();
        }
        else
        {
            try
            {
                var request = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}request/SearchTest?testname={Uri.EscapeDataString(searchtest)}");
                if (!string.IsNullOrEmpty(token))
                {
                    request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
                }
                var response = await http.SendAsync(request);

                if (response.IsSuccessStatusCode)
                {
                    var res = await response.Content.ReadAsStringAsync();
                    tm = JsonConvert.DeserializeObject<List<Test_Master>>(res) ?? new();

                    if (!tm.Any())
                    {
                        ShowNotification("No tests found matching your search criteria.", NotificationType.Warning);
                    }
                    else
                    {
                        // Auto-show is handled by the UI based on tm.Any()
                    }
                }
                else
                {
                    tm.Clear();
                    ShowNotification("Error searching tests", "Please check your connection and try again.", NotificationType.Error);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error searching tests: {ex.Message}");
                tm.Clear();
                ShowNotification("Search Failed", "An error occurred while searching for tests.", NotificationType.Error);
            }
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task SelectTestItem(Test_Master test, string type)
    {
        if (test == null) return;

        pntm.TCode = test.TCode;
        searchtest = test.Name;
        tm.Clear();
        //await PersistDataToSession();

        var res = await http.GetAsync($"{AppSettings.BaseUrl}genetics/prenataltest?TCode={test.TCode}");
        if(res.IsSuccessStatusCode)
        {
            var tt1 = await res.Content.ReadFromJsonAsync<PreNatalMasterData>();
            pntm = tt1.ptm;
            ptrm = tt1.ptrm;

            if(ptrm!=null && ptrm.Count>0)
            {
                foreach(var it in ptrm)
                {
                    it.Method = it.Method ?? "";
                    it.MachineCode = it.MachineCode ?? "";
                }
            }
        }

        ShowNotification("Test Selected", $"Selected: {test.Name}", NotificationType.Success, 3);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ClearTestSelection()
    {
        // Clear the test selection input
        searchtest = string.Empty;
        tm.Clear();
        
        // Clear the main form
        pntm = new();
        ptrm = new List<PreNatal_Test_Result_Master>();
        
        // Clear the result table entry form
        ptrm1 = new();
        
        ShowNotification("Form Cleared", "Test selection and all forms have been cleared.", NotificationType.Info, 3);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnTestFiltering(Syncfusion.Blazor.DropDowns.FilteringEventArgs args)
    {
        args.PreventDefaultAction = true;
        searchtest = args.Text; // Update search term

        debounceTimer?.Stop();
        debounceTimer?.Dispose();
        debounceTimer = new System.Timers.Timer(300);
        debounceTimer.AutoReset = false;
        debounceTimer.Elapsed += async (_, __) => await InvokeAsync(SearchTests);
        debounceTimer.Start();
    }

    private async Task OnTestSelected(Syncfusion.Blazor.DropDowns.ChangeEventArgs<string, Test_Master> args)
    {
        if (args.ItemData != null)
        {
            await SelectTestItem(args.ItemData, "Test");
        }
    }

    private async Task OnInputChanged(Microsoft.AspNetCore.Components.ChangeEventArgs e, string type)
    {
        searchtest = e.Value?.ToString() ?? string.Empty;
        debounceTimer?.Stop();
        debounceTimer?.Dispose();
        debounceTimer = new System.Timers.Timer(300) { AutoReset = false };
        debounceTimer.Elapsed += async (_, __) => await InvokeAsync(SearchTests);
        debounceTimer.Start();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e, string type)
    {
        // This method can be simplified or removed as SfComboBox handles keyboard navigation.
    }

    private async Task OnDebounceTimerElapsed()
    {
        await InvokeAsync(SearchTests);
    }

    public void Dispose()
    {
        debounceTimer?.Dispose();
        foreach (var notification in notifications)
        {
            notification.AutoRemoveTimer?.Dispose();
        }
    }

    private async Task PersistDataToSession()
    {
        var dataToSave = new PreNatalMasterData
        {
            ptm = pntm,
            ptrm = ptrm.ToList()
        };
        await _sessionStorage.SetAsync("preNatalData", dataToSave);
    }

    private async Task AddTestResult()
    {
        // if (string.IsNullOrWhiteSpace(ptrm1.BiochemicalMarker))
        // {
        //     ShowNotification("Validation Error", "Biochemical Marker is required", NotificationType.Error);
        //     return;
        // }

        // Use LINQ's FirstOrDefault to find an existing item by its unique ID.
        var existingItem = ptrm.FirstOrDefault(x => x.PNTRID != Guid.Empty && x.PNTRID == ptrm1.PNTRID);

        if (existingItem != null)
        {
            // Update existing item's properties
            existingItem.Title = ptrm1.Title;
            existingItem.BiochemicalMarker = ptrm1.BiochemicalMarker;
            existingItem.Concentration = ptrm1.Concentration;
            existingItem.Unit = ptrm1.Unit;
            existingItem.CorrMOM = ptrm1.CorrMOM;
            existingItem.Disorder = ptrm1.Disorder;
            existingItem.RiskValue = ptrm1.RiskValue;
            existingItem.CutOff = ptrm1.CutOff;
            existingItem.FinalRisk = ptrm1.FinalRisk;
            existingItem.RangeType = ptrm1.RangeType;
            existingItem.RangeFrom = ptrm1.RangeFrom;
            existingItem.RangeTo = ptrm1.RangeTo;
            existingItem.Method = ptrm1.Method;
            existingItem.LowMessage = ptrm1.LowMessage;
            existingItem.HighMessage = ptrm1.HighMessage;
            existingItem.NormalMessage = ptrm1.NormalMessage;
            existingItem.MachineCode = "";
            ShowNotification("Test Result Updated", "The entry has been updated successfully.", NotificationType.Success, 3);
        }
        else
        {
            // Add a new item
            ptrm1.PNTRID = Guid.NewGuid();
            ptrm.Add(new PreNatal_Test_Result_Master
            {
                PNTRID = ptrm1.PNTRID,
                Title = ptrm1.Title ?? "",
                BiochemicalMarker = ptrm1.BiochemicalMarker ?? "",
                Concentration = ptrm1.Concentration ?? "",
                Unit = ptrm1.Unit ?? "",
                CorrMOM = ptrm1.CorrMOM ?? "",
                Disorder = ptrm1.Disorder ?? "",
                RiskValue = ptrm1.RiskValue ?? "",
                CutOff = ptrm1.CutOff ?? "",
                FinalRisk = ptrm1.FinalRisk ?? "",
                RangeType = ptrm1.RangeType ?? "-",
                RangeFrom = ptrm1.RangeFrom,
                RangeTo = ptrm1.RangeTo,
                Method = ptrm1.Method ?? "",
                LowMessage = ptrm1.LowMessage ?? "",
                HighMessage = ptrm1.HighMessage ?? "",
                NormalMessage = ptrm1.NormalMessage ?? "",
                MachineCode = ""
            });
            ShowNotification("Test Result Added", "The new entry has been added to the table.", NotificationType.Success, 3);
        }

        // Clear the form for the next entry
        ptrm1 = new();
        
        // Refresh the grid and persist the session
        grd1?.Refresh();
        await PersistDataToSession();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveData()
    {
        if (pntm.TCode == 0)
        {
            ShowNotification("Validation Error", "Please select a test first.", NotificationType.Warning);
            return;
        }

        if (!ptrm.Any())
        {
            ShowNotification("Validation Error", "Please add at least one test result.", NotificationType.Warning);
            return;
        }

        isSaving = true;
        ShowNotification("Saving Data", "Please wait while we save your data...", NotificationType.Info, 0);

        try
        {
            var preNatalMasterData = new
            {
                pntm = this.pntm,
                ptrm = this.ptrm.ToList()
            };
            var tt = JsonConvert.SerializeObject(preNatalMasterData);
            var response = await _apiData.PostData("PreNatalTest/AddPreNatalTest", JsonConvert.SerializeObject(preNatalMasterData), token);

            // Clear the "saving" notification
            var savingNotification = notifications.FirstOrDefault(n => n.Message.Contains("Please wait while we save"));
            if (savingNotification != null)
            {
                await RemoveNotification(savingNotification.Id);
            }

            if (response.Equals("Success", StringComparison.OrdinalIgnoreCase))
            {
                _ = NotificationService.ShowSuccess("Data has been saved successfully!");
                ShowNotification("Success!", "Data has been saved successfully!", NotificationType.Success, 5);
                pntm = new();
                ptrm.Clear();
                searchtest = string.Empty;
                await _sessionStorage.DeleteAsync("preNatalData");
            }
            else
            {
                ShowNotification("Save Failed", $"Error: {response}", NotificationType.Error, 10);
            }
        }
        catch (Exception ex)
        {
            ShowNotification("Unexpected Error", $"An error occurred while saving: {ex.Message}", NotificationType.Error, 10);
        }
        finally
        {
            isSaving = false;
            await InvokeAsync(StateHasChanged);
        }
    }



    private async Task SaveMaster(EditContext context)
    {
        pntm.Interpretation = pntm.Interpretation ?? "";
        pntm.Abnormal = pntm.Abnormal ?? "";
        pntm.Normal = pntm.Normal ?? "";
        pntm.Comments=pntm.Comments??"";
        pntm.Disclaimer = pntm.Disclaimer ?? "";

        // Set PNCode for all test result masters
        foreach (var item in ptrm)
        {
            item.PNCode = pntm.PNCode;
        }

        PreNatalMasterData preNatalMaster = new PreNatalMasterData
        {
            ptm = this.pntm,
            ptrm = ptrm.ToList()
        };
        var tt = JsonConvert.SerializeObject(preNatalMaster);
        var res = await http.PostAsJsonAsync($"{AppSettings.BaseUrl}Genetics/PrenatalMaster", preNatalMaster);
        if (res.IsSuccessStatusCode)
        {
            var responseContent = await res.Content.ReadAsStringAsync();
            _ = NotificationService.ShowSuccess("Data saved successfully!");
            ShowNotification("Data saved successfully!", NotificationType.Success, 5);
            pntm = new();
            ptrm.Clear();
            this.PersistDataToSession();
        }
        else
        {
            var errorContent = await res.Content.ReadAsStringAsync();
            Console.WriteLine($"Error saving data: {res.StatusCode} - {errorContent}");
            ShowNotification("Error saving data", $"Please try again later. Status: {res.StatusCode}", NotificationType.Error, 10);
        }

    }

    private async Task DeleteTest(Guid tid)
    {
        var itemToRemove = ptrm.FirstOrDefault(x => x.PNTRID == tid);
        if (itemToRemove != null)
        {
            ptrm.Remove(itemToRemove);
            grd1?.Refresh(); // Refresh the grid to show the change
            await PersistDataToSession();
            _ = NotificationService.ShowSuccess("Entry removed successfully!");
            ShowNotification("Entry Removed", "The selected entry has been removed.", NotificationType.Warning, 3);
            await InvokeAsync(StateHasChanged);
        }
    }
