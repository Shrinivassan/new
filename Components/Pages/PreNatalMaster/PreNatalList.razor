<!-- Modern PreNatal Header -->
<div class="d-flex align-items-center mb-3 py-2 px-3 shadow-sm rounded position-relative overflow-hidden" style="background: var(--bg-card); border-left: 5px solid #667eea; border: 1px solid var(--border-color); border-left-width: 5px;">
    <i class="fas fa-dna position-absolute pe-none" style="font-size: 6rem; right: 10px; top: -20px; opacity: 0.05; color: #667eea; transform: rotate(20deg);"></i>
    <div class="me-3 rounded-circle d-flex justify-content-center align-items-center" style="background: rgba(102, 126, 234, 0.1); width: 45px; height: 45px; z-index: 1;">
        <i class="fas fa-dna" style="font-size: 1.5rem; color: #667eea;"></i>
    </div>
    <div style="z-index: 1;">
        <h4 class="mb-0 fw-bold" style="font-family: 'Inter', sans-serif; letter-spacing: 0.3px; color: var(--text-primary);">PreNatal List</h4>
    </div>
</div>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col">
            <div class="card">
                <div class="card-body">
                    <div class="row align-items-end">
                        <div class="col-md-2">
                            <label>From Date</label>    
                            <InputDate @bind-Value="fromDate" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label>To Date</label>    
                            <InputDate @bind-Value="toDate" class="form-control" />
                        </div>
                        <div class="col-md-2">
    <button class="btn btn-primary mt-2" @onclick="btnrefreshAsync">
        <i class="bi bi-search"></i> Search
    </button>
</div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <div class="card">
                <div class="card-body">
                    <SfGrid @ref="grd1" DataSource="@preNatalrequests">
                        @* <GridEvents RowSelected="OnRowSel" TValue="PreNatalRequest"></GridEvents> *@
                        <GridColumns>
                            @* <GridColumn Field="RequestGUID" IsPrimaryKey="true" HeaderText="GUID"></GridColumn> *@
                            <GridColumn Field="RequestSno" HeaderText="SID" Width="40"></GridColumn>
                            <GridColumn Field="RequestDateTime" Format="dd-MM-yyyy" HeaderText="Date" Width="120"></GridColumn>
                            <GridColumn Field="PatientName" HeaderText="Patient Name" Width="200"></GridColumn>
                            <GridColumn Field="Age" HeaderText="Age" Width="80"></GridColumn>
                            <GridColumn Field="Gender" HeaderText="Gender" Width="100"></GridColumn>
                            <GridColumn Field="MobileNo" HeaderText="Mobile No" Width="120"></GridColumn>
                            <GridColumn Field="DoctorFullName" HeaderText="Referral" Width="150"></GridColumn>
                            <GridColumn Field="TestName" HeaderText="Test Name" Width="200"></GridColumn>


                            <!-- Actions Column -->
                            <GridColumn HeaderText="Actions" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center" Width="150">
                                <Template>
                                    @{
                                        var dat = (context as PreNatalRequest);
                                    }
                                    <div style="display: flex; gap: 8px; justify-content: center;">
                                     <button type="button"
        class="btn btn-primary btn-sm d-flex align-items-center gap-1"
        style="border: 1px solid blue; color: blue;"
        @onclick="() => ResultEntry(dat)">
    <i class="bi bi-box-arrow-in-right" style="color: blue;"></i>
    Entry
</button>


                                        @if (dat.AuthorizedBy > 0)
                                        {
                                            <button type="button"
                                                    @onclick="() => GetReport(dat)"
                                                    class="btn btn-info btn-sm d-flex align-items-center gap-1">
                                                <i class="bi bi-eye-fill"></i>
                                                View
                                            </button>
                                        }
                                    </div>
                                </Template>
                            </GridColumn>
                        </GridColumns>
                    </SfGrid>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col">
          
        </div>
    </div>
 
</div>


    
@if(isviewer==true)
{
    <div class="row">
       
    </div>    
}
<SfDialog Visible="@isshow" Width="100%" Height="100vh" IsModal="true" ShowCloseIcon="true">
    <DialogTemplates>
        <Header>Result Entry</Header>
        <Content>
         <Lims.Components.Shared.ToastComponent />
            <PreNatalResults prenatalrequest="@pnr"></PreNatalResults>
        </Content>
    </DialogTemplates>
    <DialogEvents OnClose="CloseEntry"></DialogEvents>
</SfDialog>
<SfDialog Visible="@isviewer" Width="80%" Header="Result" Height="80%" IsModal="true" ShowCloseIcon="true">
    <DialogTemplates>
        <Header>Result Entry</Header>
        <Content>
            <ReportViewer Reportstring="@reportstring" pnr="@reportrequest"></ReportViewer>
        </Content>
    </DialogTemplates>
    <DialogEvents OnClose="CloseViewer"></DialogEvents>
</SfDialog>
@code {
    DateTime fromDate = DateTime.Now;
    DateTime toDate = DateTime.Now;

    SfGrid<PreNatalRequest> grd1;
