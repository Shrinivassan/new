    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            http.DefaultRequestHeaders.Clear();
            http.DefaultRequestHeaders.Add("X-Tenant-ID", appSettings.ClientId);
            await btnrefreshAsync();
        }
    }

    private async Task btnrefreshAsync()
    {
        try
        {
            string sd = fromDate.ToString("yyyy-MM-dd") + " 12:00:00 AM";
            string ed = toDate.ToString("yyyy-MM-dd") + " 11:59:59 PM";
            var res = await http.GetAsync($"{appSettings.BaseUrl}Genetics/PreNatalRequest?fdate={Uri.EscapeDataString(sd)}&tdate={Uri.EscapeDataString(ed)}");
            if (res.IsSuccessStatusCode)
            {
                var tt = res.Content.ReadAsStringAsync().Result;

                if (!string.IsNullOrWhiteSpace(tt))
                {
                    var natal = JsonConvert.DeserializeObject<IList<PreNatalRequest>>(tt) ?? new List<PreNatalRequest>();

                    if (natal != null && natal.Count > 0)
                    {
                        preNatalrequests = natal.Where(x => x.SkyCode == "PreNatal").ToList();
                        // Load status overrides from sessionStorage
                        foreach (var req in preNatalrequests)
                        {
                            var status = await JS.InvokeAsync<string>("sessionStorage.getItem", $"prenatal_status_{req.RequestGUID}");
                            if (!string.IsNullOrEmpty(status))
                            {
                                req.RequestStatus = status;
                            }
                        }
                    }
                    StateHasChanged();

                }
            }
        }catch(Exception ex)
        {
            var tt = ex.Message.ToString();
            var tt1 = tt;
        }
    }

    private async Task ResultEntry(PreNatalRequest args)
    {

        pnr = args;
        isshow = true;

        StateHasChanged();
    }

    private async Task OnRowSel(RowSelectEventArgs<PreNatalRequest> args)
    {
        pnr = args.Data;
        isshow = true;
        StateHasChanged();
    }

    private async Task CloseEntry()
    {
        isshow = false;
        await btnrefreshAsync();
    }
    private async Task CloseViewer()
    {
        isviewer = false;
        await btnrefreshAsync();
