<script>
    (function () {
        var canvas = document.getElementById('lx-canvas');
        if (!canvas) return;
        var ctx = canvas.getContext('2d');
        var W, H, particles = [], COUNT = 60;

        function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }

        function rnd(a, b) { return a + Math.random() * (b - a); }

        function mkP() {
            return {
                x: Math.random() * W, y: Math.random() * H, r: rnd(1.5, 3.5),
                vx: rnd(-0.25, 0.25), vy: rnd(-0.5, -0.15),
                alpha: rnd(0.3, 0.7), hue: Math.random() < 0.5 ? 195 : 240
            };
        }

        function init() { particles = []; for (var i = 0; i < COUNT; i++) particles.push(mkP()); }

        function draw() {
            ctx.clearRect(0, 0, W, H);
            for (var i = 0; i < particles.length; i++) {
                for (var j = i + 1; j < particles.length; j++) {
                    var dx = particles[i].x - particles[j].x, dy = particles[i].y - particles[j].y;
                    var d = Math.sqrt(dx * dx + dy * dy);
                    if (d < 120) {
                        ctx.beginPath();
                        ctx.strokeStyle = 'rgba(56,189,248,' + (0.1 * (1 - d / 120)) + ')';
                        ctx.lineWidth = 0.7;
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.stroke();
                    }
                }
            }
            particles.forEach(function (p) {
                var g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 3);
                g.addColorStop(0, 'hsla(' + p.hue + ',90%,72%,' + p.alpha + ')');
                g.addColorStop(1, 'hsla(' + p.hue + ',90%,72%,0)');
                ctx.beginPath(); ctx.fillStyle = g;
                ctx.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2); ctx.fill();
                p.x += p.vx; p.y += p.vy;
                if (p.y < -10) { p.y = H + 10; p.x = Math.random() * W; }
                if (p.x < -10) p.x = W + 10;
                if (p.x > W + 10) p.x = -10;
            });
            requestAnimationFrame(draw);
        }

        window.addEventListener('resize', function () { resize(); init(); });
        resize(); init(); draw();
    })();
</script>

@code {
    private ReferralLogin loginModel = new ReferralLogin();















    private bool isLoading = false;















    private bool showSuccessNotification = false;















    private bool showErrorNotification = false;















    private string errorMessage = "";































    private IList<Branch_Master> branches = new List<Branch_Master>();































    protected override async Task OnInitializedAsync()















    {















        // Fallback to fake data if API call fails or returns empty















    }































    public class Address















    {















        public string State { get; set; }















    }































    protected override async Task OnAfterRenderAsync(bool firstRender)















    {















        if (firstRender)















        {















            try















            {















                http.DefaultRequestHeaders.Clear();















                http.DefaultRequestHeaders.Add("X-Tenant-ID", AppSettings.ClientId);















                var res = await http.GetAsync($"{AppSettings.BaseUrl}masters/branches");















                if (res.IsSuccessStatusCode)















                {















                    var branchList = await res.Content.ReadFromJsonAsync<List<Branch_Master>>();















                    if (branchList != null && branchList.Any())















                    {















                        branches = branchList.Where(x => x.Deleted == false).ToList();















                        loginModel.BranchCode = branches.Where(x => x.IsMainBranch == true).Select(x => x.BHCode).FirstOrDefault();















                        await _sessionStorage.SetAsync("MainBranch", branches.Where(x => x.IsMainBranch == true).Select(x =>







                        x.Description).FirstOrDefault());















                    }















                    StateHasChanged();















                }















                else















                {















                    errorMessage = "Invalid credentials or server error.";















                    _ = NotificationService.ShowError(errorMessage);















                }















            }















            catch (Exception ex)















            {















                Console.WriteLine($"Failed to load branches from API: {ex.Message}");















            }































            var loggedOutFlag = await _sessionStorage.GetAsync<bool>("justLoggedOut");















            if (loggedOutFlag.Success && loggedOutFlag.Value)















            {















                await _sessionStorage.DeleteAsync("justLoggedOut");















                await NotificationService.ShowInfo("You have been signed out.", "Signed Out", 4000);















            }















        }















    }































    private async Task HandleLogin()















    {















        isLoading = true;















        showErrorNotification = false;































        try















        {















            if (!string.IsNullOrWhiteSpace(loginModel?.DoctorCode)















            && !string.IsNullOrWhiteSpace(loginModel?.Password)















            && loginModel.BranchCode > 0)















            {















                loginModel.LoginType = "User";















                var res = await http.PostAsJsonAsync($"{AppSettings.BaseUrl}Auth/login", loginModel);















                if (res.IsSuccessStatusCode)















                {















                    var response = await res.Content.ReadAsStringAsync();















                    var tt = JsonConvert.DeserializeObject<LoginResponse>(response);















                    string token = tt.token;















                    var userDetails = tt.userdetails;















                    var rights = tt.rights;































                    UserAuth user = new UserAuth















                        {















                            token = token,















                            UserCode = userDetails.UserCode,















                            Name = userDetails.Name,















                            CounterCode = userDetails.CNTCode,















                            BranchCode = userDetails.BHCode,















                        };































                    await _sessionStorage.SetAsync("claim", user);















                    await _sessionStorage.SetAsync("UserRights", rights);















                    await _sessionStorage.SetAsync("branch", branches);















                    await _sessionStorage.SetAsync("UserDetails", userDetails);































                    await NotificationService.ShowSuccess("Login successful. Redirecting to dashboard...");















                    await Task.Delay(100);















                    StateHasChanged();















                    await Task.Delay(2000);















                    Nav.NavigateTo("/Home");















                }















                else















                {















                    var errorContent = await res.Content.ReadAsStringAsync();















                    errorMessage = "Invalid credentials or server error.";















                    _ = NotificationService.ShowError(errorMessage);















                    Console.WriteLine($"Login failed: {errorContent}");















                }















            }















            else















            {















                errorMessage = "Username, password, and branch are required.";















                _ = NotificationService.ShowError(errorMessage);















            }















        }















        catch (Exception ex)















        {















            errorMessage = $"Login failed: {ex.Message}";















            _ = NotificationService.ShowError(errorMessage);















            Console.WriteLine($"Login failed: {ex.Message}");















        }















        finally















        {















            isLoading = false;















        }















    }































    private void DismissNotification() { showSuccessNotification = false; }















    private void DismissErrorNotification() { showErrorNotification = false; }
}