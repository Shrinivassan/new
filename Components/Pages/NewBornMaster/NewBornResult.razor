    string uploadkey = "";
    bool isReportFileVisible = false;
    string reportFileBase64 = "";

    private async Task UploadFile(InputFileChangeEventArgs e, int uploadno)
    {
        if (SelectedBill == null) return;
        string client = (await sessionStorage.GetAsync<string>("MainBranch")).Value ?? "General";
        var file = e.File;
        var content = new MultipartFormDataContent();
        var streamContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
        streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
        content.Add(streamContent, "file", (SelectedBill.RequestSnoPrint?.Replace("/", "") ?? "NB") + "_" + file.Name);

        var response = await Http.PostAsync($"{appSettings.BaseUrl}files/upload?client={client}", content);

        if (response.IsSuccessStatusCode)
        {
            var tt = await response.Content.ReadFromJsonAsync<JsonElement>();
            uploadkey = tt.GetProperty("key").GetString();
            switch (uploadno)
            {
                case 1: nrd.nrm.Filepath1 = uploadkey; break;
                case 2: nrd.nrm.Filepath2 = uploadkey; break;
            }
            await NotificationService.ShowSuccess("File uploaded successfully!");
            StateHasChanged();
        }
        else
        {
            Console.WriteLine($"Upload failed: {response.StatusCode}");
        }
    }

    private async Task DownloadFile(string key)
    {
        try
        {
            string client = (await sessionStorage.GetAsync<string>("MainBranch")).Value ?? "General";
            var result = await Http.GetFromJsonAsync<FileDownloadResult>($"{appSettings.BaseUrl}files/download/{key}?client={client}");

            if (result != null)
            {
                reportFileBase64 = Convert.ToBase64String(result.Base64);
                isReportFileVisible = true;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error downloading file: {ex.Message}";
        }
    }

    private async Task DeleteFile(string key, int uploadno)
    {
        if (string.IsNullOrEmpty(key)) return;
        string client = (await sessionStorage.GetAsync<string>("MainBranch")).Value ?? "General";
        var encodedKey = Uri.EscapeDataString(key);
        var response = await Http.DeleteAsync($"{appSettings.BaseUrl}files/delete?client={client}&key={encodedKey}");

        if (response.IsSuccessStatusCode)
        {
            switch (uploadno)
            {
                case 1: nrd.nrm.Filepath1 = ""; break;
                case 2: nrd.nrm.Filepath2 = ""; break;
            }
            await NotificationService.ShowSuccess("File deleted successfully!");
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Delete failed: {response.StatusCode} - {error}");
        }
        StateHasChanged();
    }

    private async Task<string> SplitFileName(string filename)
    {
        try
        {
            string[] sp = filename.Split("_");
            return sp.Length > 2 ? sp[1] + "_" + sp[2] : filename;
        }
        catch { return filename; }
    }






    private async Task SaveResultsAsync()
    {
        // Ensure nrd and nrm are not null
        if (nrd == null || nrd.nrm == null)
        {
            errorMessage = "No result data to save. Please load data first.";
            return;
        }

        // Ensure SelectedBill and RequestGUID are set
        if (SelectedBill == null || SelectedBill.RequestGUID == Guid.Empty)
        {
            errorMessage = "No bill selected. Cannot save results.";
            return;
        }

        // Set the RequestGUID from SelectedBill
        nrd.nrm.RequestGUID = SelectedBill.RequestGUID;
        nrd.nrm.TCode = SelectedBill.TCode;

        // Ensure string properties are not null
        nrd.nrm.Interpretation = nrd.nrm.Interpretation ?? "";
        nrd.nrm.Method = nrd.nrm.Method ?? "";
        nrd.nrm.Comments = nrd.nrm.Comments ?? "";
        nrd.nrm.Disclaimer = nrd.nrm.Disclaimer ?? "";
        nrd.nrm.Filepath1 = nrd.nrm.Filepath1 ?? "";
        nrd.nrm.Filepath2 = nrd.nrm.Filepath2 ?? "";
        nrd.nrm.Filepath3 = nrd.nrm.Filepath3 ?? "";
        nrd.nrm.Abnormal = nrd.nrm.Abnormal ?? "";
        nrd.nrm.Normal = nrd.nrm.Normal ?? "";

        // Ensure all result details have MachineCode set (required by API)
        if (nrd.nrd != null && nrd.nrd.Count > 0)
        {
            foreach (var item in nrd.nrd)
            {
                item.MachineCode = item.MachineCode ?? "N/A";
            }
        }

        bool issaved = false;

        if (isauthorized == true)
        {
            if (nrd.nrm.AuthorizedBy == 0 || nrd.nrm.AuthorizedBy == user.UserCode)
            {
                issaved = true; nrd.nrm.AuthorizedBy = nrd.nrm.AuthorizedBy == 0 ? user.UserCode : nrd.nrm.AuthorizedBy;
            }
            else
            {
                issaved = false;
            }
        }

        if (isapproved == true)
        {
            if ((nrd.nrm.ApprovedBy == 0 || nrd.nrm.ApprovedBy == user.UserCode) && nrd.nrm.AuthorizedBy == 0)
            {
                issaved = true; nrd.nrm.ApprovedBy = nrd.nrm.ApprovedBy == 0 ? user.UserCode : nrd.nrm.ApprovedBy;
            }
            else if (isauthorized == false)
            {
                issaved = false;
            }
        }

        if (isentered == true)
        {
            if ((nrd.nrm.EnteredBy == 0 || nrd.nrm.EnteredBy == user.UserCode) && nrd.nrm.ApprovedBy == 0 && nrd.nrm.AuthorizedBy == 0)
            {
                issaved = true; nrd.nrm.EnteredBy = nrd.nrm.EnteredBy == 0 ? user.UserCode : nrd.nrm.EnteredBy;
            }
            else if (isapproved == false && isauthorized == false)
            {
                issaved = false;
            }
        }

        if (issaved == false)
        {
            errorMessage = "You do not have rights to save the record.";
            await NotificationService.ShowError("You do not have rights to save the record.");
            return;
        }
        else
        {
            try
            {
                var res = await Http.PostAsJsonAsync($"{appSettings.BaseUrl}Newborn/NewBornResultinsert", nrd);
                
                if (res.IsSuccessStatusCode)
                {
                    errorMessage = null;
                    await NotificationService.ShowSuccess("Result saved successfully!");
                    nrd = new NewBornResultData() { nrm = new NewBorn_Result_Master(), nrd = new List<Newborn_Result_Details>() };
                }
                else
                {
                    var responseContent = await res.Content.ReadAsStringAsync();
                    errorMessage = $"Error saving results: {res.StatusCode} - {responseContent}";
                    await NotificationService.ShowError(errorMessage);
                    Console.WriteLine($"Save Error - Status: {res.StatusCode}, Response: {responseContent}");
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error saving results: {ex.Message}";
                await NotificationService.ShowError(errorMessage);
                Console.WriteLine($"Save Exception: {ex}");
            }
        }
    }


    private string? errorMessage = null;


    public async Task LoadAsync()
    {
        var res = await Http.GetAsync($"{appSettings.BaseUrl}Newborn/NewBornGet?rid={(Convert.ToString(SelectedBill.RequestGUID))}");
        if(res.IsSuccessStatusCode)
        {
            nrd = await res.Content.ReadFromJsonAsync<NewBornResultData>() ?? new NewBornResultData();

            // Ensure nrd.nrd is initialized if null
            if (nrd.nrd == null)
            {
                nrd.nrd = new List<Newborn_Result_Details>();
            }

            // Ensure nrm is initialized if null
            if (nrd.nrm == null)
            {
                nrd.nrm = new NewBorn_Result_Master();
            }

            nrd.nrm.CollectedDateTime = nrd.nrm.CollectedDateTime == null ? DateTime.Now : nrd.nrm.CollectedDateTime;
            nrd.nrm.ReceivedDateTime = nrd.nrm.ReceivedDateTime == null ? DateTime.Now : nrd.nrm.ReceivedDateTime;
            nrd.nrm.ResultDateTime = nrd.nrm.ResultDateTime == null ? DateTime.Now : nrd.nrm.ResultDateTime;

            // Load assigned machine codes and populate table from master data
            if (SelectedBill.TCode != 0)
            {
                try
                {
                    var masterRes = await Http.GetAsync($"{appSettings.BaseUrl}Newborn/NewBornTestMaster?TCode={SelectedBill.TCode}");
                    if (masterRes.IsSuccessStatusCode)
                    {
                        var masterData = await masterRes.Content.ReadFromJsonAsync<NewBornMasterData>();
                        if (masterData?.ntd != null)
                        {
                            assignedMachineCodes = masterData.ntd.Where(x => !string.IsNullOrEmpty(x.MachineCode)).Select(x => x.MachineCode).ToList();
                            
                            // If nrd.nrd is empty or needs to be populated from master data
                            if (nrd.nrd == null || nrd.nrd.Count == 0)
                            {
                                nrd.nrd = new List<Newborn_Result_Details>();
                                // Populate table with master data
                                foreach (var masterDetail in masterData.ntd)
                                {
                                    nrd.nrd.Add(new Newborn_Result_Details
                                    {
                                        NBDetailsID = Guid.NewGuid(),
                                        NBID = nrd.nrm?.NBID ?? Guid.Empty,
                                        TCode = SelectedBill.TCode,
                                        SLNo = masterDetail.SLNo,
                                        TableTitle = masterDetail.TableTitle,
                                        Parameters = masterDetail.Parameters,
                                        Details = masterDetail.Details,
                                        Method = masterDetail.Method,
                                        ObserverValue = masterDetail.ObserverValue ?? "",
                                        MachineCode = masterDetail.MachineCode,
                                        RangeType = masterDetail.RangeType,
                                        RangeFrom = masterDetail.RangeFrom,
                                        RangeTo = masterDetail.RangeTo,
                                        ReferenceRange = masterDetail.ReferenceRange,
                                        Unit = masterDetail.Unit,
                                        Result = masterDetail.Result ?? "",
                                        GroupTitle = masterDetail.GroupTitle,
                                        Condition = masterDetail.Condition,
                                        RangeType1 = masterDetail.RangeType1,
                                        RangeFrom1 = masterDetail.RangeFrom1,
                                        RangeTo1 = masterDetail.RangeTo1,
                                        Abnormal = masterDetail.Abnormal,
                                        Normal = masterDetail.Normal
                                    });
                                }
                            }
                            else
                            {
                                // Filter existing data to only include rows with matching MachineCode or empty MachineCode
                                nrd.nrd = nrd.nrd.Where(x => string.IsNullOrEmpty(x.MachineCode) || assignedMachineCodes.Contains(x.MachineCode, StringComparer.OrdinalIgnoreCase)).ToList();
                            }
                        }
                    }
                }
                catch (Exception ex)
                {
                    // Log or handle the error - endpoint may not exist
                    Console.WriteLine($"Error loading NewBornTestMaster data: {ex.Message}");
                }
            }

        }else
        {
            var tt = res.Content.ReadAsStringAsync();
            var tt1 = tt;
        }
        StateHasChanged();
    }

    private bool isMachineResultDialogVisible = false;
    private List<MachineResultItem> machineResultsList = new();

    private async Task GetMachineResultsAsync()
    {
        errorMessage = null;
        if (SelectedBill == null || SelectedBill.RequestGUID == Guid.Empty)
        {
            errorMessage = "No bill selected for machine results.";
            return;
        }

        try
        {
            var url = $"{appSettings.BaseUrl}MachineInterface/GetResultbyid?rguid={SelectedBill.RequestGUID}";
            if (!Http.DefaultRequestHeaders.Contains("X-Tenant-ID"))
                Http.DefaultRequestHeaders.Add("X-Tenant-ID", appSettings.ClientId);
            var res = await Http.GetAsync(url);
            
            if (res.IsSuccessStatusCode)
            {
                machineResultsList = await res.Content.ReadFromJsonAsync<List<MachineResultItem>>() ?? new();
                // Filter machine results to only include those with assigned machine codes
                machineResultsList = machineResultsList.Where(x => assignedMachineCodes.Contains(x.ParameterName, StringComparer.OrdinalIgnoreCase)).ToList();
                
                if (machineResultsList != null && machineResultsList.Count > 0)
                {
                    isMachineResultDialogVisible = true;
                    StateHasChanged();
                }
                else
                {
                    errorMessage = "No machine results found for this request.";
                }
            }
            else
            {
                errorMessage = $"Failed to get machine results: {res.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error fetching machine results: {ex.Message}";
        }
    }

    private async Task AddMachineResultsToGrid()
    {
        if (machineResultsList != null && machineResultsList.Count > 0 && nrd?.nrd != null)
        {
            bool updated = false;
            foreach (var item in machineResultsList)
            {
                // Try matching MachineCode first
                var row = nrd.nrd.FirstOrDefault(x => string.Equals(x.MachineCode, item.ParameterName, StringComparison.OrdinalIgnoreCase));
                
                // Fallback to matching Parameters
                 if (row == null)
                {
                    row = nrd.nrd.FirstOrDefault(x => string.Equals(x.Parameters, item.ParameterName, StringComparison.OrdinalIgnoreCase));
                }

                if (row != null)
                {
                    // Machine code values should only be added to ObserverValue, not Result
                    row.ObserverValue = item.ParameterValue;
                    updated = true;
                }
            }
            
            if (updated)
            {
                 if(grd1 != null) await grd1.Refresh();
            }
        }
        isMachineResultDialogVisible = false;
        StateHasChanged();
    }

    private void ClearMachineResults()
    {
        machineResultsList.Clear();
        StateHasChanged();
    }

