    public async Task CellSaveHandlerAsync(CellSavedArgs<Newborn_Result_Details> args)
    {
        try
        {



            switch (args.Column.Field)
            {
                case "ObserverValue":
                    nrd.nrd.Where(x => x.NBDetailsID == args.Data.NBDetailsID).FirstOrDefault().ObserverValue = args.Value?.ToString() ?? "";
                    break;
                case "Result":
                    nrd.nrd.FirstOrDefault(x => x.NBDetailsID == args.Data.NBDetailsID).Result = args.Value?.ToString() ?? "";
                    break;
                case "Parameters":
                    nrd.nrd.FirstOrDefault(x => x.NBDetailsID == args.Data.NBDetailsID).Parameters = args.Value?.ToString() ?? "";
                    break;
                case "ReferenceRange":
                    nrd.nrd.FirstOrDefault(x => x.NBDetailsID == args.Data.NBDetailsID).ReferenceRange = args.Value?.ToString() ?? "";
                    break;
                case "Unit":
                    nrd.nrd.FirstOrDefault(x => x.NBDetailsID == args.Data.NBDetailsID).Unit = args.Value?.ToString() ?? "";
                    break;
                case "CutOff":
                    nrd.nrd.FirstOrDefault(x => x.NBDetailsID == args.Data.NBDetailsID).CutOff = double.TryParse(args.Value?.ToString(), out double cutoff) ? cutoff.ToString() : "0.0";
                    break;
                case "RiskValue":
                    nrd.nrd.FirstOrDefault(x => x.NBDetailsID == args.Data.NBDetailsID).RiskValue = double.TryParse(args.Value?.ToString(), out double riskValue) ? riskValue.ToString() : "0.0";
                    break;
                case "MachineCode":
                    nrd.nrd.FirstOrDefault(x => x.NBDetailsID == args.Data.NBDetailsID).MachineCode = args.Value?.ToString() ?? "";
                    break;
            }




        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving cell: {ex.Message}";

        }
    }



