@code {
    [Inject]
    private ExecutionClass? exe { get; set; }


    [Parameter]
    public NewBornRequest? SelectedBill { get; set; }


    // Local modal state for viewing table/row details
    private bool showDetailModal = false;
    private string selectedTableTitle = string.Empty;



    NewBornResultData nrd = new NewBornResultData() { nrm = new NewBorn_Result_Master(), nrd = new List<Newborn_Result_Details>() };

    private async Task ShowAbnormalClicked()
    {
        nrd.nrm.Interpretation = nrd.nrm.Abnormal ?? "";

    }

    private async Task ShowNormalClicked()
    {
        nrd.nrm.Interpretation = nrd.nrm.Normal ?? "";
    }

    private User_Master user = new User_Master();
    private IList<User_Master> usermaster = new List<User_Master>();
    string ent1 = "";
    string ent2 = "";
    string app1 = "";
    string app2 = "";
    string auth1 = "";
    string auth2 = "";

    bool isentered = false;
    bool isapproved = false;
    bool isauthorized = false;

    protected override async Task OnInitializedAsync()
    {

        if (!string.IsNullOrEmpty(appSettings?.ClientId) && !Http.DefaultRequestHeaders.Contains("X-Tenant-ID"))
            Http.DefaultRequestHeaders.Add("X-Tenant-ID", appSettings.ClientId);

    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            user = (await sessionStorage.GetAsync<User_Master>("UserDetails")).Value ?? new User_Master();
            var rights = (await sessionStorage.GetAsync<List<User_Rights>>("UserRights")).Value ?? new List<User_Rights>();
            isentered = rights.Where(x => x.Department == "Lab" && x.ModuleName == "Result Entry").Select(x =>x.ToAdd).FirstOrDefault();
            isapproved = rights.Where(x => x.Department == "Lab" && x.ModuleName == "Authorize Lab Results").Select(x =>x.ToAdd).FirstOrDefault();
            isauthorized = rights.Where(x => x.Department == "Lab" && x.ModuleName == "Authorize Lab Results 2").Select(x => x.ToAdd).FirstOrDefault();

            this.UserMasterAsync();

            StateHasChanged();
        }
    }


    protected override async Task OnParametersSetAsync()
    {
        await this.LoadAsync();
    }



    private async Task ReloadClicked()
    {
        try
        {
            Guid nbid = nrd.nrm.NBID == Guid.Empty ? Guid.NewGuid() : nrd.nrm.NBID;
            var res = await Http.GetAsync($"{appSettings.BaseUrl}Newborn/NewBornReload?rid={Uri.EscapeDataString(SelectedBill.RequestGUID.ToString())}");
            if (res.IsSuccessStatusCode)
            {
                nrd = await res.Content.ReadFromJsonAsync<NewBornResultData>() ?? new NewBornResultData();

                // Ensure nrd.nrd is initialized if null
                if (nrd.nrd == null)
                {
                    nrd.nrd = new List<Newborn_Result_Details>();
                }
                nrd.nrm.NBID = nbid;
                nrd.nrd.ToList().ForEach(x => x.NBID = nbid);

                nrd.nrm.CollectedDateTime = nrd.nrm.CollectedDateTime == null ? DateTime.Now : nrd.nrm.CollectedDateTime;
                nrd.nrm.ReceivedDateTime = nrd.nrm.ReceivedDateTime == null ? DateTime.Now : nrd.nrm.ReceivedDateTime;
                nrd.nrm.ResultDateTime = nrd.nrm.ResultDateTime == null ? DateTime.Now : nrd.nrm.ResultDateTime;

                // Load assigned machine codes and populate table from master data
                if (SelectedBill.TCode != 0)
                {
                    try
                    {
                        var masterRes = await Http.GetAsync($"{appSettings.BaseUrl}Newborn/NewBornTestMaster?TCode={SelectedBill.TCode}");
                        if (masterRes.IsSuccessStatusCode)
                        {
                            var masterData = await masterRes.Content.ReadFromJsonAsync<NewBornMasterData>();
                            if (masterData?.ntd != null)
                            {
                                assignedMachineCodes = masterData.ntd.Where(x => !string.IsNullOrEmpty(x.MachineCode)).Select(x => x.MachineCode).ToList();
                                
                                // If nrd.nrd is empty or needs to be populated from master data
                                if (nrd.nrd == null || nrd.nrd.Count == 0)
                                {
                                    nrd.nrd = new List<Newborn_Result_Details>();
                                    // Populate table with master data
                                    foreach (var masterDetail in masterData.ntd)
                                    {
                                        nrd.nrd.Add(new Newborn_Result_Details
                                        {
                                            NBDetailsID = Guid.NewGuid(),
                                            NBID = nbid,
                                            TCode = SelectedBill.TCode,
                                            SLNo = masterDetail.SLNo,
                                            TableTitle = masterDetail.TableTitle,
                                            Parameters = masterDetail.Parameters,
                                            Details = masterDetail.Details,
                                            Method = masterDetail.Method,
                                            ObserverValue = masterDetail.ObserverValue ?? "",
                                            MachineCode = masterDetail.MachineCode,
                                            RangeType = masterDetail.RangeType,
                                            RangeFrom = masterDetail.RangeFrom,
                                            RangeTo = masterDetail.RangeTo,
                                            ReferenceRange = masterDetail.ReferenceRange,
                                            Unit = masterDetail.Unit,
                                            Result = masterDetail.Result ?? "",
                                            GroupTitle = masterDetail.GroupTitle,
                                            Condition = masterDetail.Condition,
                                            RangeType1 = masterDetail.RangeType1,
                                            RangeFrom1 = masterDetail.RangeFrom1,
                                            RangeTo1 = masterDetail.RangeTo1,
                                            Abnormal = masterDetail.Abnormal,
                                            Normal = masterDetail.Normal
                                        });
                                    }
                                }
                                else
                                {
                                    // Filter existing data to only include rows with matching MachineCode or empty MachineCode
                                    nrd.nrd = nrd.nrd.Where(x => string.IsNullOrEmpty(x.MachineCode) || assignedMachineCodes.Contains(x.MachineCode, StringComparer.OrdinalIgnoreCase)).ToList();
                                }
                            }
                        }
                    }
                    catch (Exception ex)
                    {
                        // Log or handle the error - endpoint may not exist
                        Console.WriteLine($"Error loading NewBornTestMaster data on reload: {ex.Message}");
                    }
                }

                // Refresh the grid to display updated values
                if (grd1 != null)
                {
                    await grd1.Refresh();
                }
                await NotificationService.ShowSuccess("Data reloaded successfully!");
                errorMessage = null;
            }
            else
            {
                var tt = await res.Content.ReadAsStringAsync();
                errorMessage = $"Error reloading data: {tt}";
                await NotificationService.ShowError(errorMessage);
            }
            StateHasChanged();
        }catch(Exception ex)
        {
            errorMessage = $"Error reloading data: {ex.Message}";
        }
    }





    private SfGrid<Newborn_Result_Details> grd1;

    IList<string> assignedMachineCodes = new List<string>();

    private async Task OnCellEdit(CellEditArgs<Newborn_Result_Details> args)
    {

        StateHasChanged();
    }

    private async Task OnCellSelAsync(CellSelectEventArgs<Newborn_Result_Details> args)
    {
