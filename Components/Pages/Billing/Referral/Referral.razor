    private void SanitizeFormModel()
    {
        formModel.NameTitle ??= "";
        formModel.Name ??= "";
        formModel.Reference ??= "";
        formModel.Address ??= "";
        formModel.ICChequeName ??= "";
        formModel.Email ??= "";
        formModel.Website ??= "";
        formModel.City ??= "";
        formModel.ZipCode ??= "";
        formModel.State ??= "";
        formModel.Country ??= "";
        formModel.Phone ??= "";
        formModel.Mobile ??= "";
        formModel.ContactPerson ??= "";
        formModel.ICPayMode ??= "";
        formModel.AccountsMobileNo ??= "";
        formModel.Bedno ??= "";
        formModel.Password ??= "";
        formModel.Code ??= "";
        formModel.Narration ??= "";
        formModel.Fax ??= "";
        formModel.EntryType ??= "";
        formModel.SchemeRate ??= "";
        formModel.ResultMobile ??= "";
        formModel.OffersMobile ??= "";
        formModel.BillInfoMobile ??= "";
        formModel.SendSMSTo ??= "";
        formModel.MonthlyAccount ??= "";
        if (string.IsNullOrWhiteSpace(formModel.Area))
        {
            formModel.Area = Areas.FirstOrDefault(a => a.AreaCode == formModel.AreaCode)?.AreaName ?? "NotSpecified";
        }

        // DoctorFullName: build from title + name if missing
        if (string.IsNullOrWhiteSpace(formModel.DoctorFullName))
        {
            var parts = new List<string>();
            if (!string.IsNullOrWhiteSpace(formModel.NameTitle)) parts.Add(formModel.NameTitle);
            if (!string.IsNullOrWhiteSpace(formModel.Name)) parts.Add(formModel.Name);
            formModel.DoctorFullName = parts.Any() ? string.Join(" ", parts) : "NotSpecified";
        }

        // Standard codes and short names: provide safe defaults
        formModel.SkyCode ??= "NotSpecified";
        formModel.FaxStdCode ??= "0";
        formModel.PhoneStdCode ??= "0";
        formModel.SMSLabName ??= (AppSettings?.ClientId ?? "LIMS") as string ?? "LIMS";
        formModel.ImportReference ??= "0";

        // DoctorImage: prefer any newly selected photo (PhotoData). If no new photo
        // was provided, keep the existing DoctorImage when present; otherwise send
        // an empty array so the server receives a non-null value.
        if (PhotoData != null && PhotoData.Length > 0)
        {
            formModel.DoctorImage = PhotoData;
        }
        else if (formModel.DoctorImage == null || formModel.DoctorImage.Length == 0)
        {
            formModel.DoctorImage = Array.Empty<byte>();
        }

        if (formModel.EnteredDate == default)
        {
            formModel.EnteredDate = DateTime.Now;
        }
    }

    private async Task SaveData()
    {
        isSaving = true;
        SanitizeFormModel();

        if (!string.IsNullOrEmpty(AppSettings?.ClientId) && !http.DefaultRequestHeaders.Contains("X-Tenant-ID"))
        {
            http.DefaultRequestHeaders.Add("X-Tenant-ID", AppSettings.ClientId);
        }

        try
        {
            // Ensure IBSDate is a valid DateTime (server expects a DateTime value for 'ibsDate')
            // and ensure DeliveredMode is present (server validation requires 'dm').
            if (formModel.IBSDate == null || formModel.IBSDate == default)
            {
                // Set to now if not provided to avoid server conversion errors.
                formModel.IBSDate = DateTime.Now;
            }

            if (string.IsNullOrWhiteSpace(formModel.DeliveredMode))
            {
                // Provide a sensible default so server-side required validation for 'dm' passes.
                // If your API expects specific values here, adjust accordingly.
                formModel.DeliveredMode = "NotSpecified";
            }

            // Use Newtonsoft JObject to build a payload with the property names the server expects
            // (server error referenced 'dm' and 'ibsDate' in lowercase).
            var payload = JObject.FromObject(formModel);

            // Add lower-case aliases expected by the API
            payload["dm"] = payload["DeliveredMode"] ?? JValue.CreateString(formModel.DeliveredMode);
            // Ensure ibsDate is a DateTime token (not an empty string)
            payload["ibsDate"] = formModel.IBSDate.HasValue ? JToken.FromObject(formModel.IBSDate.Value) : JValue.CreateNull();

            // Include photo if provided (base64)
            if (PhotoData != null && PhotoData.Length > 0)
            {
                payload["photoBase64"] = Convert.ToBase64String(PhotoData);
                payload["photoContentType"] = PhotoPreview?.Split(':').Skip(1).FirstOrDefault()?.Split(';').FirstOrDefault() ?? "image/jpeg";
            }

            // UploadOnline flag
            payload["uploadOnline"] = UploadOnline;

            // Optionally remove the PascalCase properties to avoid duplicates (not strictly necessary)
            var dmProp = payload.Property("DeliveredMode");
            if (dmProp != null) dmProp.Remove();
            var ibsProp = payload.Property("IBSDate");
            if (ibsProp != null) ibsProp.Remove();

            var json = payload.ToString(Newtonsoft.Json.Formatting.None);
            var content = new StringContent(json, Encoding.UTF8, "application/json");
            var response = await http.PostAsync($"{(AppSettings?.BaseUrl ?? string.Empty)}referral/savereferral", content);

            if (response.IsSuccessStatusCode)
            {
                await ClearForm();
                await LoadReferralsFromApi();
                _ = Notifier.ShowSuccess("Referral saved successfully.");
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Save failed: {msg}");
                _ = Notifier.ShowError($"Failed to save: {msg}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception during save: {ex.Message}");
            _ = Notifier.ShowError($"An error occurred while saving: {ex.Message}");
        }

    isSaving = false;
        await InvokeAsync(StateHasChanged); 
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file != null)
            {
                if (file.Size > MaxPhotoFileSize)
                {
                    Console.WriteLine($"File size exceeds maximum allowed size of {MaxPhotoFileSize / 1024 / 1024} MB");
                    return;
                }

                using var stream = file.OpenReadStream(MaxPhotoFileSize);
                using var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);
                PhotoData = memoryStream.ToArray();

                // store metadata
                PhotoFileName = file.Name ?? string.Empty;
                PhotoContentType = file.ContentType ?? string.Empty;
                PhotoSize = file.Size;
                IsServerPhoto = false;
                ShowWebcam = false; // Close webcam if a file is uploaded

                var base64 = Convert.ToBase64String(PhotoData);
                PhotoPreview = $"data:{PhotoContentType};base64,{base64}";

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading photo: {ex.Message}");
        }
    }

