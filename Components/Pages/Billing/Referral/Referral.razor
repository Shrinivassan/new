    private async Task ToggleWebcam()
    {
        ShowWebcam = !ShowWebcam;
        // Ensure the component re-renders so the <video> and <canvas> elements exist
        await InvokeAsync(StateHasChanged);

        if (ShowWebcam)
        {
            // Small delay to allow browser layout to finish (video dimensions may be 0 otherwise)
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("limsWebcam.startWebcam", "webcamVideo", "webcamCanvas");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("limsWebcam.stopWebcam", "webcamVideo");
        }
        // final render
        await InvokeAsync(StateHasChanged);
    }

    private async Task CapturePhoto()
    {
        try
        {
            // Use a CancellationToken with a timeout to prevent long waits or TaskCanceledException on slow devices.
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            var base64Image = await JSRuntime.InvokeAsync<string>("limsWebcam.capturePhoto", cts.Token, "webcamVideo", "webcamCanvas");

            if (!string.IsNullOrEmpty(base64Image))
            {
                // Extract base64 data and content type
                var parts = base64Image.Split(',');
                if (parts.Length == 2)
                {
                    PhotoPreview = base64Image;
                    PhotoData = Convert.FromBase64String(parts[1]);
                    PhotoContentType = parts[0].Replace("data:", "").Replace(";base64", "");
                    PhotoFileName = $"webcam_capture_{DateTime.Now:yyyyMMddHHmmss}.jpg";
                    PhotoSize = PhotoData.LongLength;
                    IsServerPhoto = false;
                    ShowWebcam = false; // Close webcam after capturing
                    await JSRuntime.InvokeVoidAsync("limsWebcam.stopWebcam", "webcamVideo");
                    StateHasChanged();
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
            Console.WriteLine("Error capturing photo from webcam: The operation timed out.");
            if (Notifier != null)
            {
                await Notifier.ShowError("Could not capture photo from webcam. The operation timed out. Please try again.", "Webcam Timeout");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error capturing photo from webcam: {ex.Message}");
            if (Notifier != null)
            {
                await Notifier.ShowError($"An error occurred while capturing the photo: {ex.Message}", "Webcam Error");
            }
        }
    }

    private string GetDoctorImageUrl(byte[]? image)
    {
        if (image == null || image.Length == 0) return string.Empty;
        try
        {
            return $"data:image/jpeg;base64,{Convert.ToBase64String(image)}";
        }
        catch
        {
            return string.Empty;
        }
    }

    private string FormatFileSize(long bytes)
    {
        if (bytes <= 0) return "0 B";
        var units = new[] { "B", "KB", "MB", "GB", "TB" };
        int digitGroups = (int)(Math.Log10(bytes) / Math.Log10(1024));
        return $"{bytes / Math.Pow(1024, digitGroups):F2} {units[digitGroups]}";
    }

