    private async Task SaveQualification()
    {
        if (qualificationModel == null) return;

        // Simple in-memory add/update. API integration can be added later.
        if (qualificationModel.QualificationId == 0)
        {
            var nextId = qualificationList.Any() ? qualificationList.Max(q => q.QualificationId) + 1 : 1;
            qualificationModel.QualificationId = nextId;
            qualificationModel.EnteredDate = qualificationModel.EnteredDate == default ? DateTime.Now : qualificationModel.EnteredDate;
            qualificationModel.IBSDate = qualificationModel.IBSDate == default ? DateTime.Now : qualificationModel.IBSDate;
            qualificationList.Insert(0, qualificationModel);
        }
        else
        {
            var existing = qualificationList.FirstOrDefault(q => q.QualificationId == qualificationModel.QualificationId);
            if (existing != null)
            {
                existing.OrderNo = qualificationModel.OrderNo;
                existing.ShortName = qualificationModel.ShortName;
                existing.Name = qualificationModel.Name;
                existing.Description = qualificationModel.Description;
                existing.Deleted = qualificationModel.Deleted;
                existing.EnteredDate = qualificationModel.EnteredDate == default ? DateTime.Now : qualificationModel.EnteredDate;
                existing.IBSDate = qualificationModel.IBSDate == default ? DateTime.Now : qualificationModel.IBSDate;
            }
        }

        // Keep the main Qualifications list in sync for dropdowns
        Qualifications = new List<Qualification_Master>(qualificationList);

        // Notify user of success
        await Notifier.ShowSuccess("Qualification saved successfully!");

        // Reset the model for the next entry but keep the modal open
        qualificationModel = new Qualification_Master();
        await InvokeAsync(StateHasChanged);
    }

