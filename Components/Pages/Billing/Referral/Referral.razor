    private async Task ConfirmDelete()
    {
        if (DoctorToDelete == null) return;

        try
        {
            if (!string.IsNullOrEmpty(AppSettings?.ClientId) && !http.DefaultRequestHeaders.Contains("X-Tenant-ID"))
            {
                http.DefaultRequestHeaders.Add("X-Tenant-ID", AppSettings.ClientId);
            }

            var response = await http.DeleteAsync($"{(AppSettings?.BaseUrl ?? string.Empty)}referral/deletereferral/{DoctorToDelete.DCode}");
            
            if (response.IsSuccessStatusCode)
            {
                await LoadReferralsFromApi();
                _ = Notifier.ShowSuccess("Referral deleted successfully.");
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Delete failed: {msg}");
                _ = Notifier.ShowError($"Failed to delete: {msg}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception during delete: {ex.Message}");
            _ = Notifier.ShowError($"An error occurred while deleting: {ex.Message}");
        }
        finally
        {
            ShowDeleteModal = false;
            DoctorToDelete = null;
            await InvokeAsync(StateHasChanged);
        }
    }

