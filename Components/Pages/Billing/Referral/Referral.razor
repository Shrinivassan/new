    private async Task LoadReferralsFromApi()
    {
        try
        {
            if (!string.IsNullOrEmpty(AppSettings?.ClientId) && !http.DefaultRequestHeaders.Contains("X-Tenant-ID"))
            {
                http.DefaultRequestHeaders.Add("X-Tenant-ID", AppSettings.ClientId);
            }

            var requestUrl = $"{(AppSettings?.BaseUrl ?? string.Empty)}referral/referralmaster";
            var response = await http.GetAsync(requestUrl);
            if (!response.IsSuccessStatusCode) return;

            var content = await response.Content.ReadAsStringAsync();
            var root = JObject.Parse(content);

            // Parse doctor_Masters
            if (root.TryGetValue("doctor_Masters", StringComparison.OrdinalIgnoreCase, out var doctorToken) && doctorToken is JArray doctorArray)
            {
                allDoctors = doctorArray.ToObject<List<Doctor_Master>>(new JsonSerializer { NullValueHandling = NullValueHandling.Ignore }) ?? new List<Doctor_Master>();
                // Use the computed Title property on Doctor_Master to populate the title dropdown
                DoctorTitles = allDoctors.Select(d => d.Title).Where(t => !string.IsNullOrEmpty(t)).Distinct().ToList();
                
                var apiDoctorTypes = allDoctors.Select(d => d.EntryType).Where(t => !string.IsNullOrEmpty(t)).Distinct();
                DoctorTypes.AddRange(apiDoctorTypes.Except(DoctorTypes, StringComparer.OrdinalIgnoreCase));

                filteredReferrals = new List<Doctor_Master>(allDoctors);
            }

            

            // Parse feeType_Masters
            if (root.TryGetValue("feeType_Masters", StringComparison.OrdinalIgnoreCase, out var feeToken) && feeToken is JArray feeArray)
            {
                FeeTypes = feeArray.ToObject<List<FeeType_Master>>() ?? new List<FeeType_Master>();
            }

            // Parse area_Masters
            if (root.TryGetValue("area_Masters", StringComparison.OrdinalIgnoreCase, out var areaToken) && areaToken is JArray areaArray)
            {
                Areas = areaArray.ToObject<List<Area_Master>>() ?? new List<Area_Master>();
            }

            // Parse speciality_Masters
            if (root.TryGetValue("speciality_Masters", StringComparison.OrdinalIgnoreCase, out var specToken) && specToken is JArray specArray)
            {
                Specialities = specArray.ToObject<List<Speciality_Master>>() ?? new List<Speciality_Master>();
            }

            // Parse qualification_Masters
            if (root.TryGetValue("qualification_Masters", StringComparison.OrdinalIgnoreCase, out var qualToken) && qualToken is JArray qualArray)
            {
                Qualifications = qualArray.ToObject<List<Qualification_Master>>() ?? new List<Qualification_Master>();
                // Keep a local editable copy used by the Qualification Master modal/table
                qualificationList = new List<Qualification_Master>(Qualifications);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load referrals from API: {ex.Message}");
        }
    }

    private void FilterReferrals(ChangeEventArgs e)
    {
        var searchTerm = e.Value?.ToString() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredReferrals = new List<Doctor_Master>(allDoctors);
        }
        else
        {
            filteredReferrals = allDoctors.Where(r => r.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }
    
