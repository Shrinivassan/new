    private void EditReferral(Doctor_Master doctor)
    {
 
        if (doctor == null) return;
 
        // Create a deep copy of the doctor object to avoid modifying the original list directly
        formModel = JsonConvert.DeserializeObject<Doctor_Master>(JsonConvert.SerializeObject(doctor));
        
  
        // If the doctor record already contains an image, restore it so it isn't lost on save.
        if (doctor.DoctorImage != null && doctor.DoctorImage.Length > 0)
        {
            PhotoData = doctor.DoctorImage;
            try
            {
                var base64 = Convert.ToBase64String(doctor.DoctorImage);
                // Assume jpeg if server didn't provide a content type
                PhotoPreview = $"data:image/jpeg;base64,{base64}";
                PhotoFileName = $"Doctor_{doctor.DCode}.jpg";
                PhotoContentType = "image/jpeg";
                PhotoSize = doctor.DoctorImage.LongLength;
                ShowWebcam = false; // Close webcam if an existing photo is loaded
                IsServerPhoto = true;
            }
            catch
            {
                PhotoPreview = string.Empty;
            }
        }
        else
        {
            PhotoPreview = string.Empty;
            PhotoData = null;
            PhotoFileName = string.Empty;
            PhotoContentType = string.Empty;
            PhotoSize = 0;
            IsServerPhoto = false;
        }
 
        StateHasChanged();
    }

