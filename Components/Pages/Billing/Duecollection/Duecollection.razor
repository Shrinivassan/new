private async Task SaveReceipt()
{
    string successMessage = "";
    errorMessage = null;
    var selectedRows = billRows.Where(r => r.Selected).ToList();

    if (!selectedRows.Any())
    {
        errorMessage = "No bills selected to save.";
        StateHasChanged();
        return;
    }

    SanitizeReceiptModel();

    if (int.TryParse(receiptNoString, out var receiptSno))
    {
        Model.receipt_Master.ReceiptSNo = receiptSno;
    }

    // Pass UserCode; BHCode is not a property on Receipt_Master so include it in the payload when saving.
        if (!string.IsNullOrWhiteSpace(userCode) && int.TryParse(userCode, out var parsedUserCode))
        {
            Model.receipt_Master.UserCode = parsedUserCode;
        }
        else
        {
            Model.receipt_Master.UserCode = 0; // default value when UserCode is not available or invalid
        }

    // Compute total to send in payload without requiring a ReceiptAmount member on Receipt_Master
    var receiptAmount = (double)selectedRows.Sum(r => r.Collected);

    Model.receipt_Master.IsBill = SelectedReceiptType == "Bill";
    Model.receipt_Master.IsPatient = SelectedReceiptType == "Patient";
    Model.receipt_Master.IsRefferal = SelectedReceiptType == "Referral";
    Model.receipt_Master.IsMonthly = SelectedReceiptType == "Monthly";
    Model.receipt_Master.IsRefund = false;

    try
    {
        var consistentRequestGuid = string.IsNullOrWhiteSpace(Model.receipt_Master.ReceiptGUID)
            ? Guid.NewGuid().ToString()
            : Model.receipt_Master.ReceiptGUID;

        Model.receipt_Master.ReceiptGUID = consistentRequestGuid;

        // Build JSON payload manually so we can include the computed ReceiptAmount field
        var masterObj = JObject.FromObject(Model.receipt_Master);
        masterObj["ReceiptAmount"] = receiptAmount;
        // Inject BHCode into the payload because Receipt_Master class does not expose a BHCode property
        masterObj["BHCode"] = selectedBranchId;
        var detailsArray = JArray.FromObject(selectedRows.Select(row => new
        {
            RequestSno = row.Bill.RequestSno,
            RequestGUID = row.Bill.RequestGUID,
            Collected = (double)row.Collected,
            Concession = (double)row.Concession,
            ReceiptGUID = consistentRequestGuid,
            ReceiptSNo = Model.receipt_Master.ReceiptSNo
        }).ToList());

        var payloadObj = new JObject
        {
            ["receipt_Master"] = masterObj,
            ["receipt_Details"] = detailsArray
        };

        var payloadJson = payloadObj.ToString(Newtonsoft.Json.Formatting.Indented);
        errorMessage = $"Sending payload:\n{payloadJson}";

        if (!string.IsNullOrEmpty(appSettings?.ClientId) &&
            !http.DefaultRequestHeaders.Contains("X-Tenant-ID"))
        {
            http.DefaultRequestHeaders.Add("X-Tenant-ID", appSettings.ClientId);
        }

        var content = new StringContent(payloadJson, Encoding.UTF8, "application/json");

        var response = await http.PostAsync($"{appSettings.BaseUrl}DueCollection/save", content);

            if (response.IsSuccessStatusCode)
            {
                var successContent = await response.Content.ReadAsStringAsync();
                successMessage = $"Receipt saved successfully! Response: {successContent}\n\nPayload Sent:\n{payloadJson}";
                _ = NotificationService.ShowSuccess("Receipt saved successfully!");
                // Mark selected rows as collected and keep them in the grid so the
                // user can see the status change. Do not remove rows from the
                // table; switching to read-only display is handled in the UI.
                foreach (var row in selectedRows)
                {
                    if (row.Collected >= (decimal)row.Bill.Balance)
                    {
                        row.Status = "Collected";
                        row.Bill.Balance = 0; // Update local balance
                    }
                    // Clear selection after successful save
                    row.Selected = false;
                }
                // Keep receipt details cleared for next entry but preserve the
                // billRows so statuses remain visible.
                Model.receiptDetails.Clear();
                Model.receipt_Master.ReceiptSNo = 0;
                Model.receipt_Master.ReceiptGUID = string.Empty;
                receiptNoString = "";
                paidAmount = 0;
                RecalculateTotals();
                // Apply optimistic local updates (done above) and update UI now
                StateHasChanged();

                // Schedule a short delayed refresh to pick up the authoritative
                // state from the server. This avoids immediately overwriting
                // the optimistic UI change if the server takes a moment to
                // persist and propagate the update.
                _ = Task.Run(async () =>
                {
                    try
                    {
                        await Task.Delay(800);
                        await InvokeAsync(async () => await SearchDueBills());
                    }
                    catch { /* ignore background errors */ }
                });
            }
        else
        {
            var errorContent = await response.Content.ReadAsStringAsync();
            errorMessage = $"Save failed ({(int)response.StatusCode}): {errorContent}\n\nPayload Sent:\n{payloadJson}";
        }
    }
    catch (Exception ex)
    {
        errorMessage = $"An exception occurred: {ex.Message}";
    }

    if (!string.IsNullOrEmpty(successMessage))
    {
        errorMessage = successMessage; // Use errorMessage to display success message as well
    }

    StateHasChanged();
}


    private void SanitizeReceiptModel()
    {
        // The properties like Narration, ChequeNo etc. are on the DueCollectionModel (Model)
        // and not on the Receipt_Master. The ??= operator is for reference or nullable types.
        // Value types like int don't need null checks as they default to 0.

        Model.receipt_Master.CardNo = Model.receipt_Master.CardNo ?? "";
        Model.receipt_Master.ReceiptGUID = string.IsNullOrWhiteSpace(Model.receipt_Master.ReceiptGUID) ? Guid.NewGuid().ToString() : Model.receipt_Master.ReceiptGUID;
        Model.receipt_Master.BankName = Model.receipt_Master.BankName ?? "";
        Model.receipt_Master.ChequeNo = Model.receipt_Master.ChequeNo ?? "";
        Model.receipt_Master.Narration = Model.receipt_Master.Narration ?? "";
        Model.receipt_Master.PaymentReference = Model.receipt_Master.PaymentReference ?? "";
        Model.receipt_Master.ReceiptBarCode = Model.receipt_Master.ReceiptBarCode ?? "";
        Model.receipt_Master.CardDate = (Model.receipt_Master.CardDate == DateTime.MinValue) ? DateTime.Now : Model.receipt_Master.CardDate;
        Model.receipt_Master.ChequeDate = (Model.receipt_Master.ChequeDate == DateTime.MinValue) ? DateTime.Now : Model.receipt_Master.ChequeDate;
        Model.receipt_Master.IBSDate = (Model.receipt_Master.IBSDate == DateTime.MinValue) ? DateTime.Now : Model.receipt_Master.IBSDate;
        Model.receipt_Master.EnteredDate = (Model.receipt_Master.EnteredDate == DateTime.MinValue) ? DateTime.Now : Model.receipt_Master.EnteredDate;

        Model.receipt_Master.ReceiptCovertedBarCode = Model.receipt_Master.ReceiptCovertedBarCode ?? "";

        Model.receipt_Master.ReceiptTime = receiptTime.ToString("HH:mm");


    }




