        }
    }

    private async Task SearchPatients(string query)
    {
        // This method will be called by the debounced search
        if (string.IsNullOrWhiteSpace(query))
        {
            patientSearchResults.Clear();
            StateHasChanged();
            return;
        }

        try

        {
            var apiUrl = $"{appSettings.BaseUrl}request/PatientSearch?src={Uri.EscapeDataString(query)}";
            var request = new HttpRequestMessage(HttpMethod.Get, apiUrl);
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }
            var response = await http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var res = await response.Content.ReadAsStringAsync();
                patientSearchResults = JsonConvert.DeserializeObject<List<Customer_Master>>(res) ?? new();
            }
            else
            {
                patientSearchResults.Clear();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred while searching for patients: {ex.Message}";
            patientSearchResults.Clear();
        }
        StateHasChanged();
    }

    private async Task SelectPatient(Customer_Master patient)
    {
        PatientName = patient.Name;
        PatientMobile = patient.Mobile ?? "";
        // Clear search results and reset index
        patientSearchResults.Clear();
        selectedPatientIndex = -1;
        // Trigger search for due bills for the selected patient
        await DebounceSearch();
        StateHasChanged();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (referralResults.Any())
        {
            if (e.Key == "ArrowDown")
            {
                selectedReferralIndex = (selectedReferralIndex + 1) % referralResults.Count;
            }
            else if (e.Key == "ArrowUp")
            {
                selectedReferralIndex = (selectedReferralIndex - 1 + referralResults.Count) % referralResults.Count;
            }
            else if (e.Key == "Enter" && selectedReferralIndex >= 0)
            {
                await SelectReferralDoctor(referralResults[selectedReferralIndex]);
            }
            StateHasChanged();
        }
    }

    private async Task HandlePatientKeyDown(KeyboardEventArgs e)
    {
        if (patientSearchResults.Any())
        {
            if (e.Key == "ArrowDown")
            {
                selectedPatientIndex = (selectedPatientIndex + 1) % patientSearchResults.Count;
            }
            else if (e.Key == "ArrowUp")
            {
                selectedPatientIndex = (selectedPatientIndex - 1 + patientSearchResults.Count) % patientSearchResults.Count;
            }
            else if (e.Key == "Enter" && selectedPatientIndex >= 0)
            {
                await SelectPatient(patientSearchResults[selectedPatientIndex]);
            }
            // No need for Escape key handling, as clearing the input will clear results.
            StateHasChanged();
        }
    }

    private void AutoSelectBills()
    {
        if (paidAmount <= 0 || !billRows.Any())
        {
            return;
        }

        // Reset current selections and collected amounts
        foreach (var row in billRows)
        {
            row.Selected = false;
            row.Collected = 0;
        }

        var remainingAmountToCollect = paidAmount;

        // Process bills, oldest first, to clear dues chronologically
        foreach (var billRow in billRows.OrderBy(b => b.Bill.RequestDatetime))
        {
            if (remainingAmountToCollect <= 0) break;

            var amountToCollectForThisBill = Math.Min(remainingAmountToCollect, (decimal)billRow.Balance);

            billRow.Selected = true;
            billRow.Collected = amountToCollectForThisBill;
            remainingAmountToCollect -= amountToCollectForThisBill;
        }

        RecalculateTotals();
        StateHasChanged();
    }




