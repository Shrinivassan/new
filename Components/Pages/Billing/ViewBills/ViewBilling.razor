        var res = await http.SendAsync(request);
        //var res = exe.GetStatement(parameters, "Report/Bill").Result ?? "";
        if (res.IsSuccessStatusCode)
        {
            string res1 = res.Content.ReadAsStringAsync().Result;
            if (res1.Length > 200)
            {
                showreport = true;
                base64 = res1;
                base641 = $"data:application/pdf;base64,{base64}";
            }
        }
        else
        {
            var tt = res.Content.ReadAsStringAsync().Result;

        }
        OpenRowId = null;
       
        StateHasChanged();

