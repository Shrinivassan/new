    private void CalculateDiscount()
    {
        try
        {
            editBill.DiscountAmount = (editBill.RequestAmount * editBill.DiscountPer) / 100;
            editBill.TotalAmount = editBill.RequestAmount - editBill.DiscountAmount;
            CalculateBalance();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error calculating discount: {ex.Message}");
        }
    }

    private void CalculateFromDiscountAmount()
    {
        try
        {
            if (editBill.RequestAmount > 0)
            {
                editBill.DiscountPer = (editBill.DiscountAmount / editBill.RequestAmount) * 100;
                editBill.TotalAmount = editBill.RequestAmount - editBill.DiscountAmount;
                CalculateBalance();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error calculating from discount amount: {ex.Message}");
        }
    }

    private void CalculateBalance()
    {
        try
        {
            editBill.Balance = editBill.TotalAmount - editBill.PaidAmount;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error calculating balance: {ex.Message}");
        }
    }

    private async Task SaveBill()
    {
        try
        {
            isSaving = true;
            StateHasChanged();

            var existingBillIndex = viewbill.FindIndex(b => b.RequestSno == editBill.RequestSno);
            if (existingBillIndex >= 0)
            {
                viewbill[existingBillIndex] = editBill;
            }

            await FilterBills();
            _ = NotificationService.ShowSuccess("Bill saved successfully!");
            PrintMessage = "Bill saved successfully!";

            CancelEdit();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("console.error", $"Error saving bill: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", "Error occurred while saving the bill.");
        }
        finally
        {
            isSaving = false;
        }
    }
