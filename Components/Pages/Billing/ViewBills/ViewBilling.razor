    private Task DeleteBill(ViewBills args)
    {
        delete = args;
        billToDelete = FilteredBills?.FirstOrDefault(b => b.RequestGUID == args.RequestGUID);
        if (billToDelete != null)
        {
            confirmationMessage = $"Are you sure you want to delete bill for {billToDelete.Name} (SID: {billToDelete.RequestSno})?";
            showDeleteConfirmation = true;
            StateHasChanged();
        }
        OpenRowId = null;
        return Task.CompletedTask;
    }

    private async Task ConfirmDelete()
    {
        showDeleteConfirmation = false;

        try
        {
            if (billToDelete != null)
            {
                processingBillId = billToDelete.RequestSno.ToString();
                StateHasChanged();

                viewbill.RemoveAll(b => b.RequestSno == delete.RequestSno);
                FilteredBills.RemoveAll(b => b.RequestSno == delete.RequestSno);
                var request = new HttpRequestMessage(HttpMethod.Get,
       $"{AppSettings.BaseUrl}Request/CancelBill?rid={Uri.EscapeDataString(delete.RequestGUID)}");

                // Add the Authorization header
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

                // Send the request
                var res = await http.SendAsync(request);
                if (res.IsSuccessStatusCode)
                {
                    _ = NotificationService.ShowSuccess("Bill deleted successfully!");
                    PrintMessage = "Bill deleted successfully!";
                }
                else
                {
                    PrintMessage = $"Error deleting bill";
                }
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            PrintMessage = $"Error deleting bill: {ex.Message}";
        }
        finally
        {
            processingBillId = null;
            billToDelete = null;
            StateHasChanged();
        }
    }

