    // Add missing methods for referral search functionality
    private async Task OnReferralInputChanged(ChangeEventArgs e)
    {
        var searchTerm = e.Value?.ToString() ?? "";

        DoctorSearchTerm = searchTerm;

        referralDebounceTokenSource?.Cancel();
        referralDebounceTokenSource = new CancellationTokenSource();

        try
        {
            await Task.Delay(300, referralDebounceTokenSource.Token);
            await SearchReferralDoctors(searchTerm);
        }
        catch (TaskCanceledException)
        {
            // This is expected if the user types quickly.
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e, string type)
    {
        if (type == "ReferredBy" && referralResults.Any())
        {
            if (e.Key == "ArrowDown")
            {
                selectedReferralIndex = (selectedReferralIndex + 1) % referralResults.Count;
            }
            else if (e.Key == "ArrowUp")
            {
                selectedReferralIndex = (selectedReferralIndex - 1 + referralResults.Count) % referralResults.Count;
            }
            else if (e.Key == "Enter" && selectedReferralIndex >= 0)
            {
                SelectReferralDoctor(referralResults[selectedReferralIndex]);
            }
            StateHasChanged();
        }
    }

    private async Task SearchReferralDoctors(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            referralResults.Clear();
            selectedReferralIndex = -1;
            StateHasChanged();
            return;
        }

        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}request/ReferralSearch?src={Uri.EscapeDataString(query)}");
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }
            var response = await http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var res = await response.Content.ReadAsStringAsync();
                var doctors = JsonConvert.DeserializeObject<List<Doctor_Master>>(res) ?? new();
                referralResults = doctors;
            }
            else
            {
                referralResults.Clear();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error searching doctors: {ex.Message}");
            referralResults.Clear();
        }
        selectedReferralIndex = -1;
        StateHasChanged();
    }

    private void SelectReferralDoctor(Doctor_Master doctor)
    {

        DoctorSearchTerm = doctor.DoctorFullName;
        referralResults.Clear();
        selectedReferralIndex = -1;
    }

