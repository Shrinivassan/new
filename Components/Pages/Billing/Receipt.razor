@* @page "/receipt"
@rendermode InteractiveServer
@using Lims.Components.Pages.Billing
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage _sessionStorage
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

@if (isLoading)
{
    <div class="loading-container">
        <div class="loading-spinner"></div>
        <p class="loading-text">Loading bill details...</p>
    </div>
}
else if (bill != null)
{
    <!-- Language Switcher -->
    <div class="language-switcher d-print-none" style="margin-bottom: 15px; text-align: right;">
        <button class="btn btn-sm @(currentLanguage == "en" ? "btn-primary" : "btn-secondary")" @onclick='() => SetLanguage("en")'>English</button>
        <button class="btn btn-sm @(currentLanguage == "ta" ? "btn-primary" : "btn-secondary")" @onclick='() => SetLanguage("ta")'>தமிழ்</button>
        <button class="btn btn-sm @(currentLanguage == "hi" ? "btn-primary" : "btn-secondary")" @onclick='() => SetLanguage("hi")'>हिन्दी</button>
        <button class="btn btn-sm @(currentLanguage == "ml" ? "btn-primary" : "btn-secondary")" @onclick='() => SetLanguage("ml")'>മലയാളം</button>
        <button class="btn btn-sm @(currentLanguage == "te" ? "btn-primary" : "btn-secondary")" @onclick='() => SetLanguage("te")'>తెలుగు</button>
    </div>

<div class="print-actions d-print-none" 
     style="display: flex; justify-content: flex-end; gap: 12px; margin-bottom: 15px;">

    <button class="btn btn-print" @onclick="PrintReceipt" 
            style="background-color: #007bff; color: white; 
                   border: none; padding: 8px 16px; 
                   border-radius: 6px; cursor: pointer; 
                   display: flex; align-items: center; gap: 6px;">
        <i class="bi bi-printer"></i> Print Receipt
    </button>

    <button class="btn btn-back" @onclick="GoBack" 
            style="background-color: #6c757d; color: white; 
                   border: none; padding: 8px 16px; 
                   border-radius: 6px; cursor: pointer; 
                   display: flex; align-items: center; gap: 6px;">
        <i class="bi bi-arrow-left"></i> Back to Billing
    </button>
</div>

<!-- 🔹 Toggle Option -->
<div class="toggle-header-option d-print-none" 
     style="display: flex; justify-content: flex-end; align-items: center; 
            margin-top: 10px; font-size: 14px; gap: 6px;">

    <input type="checkbox" id="toggleHeader" @bind="showHeader" 
           style="width: 16px; height: 16px; cursor: pointer;" />
    <label for="toggleHeader" 
           style="cursor: pointer; font-weight: 500; color: #333;">
        @T("ShowHeader")
    </label>
</div>


    <div class="receipt-wrapper">
        <div class="receipt-container" id="receipt">

            <!-- 🔹 Header Section (optional) -->
            @if (showHeader)
            {
           <div class="receipt-header" 
     style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">

    <!-- 🔹 Left: Logo + Name -->
    <div class="lab-logo" 
         style="display: flex; flex-direction: column; align-items: flex-start;">
        <img src="https://img.freepik.com/premium-vector/health-care-medical-logo-vector-design_990473-2554.jpg"
             alt="Lab Logo" 
             style="width: 80px; height: 80px; object-fit: contain; border-radius: 10px; margin-bottom: 6px;" />

        <h2 class="lab-name" 
            style="font-size: 22px; font-weight: 600; color: #2c3e50; margin: 0;">
            lims Lab Center
        </h2>
    </div>

    <!-- 🔹 Right: Lab Info -->
    <div class="lab-info" 
         style="text-align: right; font-size: 14px; color: #444;">
        <p style="margin: 0;">123 Medical Street, Health District</p>
        <p style="margin: 0;">Chennai, Tamil Nadu - 600001</p>
        <div style="margin-top: 4px;">
            <span style="display: block;">📞 +91 98765 43210</span>
            <span style="display: block;">📧 info@limslab.com</span>
        </div>
    </div>
</div>

            }
            
       

            <!-- Bill Details Section -->
            <div class="bill-info-section">
                <div class="bill-header-row">
                    <div class="bill-number">
                        <span class="label">@T("InvoiceNo")</span>
                        <span class="value">#@bill.RequestSno</span>
                    </div>
                    <div class="bill-date">
                        <span class="label">@T("Date")</span>
                        <span class="value">@bill.RequestDatetime.ToString("dd MMM yyyy")</span>
                    </div>
                </div>

                <div class="patient-info-card">
                    <h4 class="card-title">Patient Information</h4>
                    <div class="patient-details">
                        <div class="detail-row">
                            <span class="detail-label">@T("PatientID")</span>
                            <span class="detail-value">@bill.CUSTCode</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">@T("Name")</span>
                            <span class="detail-value">@bill.Name</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">@T("Mobile")</span>
                            <span class="detail-value">@(bill.Mobile ?? T("NotProvided"))</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">@T("ReferredBy")</span>
                            <span class="detail-value">@(bill.DOCTOR ?? T("Self"))</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tests Section -->
            <div class="tests-section">
                <h4 class="section-title">@T("LaboratoryTests")</h4>
                <div class="tests-table-container">
                    <table class="tests-table">
                        <thead>
                            <tr>
                                <th class="sl-no">@T("SNo")</th>
                                <th class="test-name">@T("TestName")</th>
                                <th class="amount">@T("Amount")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (addedTests != null && addedTests.Any())
                            {
                                var index = 1;
                                foreach (var test in addedTests)
                                {
                                    <tr class="test-row">
                                        <td class="sl-no">@(index++)</td>
                                        <td class="test-name">@(test.Name ?? "Unknown Test")</td>
                                        <td class="amount">@test.Amount.ToString("N2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="no-tests">@T("NoTestsFound")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Payment Summary -->
            <div class="payment-summary">
                <div class="summary-row">
                    <span class="summary-label">@T("GrossAmount")</span>
                    <span class="summary-value">₹ @bill.RequestAmount.ToString("N2")</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">@T("Discount")</span>
                    <span class="summary-value discount">- ₹ @bill.DiscountAmount.ToString("N2")</span>
                </div>
                <div class="summary-divider"></div>
                <div class="summary-row total-row">
                    <span class="summary-label">@T("NetAmount")</span>
                    <span class="summary-value">₹ @bill.TotalAmount.ToString("N2")</span>
                </div>
                <div class="summary-row paid-row">
                    <span class="summary-label">@T("PaidAmount")</span>
                    <span class="summary-value">₹ @bill.PaidAmount.ToString("N2")</span>
                </div>
                @if (bill.Balance > 0)
                {
                    <div class="summary-row balance-row">
                        <span class="summary-label">@T("BalanceDue")</span>
                        <span class="summary-value balance">₹ @bill.Balance.ToString("N2")</span>
                    </div>
                }
                else
                {
                    <div class="payment-status paid-status">
                        ✓ @T("FullyPaid")
                    </div>
                }
            </div>

      

            <!-- Footer -->
            <div class="receipt-footer">
                <div class="thank-you">
                    <p>@T("ThankYou")</p>
                    <p class="sub-text">@T("GetWellSoon")</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="no-bill-container">
        <div class="no-bill-icon">📋</div>
        <h3>@T("NoBillDataFound")</h3>
        <p>@T("NoBillDetailsFound")</p>
        <button class="btn btn-primary" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i> @T("GoToBilling")
        </button>
    </div>
}

