    private string T(string key) => translations.TryGetValue(key, out var value) ? value : key;

    private void SetLanguage(string lang)
    {
        currentLanguage = lang;
        translations = lang switch
        {
            "ta" => ta,
            "hi" => hi,
            "ml" => ml,
            "te" => te,
            _ => en,
        };
    }
    // --- Localization End ---

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            SetLanguage("en"); // Set default language
            try
            {
                var billResult = await _sessionStorage.GetAsync<Billing.ViewBills>("newBill");
                if (billResult.Success && billResult.Value != null)
                {
                    bill = billResult.Value;
                }

                var testsResult = await _sessionStorage.GetAsync<List<Billing.TestItem>>("addedTestsForReceipt");
                if (testsResult.Success && testsResult.Value != null)
                {
                    addedTests = testsResult.Value;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading receipt data: {ex.Message}");
            }
            finally
            {
                isLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task PrintReceipt()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("window.print");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error printing receipt: {ex.Message}");
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/billing");
    }
} *@