    private async Task OnPatientInputChanged(ChangeEventArgs e)
    {
        patientName = e.Value?.ToString() ?? "";
        selectedPatientIndex = -1;

        patientDebounceTokenSource?.Cancel();
        patientDebounceTokenSource = new CancellationTokenSource();

        try
        {
            await Task.Delay(300, patientDebounceTokenSource.Token);
            await SearchPatients(patientName);
        }
        catch (TaskCanceledException)
        {
            // This is expected if the user types quickly.
        }
    }

    private async Task HandlePatientKeyDown(KeyboardEventArgs e)
    {
        if (patientSearchResults.Any())
        {
            if (e.Key == "ArrowDown")
            {
                selectedPatientIndex = (selectedPatientIndex + 1) % patientSearchResults.Count;
            }
            else if (e.Key == "ArrowUp")
            {
                selectedPatientIndex = (selectedPatientIndex - 1 + patientSearchResults.Count) % patientSearchResults.Count;
            }
            else if (e.Key == "Enter" && selectedPatientIndex >= 0)
            {
                await SelectPatient(patientSearchResults[selectedPatientIndex]);
            }
            else if (e.Key == "Escape")
            {
                patientSearchResults.Clear();
                selectedPatientIndex = -1;
            }
        }
    }

    private async Task SearchPatients(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            patientSearchResults.Clear();
            StateHasChanged();
            return;
        }

        var combinedResults = new List<Customer_Master>();

        try
        {
            // 1) Fetch from primary API endpoint
            var apiUrl = $"{appSettings.BaseUrl}request/PatientSearch?src={Uri.EscapeDataString(query)}";
            var request = new HttpRequestMessage(HttpMethod.Get, apiUrl);
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }
            var response = await http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var res = await response.Content.ReadAsStringAsync();
                var apiResults = JsonConvert.DeserializeObject<List<Customer_Master>>(res) ?? new();
                if (apiResults.Any())
                {
                    combinedResults.AddRange(apiResults);
                }
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("console.error", $"API patient search for '{query}' failed: {ex.Message}");
        }

        try
        {
            // 2) Fetch from ViewBills endpoint for a comprehensive search across all bills
            // Provide DCode (branch) and a date range when calling ViewBills to match API expectations
            string sd = DateTime.Now.ToString("yyyy-MM-dd") + " 12:00:00 AM";
            string ed = DateTime.Now.ToString("yyyy-MM-dd") + " 11:59:59 PM";
            var billsUrl = $"{appSettings.BaseUrl}request/ViewBills?DCode=0&fromdate={Uri.EscapeDataString(sd)}&todate={Uri.EscapeDataString(ed)}";
            var billsRequest = new HttpRequestMessage(HttpMethod.Get, billsUrl);
            if (!string.IsNullOrEmpty(token))
            {
                billsRequest.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }
            var billsResponse = await http.SendAsync(billsRequest);

            if (billsResponse.IsSuccessStatusCode)
            {
                var bills = await billsResponse.Content.ReadFromJsonAsync<List<Lims.Components.Model.ViewBills>>() ?? new();
                var matches = bills
                    .Where(b => (b.Name?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false) ||
                                (b.Mobile?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false) ||
                                (b.CUSTCode?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false))
                    .Select(b => new Customer_Master
                    {
                        Name = b.Name,
                        Mobile = b.Mobile,
                        CUSTCode = b.CUSTCode,
                        CUSTID = 0 // Mark as partial record
                    })
                    .ToList();

                // Deduplicate and merge
                foreach (var match in matches)
                {
                    if (!combinedResults.Any(p => p.CUSTCode == match.CUSTCode && !string.IsNullOrEmpty(match.CUSTCode)))
                    {
                        combinedResults.Add(match);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("console.error", $"Error fetching or filtering from ViewBills: {ex.Message}");
        }

        try
        {
            // 3) Fallback to session storage if API fails or returns no results
            try
            {
                var billsResult = await _sessionStorage.GetAsync<List<Lims.Components.Model.ViewBills>>("localBills");
                if (billsResult.Success && billsResult.Value != null && billsResult.Value.Any())
                {
                    var matchesQuery = query ?? string.Empty;
                    var matches = billsResult.Value
                        .Where(b =>
                                   (b.Name?.IndexOf(matchesQuery, StringComparison.OrdinalIgnoreCase) ?? -1) >= 0 ||
                                   (b.Mobile?.IndexOf(matchesQuery, StringComparison.OrdinalIgnoreCase) ?? -1) >= 0 ||
                                   (b.CUSTCode?.IndexOf(matchesQuery, StringComparison.OrdinalIgnoreCase) ?? -1) >= 0
                               )
                        .Take(20)
                        .Select(b => new Customer_Master // This creates a partial object
                        {
                            Name = b.Name,
                            Mobile = b.Mobile,
                            // Map minimal fields; other details can be filled after selecting from full API if needed
                            CUSTCode = b.CUSTCode
                        })
                        .ToList();

                    // Deduplicate and merge
                    foreach (var match in matches)
                    {
                        if (!combinedResults.Any(p => p.CUSTCode == match.CUSTCode && !string.IsNullOrEmpty(match.CUSTCode)))
                        {
                            combinedResults.Add(match);
                        }
                    }
                }
            }
            catch (Exception ex) { await JSRuntime.InvokeVoidAsync("console.error", $"Error reading/filtering 'localBills' from session: {ex.Message}"); }

            patientSearchResults = combinedResults.DistinctBy(p => !string.IsNullOrEmpty(p.CUSTCode) ? p.CUSTCode : $"{p.Name}-{p.Mobile}").Take(20).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error searching patients: {ex.Message}";
            patientSearchResults.Clear();
        }
        StateHasChanged();
    }

    private async Task SelectPatient(Customer_Master patient)
    {
        // If the selected patient object is partial (likely from session cache),
        // fetch the full details from the API using either CUSTID or CUSTCode.
        if (patient.CUSTID == 0 || string.IsNullOrEmpty(patient.Street))
        {
            try
            {
                var searchQuery = patient.CUSTID != 0 ? patient.CUSTID.ToString() : patient.CUSTCode;
                var url = $"{appSettings.BaseUrl}request/PatientSearch?src={Uri.EscapeDataString(searchQuery ?? "")}";
                var request = new HttpRequestMessage(HttpMethod.Get, url);
                if (!string.IsNullOrEmpty(token))
                {
                    request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
                }
                var response = await http.SendAsync(request);
                if (response.IsSuccessStatusCode)
                {
                    var fullPatientList = await response.Content.ReadFromJsonAsync<List<Customer_Master>>();
                    var foundPatient = fullPatientList?.FirstOrDefault(p => (patient.CUSTID != 0 && p.CUSTID == patient.CUSTID) || (!string.IsNullOrEmpty(patient.CUSTCode) && p.CUSTCode == patient.CUSTCode));

                    patient = foundPatient ?? patient; // Use the full record if found
                }
            }
            catch (Exception ex) { errorMessage = $"Could not fetch full patient details: {ex.Message}"; }
        }

        patientName = patient.Name;
        dateOfBirth = patient.DateOfBirth;

        // Build address string, handling null or empty parts gracefully
        var addressParts = new[] { patient.Street, patient.Area, patient.City, patient.Zipcode }.Where(s => !string.IsNullOrWhiteSpace(s));
        patientAddress = string.Join(", ", addressParts);
        if (addressParts.Count() > 2 && !string.IsNullOrWhiteSpace(patient.Zipcode))
        {
            // A slightly cleaner format if we have enough parts
            patientAddress = $"{string.Join(", ", addressParts.Take(addressParts.Count() - 1))} - {patient.Zipcode}";
        }

        patientMobile = patient.Mobile;
        patientEmail = patient.Email;

        // Persist selected patient into the request model so it can be submitted
        requestForm.CustID = patient.CUSTID;

        patientSearchResults.Clear();
        selectedPatientIndex = -1;
        StateHasChanged();
    }

