    private async Task SearchPhysiciansAsync(string query)
    {
        if (string.IsNullOrWhiteSpace(query) || query.Length < 2)
        {
            physicianSearchResults.Clear();
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            var url = $"{appSettings.BaseUrl}request/ReferralSearch?src={Uri.EscapeDataString(query)}";
            var request = new HttpRequestMessage(HttpMethod.Get, url);
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }
            var response = await http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var res = await response.Content.ReadAsStringAsync();
                physicianSearchResults = JsonConvert.DeserializeObject<List<Doctor_Master>>(res) ?? new();
            }
            else
            {
                physicianSearchResults.Clear();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error searching physicians: {ex.Message}";
            physicianSearchResults.Clear();
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task SelectPhysician(Doctor_Master physician)
    {
        physicianName = physician.DoctorFullName;
        hospital = physician.Reference;

        // Assuming Doctor_Master has Address, Area, and City properties like Customer_Master.
        // You might need to adjust this based on the actual properties of Doctor_Master.
        physicianAddress = $"{physician.Address}, {physician.Area}, {physician.City} - {physician.ZipCode}";
        physicianMobile = physician.Mobile;
        physicianEmail = physician.Email;

        // Persist selected physician's DCode into the request model.
        @* requestForm.DoctorCode = physician.DCode; *@

        // Clear search results.
        physicianSearchResults.Clear();
        selectedPhysicianIndex = -1;

        await InvokeAsync(StateHasChanged);
    }

