                }
                else { <p style="text-align:center;color:var(--text-muted);margin:16px 0;">No details available</p> }
            </div>
            <div class="details-card-footer" style="padding:10px 16px;border-top:1px solid var(--border-table);text-align:right;background:var(--bg-card);">
                <button class="btn btn-primary btn-sm" @onclick="() => showDetailsModal = false" style="background:var(--brand-accent);border:none;padding:6px 20px;font-weight:600;color:#fff;border-radius:6px;">OK</button>
            </div>
        </div>
    </div>
}

@code{


