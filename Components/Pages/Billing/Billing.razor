        // if (billnomaster.Count==0)
        // {
        //     counters = counters.Where(x=>x.Deleted==false).ToList();
        //     billnomaster = billnomaster1.Where(x => (x.IsSampleNo == true) && (x.AllBranch ||
        //                     (x.BHCode > 0 && x.CNTCode == 0 && x.BHCode == tt) ||
        //                     (x.BHCode > 0 && x.CNTCode > 0 && x.BHCode == tt && x.CNTCode == counters[0].CNTCode))).ToList();
        // }

        lrm.EnteredBHCode = tt;
        lrm.AlteredBHCode = tt;
        // Set defaults so the UI & subsequent calls know which counter and billno to use
        if (counters.Any())
