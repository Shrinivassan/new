    private async Task UpdateSID(string billdate, int bhcode, int cntcode, int bncode)
    {
        if (billingModel == null || lrm==null)
        {
            return;
        }

        var request = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}request/SampleNo?billdate={Uri.EscapeDataString(billdate)}&bhcode={bhcode}&cntcode={cntcode}&bncode={bncode}");
        if (!string.IsNullOrEmpty(token))
        {
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
        var response = await http.SendAsync(request);

        if (response.IsSuccessStatusCode)
        {
            var tt = await response.Content.ReadAsStringAsync() ?? "0";
            lrm.RequestSno = Convert.ToInt32(tt);
            billingModel.CaseNo = tt.Replace("\"", "");
            // Save last server SID into session so we can continue sequence if API is used
            try
            {
                var key = GetLocalSidKey(bhcode, cntcode, bncode);
                int val = lrm.RequestSno;
                await _sessionStorage.SetAsync(key, val);
            }
            catch { }
            await InvokeAsync(StateHasChanged);
        }
        else
        {
            // API failed or not available — fallback to a local sequential SID
            try
            {
                var next = await GetNextLocalSID(bhcode, cntcode, bncode);
                lrm.RequestSno = next;
                billingModel.CaseNo = next.ToString();
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error generating local SID fallback: {ex.Message}");
            }
        }
    }

