    private async Task HandlePrintConfirmationYes()
    {
        showPrintConfirmation = false;
        StateHasChanged();

        try
        {
            string reportGUID = lrm.RequestGUID ?? "";
            Console.WriteLine($"[PrintBill] lrm.RequestGUID={reportGUID}");

            if (string.IsNullOrWhiteSpace(reportGUID))
            {
                errorMessage = "Cannot print: RequestGUID is empty.";
                StateHasChanged();
                return;
            }

            // Step 1: Fetch today's bills from ViewBills API to confirm bill is in DB
            // This is exactly how ViewBilling verifies a bill before printing
            try
            {
                string sd = DateTime.Now.ToString("yyyy-MM-dd") + " 12:00:00 AM";
                string ed = DateTime.Now.ToString("yyyy-MM-dd") + " 11:59:59 PM";
                var listReq = new HttpRequestMessage(HttpMethod.Get,
                    $"{appSettings.BaseUrl}request/ViewBills?DCode=0&fromdate={Uri.EscapeDataString(sd)}&todate={Uri.EscapeDataString(ed)}");
                listReq.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var listResp = await http.SendAsync(listReq);
                if (listResp.IsSuccessStatusCode)
                {
                    var listContent = await listResp.Content.ReadAsStringAsync();
                    var savedBills = JsonConvert.DeserializeObject<List<Lims.Components.Model.ViewBills>>(listContent);
                    var myBill = savedBills?.FirstOrDefault(b =>
                        string.Equals(b.RequestGUID, reportGUID, StringComparison.OrdinalIgnoreCase));
                    if (myBill != null)
                    {
                        // Bill confirmed in DB - use the GUID from DB record
                        reportGUID = myBill.RequestGUID;
                        Console.WriteLine($"[PrintBill] Bill confirmed in DB: SID={myBill.RequestSno}, Name={myBill.Name}, GUID={reportGUID}");
                    }
                    else
                    {
                        Console.WriteLine($"[PrintBill] Bill NOT found in ViewBills list yet - proceeding with lrm.RequestGUID");
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[PrintBill] ViewBills fetch failed (non-critical): {ex.Message}");
            }

            // Step 2: Call Report/Bill - EXACTLY like ViewBilling PrintBill
            var parameters = new RoutineReportDto();
            parameters.ClientID   = appSettings.ClientId;
            parameters.DataSource = "DataSet1";
            parameters.ReportName = "Billing_Protrait.rdlc";
            parameters.RequestGUID = reportGUID;
            parameters.TCode = "0";
            parameters.Parameters = new List<ReportParameterDto>()
            {
                new ReportParameterDto() { Name = "TCode",        Values = new List<string>() { "0" } },
                new ReportParameterDto() { Name = "IsLetterHead", Values = new List<string>() { "false" } }
            };

            http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var res = await http.PostAsJsonAsync($"{appSettings.BaseUrl}Report/Bill", parameters);
            Console.WriteLine($"[PrintBill] Report/Bill status={res.StatusCode}");

            if (res.IsSuccessStatusCode)
            {
                string res1 = await res.Content.ReadAsStringAsync();
                Console.WriteLine($"[PrintBill] Report length={res1.Length}");
                if (res1.Length > 200)
                {
                    base64 = res1;
                    isreport = true;
                    StateHasChanged();
                }
                else
                {
                    errorMessage = $"Report has no data (length={res1.Length}). Bill may not be fully saved.";
                    StateHasChanged();
                }
            }
            else
            {
                var err = await res.Content.ReadAsStringAsync();
                Console.WriteLine($"[PrintBill] Report/Bill error: {err}");
                errorMessage = $"Report failed ({(int)res.StatusCode}): {err}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PrintBill] Exception: {ex.Message}");
            errorMessage = $"Error generating report: {ex.Message}";
            StateHasChanged();
        }
    }




    private void OnMobileInput(ChangeEventArgs e)
    {
        var input = e.Value?.ToString() ?? "";
        customer.Mobile = input;
        
        mobileDebounceTimer?.Stop();
        mobileDebounceTimer?.Dispose();
        
        if (string.IsNullOrWhiteSpace(input) || input.Length < 3)
        {
            showMobileDropdown = false;
            mobileSearchResults.Clear();
            return;
        }

        mobileDebounceTimer = new System.Timers.Timer(500);
        mobileDebounceTimer.AutoReset = false;
        mobileDebounceTimer.Elapsed += async (sender, args) =>
        {
            await InvokeAsync(() => SearchPatientByMobile(input));
        };
        mobileDebounceTimer.Start();
    }

    private async Task SearchPatientByMobile(string mobile)
    {
        try
        {
            string sd = DateTime.Now.AddYears(-2).ToString("yyyy-MM-dd") + " 12:00:00 AM";
            string ed = DateTime.Now.ToString("yyyy-MM-dd") + " 11:59:59 PM";
            int branchID = 0; 

            var request = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}request/ViewBills?DCode={branchID}&fromdate={Uri.EscapeDataString(sd)}&todate={Uri.EscapeDataString(ed)}");
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }

            var response = await http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                var bills = JsonConvert.DeserializeObject<List<Lims.Components.Model.ViewBills>>(content);
                
                if (bills != null)
                {
                    mobileSearchResults = bills
                        .Where(b => !string.IsNullOrEmpty(b.Mobile) && b.Mobile.Contains(mobile))
                        .GroupBy(b => b.CUSTCode)
                        .Select(g => g.First())
                        .Take(10)
                        .ToList();
                        
                    showMobileDropdown = mobileSearchResults.Any();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error searching by mobile: {ex.Message}");
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task SelectPatientFromMobile(Lims.Components.Model.ViewBills bill)
    {  
        showMobileDropdown = false;
        bool fullDetailsLoaded = false;

        if (!string.IsNullOrEmpty(bill.CUSTCode))
        {
             try 
             {
                 var request = new HttpRequestMessage(HttpMethod.Get, $"{AppSettings.BaseUrl}request/PatientSearch?src={Uri.EscapeDataString(bill.CUSTCode)}");
                 if (!string.IsNullOrEmpty(token))
                 {
                     request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
                 }
                 var response = await http.SendAsync(request);
                 if (response.IsSuccessStatusCode)
                 {
                     var res = await response.Content.ReadAsStringAsync();
                     var patients = JsonConvert.DeserializeObject<List<Customer_Master>>(res);
                     var patient = patients?.FirstOrDefault(p => p.CUSTCode == bill.CUSTCode);
                     if (patient != null)
                     {
                         SelectPatient(patient);
                         fullDetailsLoaded = true;
                     }
                 }
             }
             catch(Exception ex)
             {
                Console.WriteLine(ex.Message);
             }
        }

        if (!fullDetailsLoaded)
        {
            customer.Name = bill.Name;
            customer.Mobile = bill.Mobile;
            customer.CUSTCode = bill.CUSTCode;
            customer.Gender = bill.Gender;
            if (int.TryParse(bill.AgeYears, out int y)) customer.AgeYears = y;
            if (int.TryParse(bill.AgeMonths, out int m)) customer.AgeMonths = m;
            if (int.TryParse(bill.AgeDays, out int d)) customer.AgeDays = d;
            
            billingModel.PatientName = bill.Name;
            billingModel.MobileNo = bill.Mobile;
            billingModel.PatientId = bill.CUSTCode;
            billingModel.Gender = bill.Gender;
            billingModel.AgeYears = customer.AgeYears;
            billingModel.AgeMonths = customer.AgeMonths;
            billingModel.AgeDays = customer.AgeDays;

            // If ages are present, compute an approximate DOB and populate it
            var computedDob = ComputeDOBFromAge(customer.AgeYears, customer.AgeMonths, customer.AgeDays);
            if (computedDob.HasValue)
            {
                customer.DateOfBirth = computedDob.Value;
                billingModel.DateOfBirth = computedDob.Value;
                // Recalculate ages to keep fields consistent
                CalculateAgeFromDOB(customer.DateOfBirth);
            }
        }
        
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Validates the Bill Request payload structure to ensure all required fields are properly populated.
    /// Returns error message if validation fails, null if validation passes.
    /// </summary>
    private string ValidateBillPayload(BillRequest payload)
    {
        if (payload == null)
        {
            return "Payload is null";
        }

        // Validate Request_Master
        if (payload.Request_Master == null)
        {
            return "Request_Master is null";
        }

        if (string.IsNullOrWhiteSpace(payload.Request_Master.RequestGUID))
        {
            return "Request_Master.RequestGUID is empty or null";
        }

        if (string.IsNullOrWhiteSpace(payload.Request_Master.RequestSnoPrint))
        {
            return "Request_Master.RequestSnoPrint is empty or null (required for printing)";
        }

        if (payload.Request_Master.RequestSno <= 0)
        {
            return "Request_Master.RequestSno is invalid (must be greater than 0)";
        }

        // Validate Customer - Critical fields
        if (payload.customer == null)
        {
            return "Customer is null";
        }

        if (string.IsNullOrWhiteSpace(payload.customer.CUSTCode))
        {
            return "Customer.CUSTCode is empty or null";
        }

        if (string.IsNullOrWhiteSpace(payload.customer.Name))
        {
            return "Customer.Name is empty or null";
        }

        // Customer should have at least basic info
        if (string.IsNullOrWhiteSpace(payload.customer.Gender))
        {
            return "Customer.Gender is empty - this may be required by API";
        }

        // DCode (Referral Doctor) should be valid
        if (payload.Request_Master.DCode <= 0)
        {
            return "Request_Master.DCode is invalid (DCode must be > 0). Please select a referral doctor.";
        }

        // FTCode (Fee Type) should be valid
        if (payload.Request_Master.FTCode <= 0)
        {
            return "Request_Master.FTCode is invalid (FTCode must be > 0). This is typically determined by the referral doctor.";
        }

        // Branch/Counter/BillNo should be valid
        if (payload.Request_Master.EnteredBHCode <= 0)
        {
            return "Request_Master.EnteredBHCode is invalid (Branch code must be > 0)";
        }

        if (payload.Request_Master.CNTCode <= 0)
        {
            return "Request_Master.CNTCode is invalid (Counter code must be > 0)";
        }

        if (payload.Request_Master.BNCode <= 0)
        {
            return "Request_Master.BNCode is invalid (Bill number code must be > 0)";
        }

        // Validate Request_Details
        if (payload.Request_Details == null || payload.Request_Details.Count == 0)
        {
            return "Request_Details is empty. At least one test must be added";
        }

        // Validate that each Request_Detail has valid TCode
        foreach (var detail in payload.Request_Details)
        {
            if (detail.TCode <= 0)
            {
                return $"Request_Details contains item with invalid TCode: {detail.TCode}";
            }
            if (string.IsNullOrWhiteSpace(detail.RequestGUID))
            {
                return "Request_Details contains item with empty RequestGUID";
            }
        }

        // Validate Request_PatientDetails if present
        if (payload.Request_PatientDetails != null && payload.Request_PatientDetails.Count > 0)
        {
            foreach (var item in payload.Request_PatientDetails)
            {
                if (string.IsNullOrWhiteSpace(item.RequestGUID))
                {
                    return "Request_PatientDetails contains item with empty RequestGUID";
                }
            }
        }

        // Check CUSTID consistency
        if (payload.Request_Master.CUSTID != payload.customer.CUSTID)
        {
            Console.WriteLine($"Warning: CUSTID mismatch - Request_Master.CUSTID={payload.Request_Master.CUSTID}, Customer.CUSTID={payload.customer.CUSTID}");
        }

        // All validation passed
        return null;
    }
