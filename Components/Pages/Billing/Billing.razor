        var validCounters = counters.Where(c => !c.Deleted).ToList();
        int? cntCode = validCounters.FirstOrDefault()?.CNTCode;

        // Step 2: common predicate
        Func<BillNo_Master, bool> filter = x =>
            x.IsSampleNo &&
            (
                x.AllBranch ||
                (x.BHCode > 0 && x.CNTCode == 0 && x.BHCode == tt) ||
                (x.BHCode > 0 && x.CNTCode > 0 && x.BHCode == tt && x.CNTCode == cntCode)
            );

