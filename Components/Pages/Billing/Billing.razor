    private void CalculateAmounts()
    {
        if (billingModel == null)
        {
            return;
        }
        Double requestamt = addedTests.Sum(x => x.Amount) + Convert.ToDouble(billingModel.Charge);

        // Update only RequestAmount, preserve user-entered concession values for General and Referral discounts
        lrm.RequestAmount = requestamt;
        
        // Calculate TotalAmount based on all discounts
        lrm.TotalAmount = lrm.RequestAmount - lrm.OurDiscount - lrm.ReferalDiscount;

        StateHasChanged();
    }

    private void UpdateOverallDiscount(bool isPercent, bool isReferral)
    {
        if (lrm.RequestAmount == 0) return;

        if (isReferral)
        {
            // Update Referral Discount
            if (isPercent)
            {
                lrm.ReferalDiscount = (lrm.RequestAmount * lrm.ReferalPercentage) / 100;
            }
            else
            {
                lrm.ReferalPercentage = (lrm.ReferalDiscount / lrm.RequestAmount) * 100;
            }
        }
        else
        {
            // Update Our Discount
            if (isPercent)
            {
                lrm.OurDiscount = (lrm.RequestAmount * lrm.OurDisPercentage) / 100;
            }
            else
            {
                lrm.OurDisPercentage = (lrm.OurDiscount / lrm.RequestAmount) * 100;
            }
        }

        CalculateAmounts();
    }

