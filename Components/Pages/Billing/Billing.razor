                                            </td>
                                            <td style="padding:5px 8px;text-align:right;">
                                                @if (isnameedit)
                                                {
                                                    <input type="number" style="width:70px;padding:3px;border:1px solid #dde1e7;border-radius:4px;" @bind="test.Amount" @bind:event="oninput" @bind:after="CalculateAmounts" />
                                                }
                                                else
