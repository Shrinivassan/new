
@page "/billing"
@rendermode @(new InteractiveServerRenderMode(prerender:false))
@using LIMS.Model
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Newtonsoft.Json
@using Syncfusion.Blazor.Inputs
@using System.Net.Http.Headers
@using Lims.Components.Data
@inject Lims.Components.Data.NotificationService NotificationService
@using Lims.Components.Model
@inject AppSettings appSettings
@inject ProtectedSessionStorage _sessionStorage
@inject HttpClient http
@inject NavigationManager NavigationManager
@inject ExecutionClass exe
@inject ApiData apiData

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert-error alert-popup">
        @errorMessage
        <button @onclick="() => errorMessage = string.Empty" class="alert-popup-close">×</button>
    </div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert-success alert-popup" style="background:var(--bg-badge-paid); color:var(--text-success); border:1px solid var(--text-success);">
        <i class="bi bi-check-circle-fill" style="margin-right:8px;color:var(--text-success);"></i>@successMessage
        <button @onclick="() => successMessage = string.Empty" class="alert-popup-close" style="color:var(--text-success);">×</button>
    </div>
}

@if (showPrintConfirmation)
{
    <div class="print-confirmation-overlay">
        <div class="print-confirmation-dialog">
            <div class="print-confirmation-header">🧾 Print Receipt</div>
            <div class="print-confirmation-body">✅ @bsr.RequestSnoPrint @bsr.CUSTCode @bsr.Customer Bill saved successfully.<br/>Do you want to print the receipt?</div>
            <div class="print-confirmation-footer">
                <button @onclick="HandlePrintConfirmationNo" class="btn-confirm-no">No</button>
                <button @onclick="HandlePrintConfirmationYes" class="btn-confirm-yes">Yes</button>
            </div>
        </div>
    </div>
}



<SfDialog Visible=@isreport IsModal=true ShowCloseIcon=true Title="Bill Receipt" AllowDrag=true Width="900px" Height="600px">
    <DialogTemplates>
        <Content>
            @if (string.IsNullOrWhiteSpace(base64))
            {
                <div style="padding:20px;text-align:center;color:#999;width:100%;height:500px;display:flex;align-items:center;justify-content:center;flex-direction:column;">
                    <i class="bi bi-hourglass-split" style="font-size:32px;animation:spin 1s linear infinite;margin-bottom:10px;"></i>
                    <p>Loading report...</p>
                </div>
            }
            else
            {
                <div style="width:100%;height:550px;overflow:auto;border:1px solid #e0e0e0;border-radius:4px;">
                    <ReportViewer Reportstring="@base64"></ReportViewer>
                </div>
            }
        </Content>
    </DialogTemplates>
    <DialogButtons>
        <DialogButton OnClick="CloseBill">
            <ButtonProperties Content="Close" CssClass="e-flat e-outline"></ButtonProperties>
        </DialogButton>
    </DialogButtons>
</SfDialog>

<style>
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

@* TOP TOOLBAR *@
<div class="top-toolbar">
    <div class="toolbar-title-container">
        
        <span class="toolbar-title">NEW BILLING</span>
    </div>
    
    <div class="toolbar-controls">
        <div class="toolbar-control-item">
            <span class="toolbar-label">Counter</span>
            <select class="toolbar-select" style="min-width:120px;" value="@billingModel.Counter" @onchange="@(async (e) => await HandleCounterChange(e))">
                @foreach (Counter_Master it in counters){ <option value="@it.CNTCode">@it.Name</option> }
            </select>
        </div>
        
        <div class="toolbar-control-item">
            <span class="toolbar-label">Branch</span>
            <select class="toolbar-select" style="min-width:250px;" @onchange="onbranchsel">
                @foreach (Branch_Master it in branch){ <option  value="@it.BHCode" >@it.Name</option> }
            </select>
        </div>
        
        <div class="toolbar-control-item">
            <span class="toolbar-label">Bill Catalog</span>
            <select class="toolbar-select" style="min-width:120px;" value="@billingModel.BNCode" @onchange="@(async (e) => await HandleBillNoChange(e))">
                @foreach (var it in billnomaster){ <option value="@it.BNCode">@it.Name</option> }
            </select>
        </div>
        
        <div class="toolbar-control-item">
            <span class="toolbar-label">Case No / SID</span>
            <select class="toolbar-select" style="min-width:80px;" disabled><option>@lrm.RequestSno</option></select>
        </div>
    </div>
</div>

@* MAIN 3-COLUMN LAYOUT *@
<div style="display:flex;gap:10px;padding:10px;background:var(--bg-page);min-height:calc(100vh - 88px);align-items:flex-start;">

    @* === LEFT: PATIENT IDENTIFICATION === *@
    <div style="width:300px;min-width:240px;flex-shrink:0;background:var(--bg-card);border:1px solid var(--border-card);border-radius:10px;box-shadow:var(--shadow-card);padding:12px;">

        <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border-table);">
            <span style="background:var(--bg-hover);border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-person-badge" style="color:var(--brand-accent);font-size:14px;"></i>
            </span>
            <span style="font-size:13px;font-weight:700;color:var(--text-primary);">Patient Identification</span>
        </div>

        <EditForm Model="@customer">
            <div class="mb2">
                <span class="blbl">PATIENT ID</span>
                <input type="text" placeholder="Enter Patient ID" @bind="@customer.CUSTCode" class="binp" />
            </div>
            <div class="mb2">
                <span class="blbl">SEARCH MOBILE / UID</span>
                <div style="position:relative;">
                    <i class="bi bi-search" style="position:absolute;left:8px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:12px;"></i>
                    <input type="text" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"  class="binp" style="padding-left:26px;" placeholder="+91 Mobile / UID"
                           value="@customer.Mobile" @oninput="OnMobileInput" />
                    @if (showMobileDropdown && mobileSearchResults != null && mobileSearchResults.Any())
                    {
                        <ul style="position:absolute;width:100%;z-index:1000;max-height:200px;overflow-y:auto;box-shadow:var(--shadow-dropdown);list-style:none;padding:0;margin:0;background:var(--bg-dropdown);border:1px solid var(--border-color);border-radius:5px;">
                            @foreach (var item in mobileSearchResults)
                            {
                                <li style="padding:6px 10px;cursor:pointer;border-bottom:1px solid var(--border-table);" @onclick="() => SelectPatientFromMobile(item)">
                                    <div style="font-weight:600;font-size:12px;color:var(--text-primary);">@item.Name</div>
                                    <div style="font-size:11px;color:var(--text-muted);">@item.Mobile - @item.CUSTCode</div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            @* PREFIX + PATIENT NAME side by side *@
            <div class="mb2">
                <div style="display:flex;gap:6px;align-items:flex-end;">
                    <div style="flex:0 0 80px;">
                        <span class="blbl">PREFIX</span>
                        @if (isCustomSalutation)
                        {
                            <InputText @bind-value="customer.NameTitile" class="binp" placeholder="Salutation" @onblur="HandleSalutationInputBlur" />
                        }
                        else
                        {
                            <select value="@customer.NameTitile" @onchange="HandleSalutationChange" class="bsel">
                                <option value="">-- Select --</option>
                                <option value=""></option>
                                <option value="Mr.">Mr.</option>
                                <option value="Mrs.">Mrs.</option>
                                <option value="Miss.">Miss.</option>
                                <option value="Ms.">Ms.</option>
                                <option value="Master.">Master.</option>
                                <option value="Dr.">Dr.</option>
                                <option value="F/o.">F/o.</option>
                                <option value="S/o.">S/o.</option>
                                <option value="B/o.">B/o.</option>
                                <option value="C/o.">C/o.</option>
                                <option value="W/o.">W/o.</option>
                                <option value="M/s.">M/s.</option>
                                <option value="Selvan.">Selvan.</option>
                                <option value="Selvi.">Selvi.</option>
                                <option value="Sri.">Sri.</option>
                                <option value="Sri Mathi.">Sri Mathi.</option>
                                <option value="Sister.">Sister.</option>
                                <option value="Pet.">Pet.</option>
                            </select>
                        }
                    </div>
                    <div style="flex:1;min-width:0;">
                        <span class="blbl">PATIENT NAME</span>
                        <input type="text" placeholder="Enter Patient Name" @bind="@customer.Name" class="binp" style="border:1px solid #dde1e7;" />
                    </div>
                </div>
            </div>

            <div class="mb2">
                <span class="blbl">GENDER</span>
                <select class="bsel" @bind="@customer.Gender">
                    <option value="">-- Select --</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Child">Child</option>
                </select>
            </div>

            @* DOB + AGE side by side *@
            <div class="mb2">
                <div style="display:flex;gap:8px;align-items:flex-start;">

                    @* DATE OF BIRTH *@
                    <div style="flex:1;min-width:0;">
                        <span class="blbl" style="display:flex;align-items:center;gap:4px;">
                            <i class="bi bi-cake2" style="color:var(--brand-accent);font-size:10px;"></i> DATE OF BIRTH
                        </span>
                        <div style="display:flex;align-items:center;gap:6px;background:var(--bg-input);border:1.5px solid var(--border-input);border-radius:7px;padding:3px 8px;box-shadow:0 1px 4px rgba(0,0,0,.08);">
                            <i class="bi bi-calendar-heart" style="color:var(--brand-accent);font-size:13px;flex-shrink:0;"></i>
                            <InputDate TValue="DateTime"
                                       @bind-value="customer.DateOfBirth"
                                       @bind-value:after="() => CalculateAgeFromDOB(customer.DateOfBirth)"
                                       id="dob" name="dob"
                                       style="flex:1;border:none;outline:none;font-size:12px;font-weight:600;color:var(--text-primary);background:transparent;min-width:0;" />
                        </div>
                    </div>

                    @* AGE Y / M / D *@
                    <div style="display:flex;flex-direction:column;gap:2px;">
                        <span class="blbl" style="display:flex;align-items:center;gap:4px;white-space:nowrap;">
                            <i class="bi bi-hourglass-split" style="color:#5c6bc0;font-size:10px;"></i> AGE
                        </span>
                        <div style="display:flex;gap:4px;">
                            <div style="display:flex;flex-direction:column;align-items:center;">
                                <InputNumber @bind-value="@customer.AgeYears"
                                             @bind-value:after="UpdateDOBFromAge"
                                             placeholder="yy"
                                             style="width:38px;padding:4px 2px;border:1.5px solid var(--border-input);border-radius:6px;font-size:12px;font-weight:700;text-align:center;color:var(--brand-accent);background:var(--bg-hover);outline:none;" />
                                <span style="font-size:9px;color:var(--text-muted);font-weight:600;margin-top:1px;">YY</span>
                            </div>
                            <div style="display:flex;flex-direction:column;align-items:center;">
                                <InputNumber @bind-value="@customer.AgeMonths"
                                             @bind-value:after="UpdateDOBFromAge"
                                             placeholder="mm"
                                             style="width:38px;padding:4px 2px;border:1.5px solid var(--border-input);border-radius:6px;font-size:12px;font-weight:700;text-align:center;color:var(--brand-accent);background:var(--bg-hover);outline:none;" />
                                <span style="font-size:9px;color:var(--text-muted);font-weight:600;margin-top:1px;">MM</span>
                            </div>
                            <div style="display:flex;flex-direction:column;align-items:center;">
                                <InputNumber @bind-value="@customer.AgeDays"
                                             @bind-value:after="UpdateDOBFromAge"
                                             placeholder="dd"
                                             style="width:38px;padding:4px 2px;border:1.5px solid var(--border-input);border-radius:6px;font-size:12px;font-weight:700;text-align:center;color:var(--brand-accent);background:var(--bg-hover);outline:none;" />
                                <span style="font-size:9px;color:var(--text-muted);font-weight:600;margin-top:1px;">DD</span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>



            <div class="mb2">
                <div style="background:var(--bg-hover); color:var(--text-primary); font-size:11px; font-weight:700; padding:6px 10px; border-radius:6px; display:flex; justify-content:space-between; align-items:center; cursor:pointer; margin-bottom:6px; border:1px solid var(--border-color);">
                    <span>ID TYPE 1</span><i class="bi bi-chevron-down" style="font-size:10px; color:var(--text-muted);"></i>
                </div>
                <input type="text" @bind="@customer.PassportNo" class="binp" placeholder="Emirates passport" />
            </div>

            <div class="mb2">
                <div style="background:var(--bg-hover); color:var(--text-primary); font-size:11px; font-weight:700; padding:6px 10px; border-radius:6px; display:flex; justify-content:space-between; align-items:center; cursor:pointer; margin-bottom:6px; border:1px solid var(--border-color);">
                    <span>ID TYPE 2</span><i class="bi bi-chevron-down" style="font-size:10px; color:var(--text-muted);"></i>
                </div>
                <input type="text" @bind="@customer.AadhaarNo" class="binp" placeholder="Driver's License" />
            </div>

            <div class="mb2">
                <span class="blbl" style="display:flex;align-items:center;gap:4px;">
                    <i class="bi bi-geo-alt-fill" style="color:var(--brand-accent);font-size:10px;"></i> ADDRESS
                </span>
                <div style="display:flex;align-items:flex-start;gap:6px;background:var(--bg-input);border:1.5px solid var(--border-input);border-radius:7px;padding:6px 8px;box-shadow:0 1px 4px rgba(0,0,0,.08);">
                   
                    <InputTextArea @bind-value="@customer.Street"
                                   placeholder="Enter Address"
                                   style="flex:1;border:none;outline:none;resize:none;height:46px;font-size:12px;font-weight:500;color:var(--text-primary);background:transparent;padding:0;line-height:1.5;" />
                </div>
            </div>

            <div class="mb2">
                <span class="blbl">EMAIL</span>
                <input type="email" @bind="@customer.Email" placeholder="Enter the email" class="binp" style="border:1px solid #dde1e7;" />
                <a href="javascript:void(0)" style="font-size:14px;cursor:pointer;color:#3498db;display:flex;align-items:end;gap:4px;margin-top:4px;text-decoration:underline;" @onclick="() => showDetailsModal = true">
                    <i class="bi bi-list-check"></i> More info
                </a>
            </div>
        </EditForm>
    </div>

    @* === CENTER: REFERRAL DETAILS + TEST SELECTION === *@
    <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:10px;">


        @* REFERRAL DETAILS CARD *@
        <div style="background:var(--bg-card);border:1px solid var(--border-card);border-radius:10px;box-shadow:var(--shadow-card);padding:12px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border-table);">
                <span style="background:var(--bg-hover);border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-people" style="color:var(--brand-accent);font-size:14px;"></i>
                </span>
                <span style="font-size:13px;font-weight:700;color:var(--text-primary);">Referral Details</span>
            </div>
            <EditForm Model="@lrm">
                <div style="display:flex;gap:12px;margin-bottom:10px;">
                    <div style="flex:1;position:relative;">
                        <span class="blbl">PRIMARY REFERRAL (DOCTOR)</span>
                        <div style="display:flex;align-items:center;border:1px solid #dde1e7;border-radius:5px;background:#fff;">
                            <input type="text" style="flex:1;border:none;outline:none;padding:5px 8px;font-size:12px;border-radius:5px;"
                                   @bind="billingModel.ReferredBy"
                                   @oninput='(e => OnInputChanged(e, "ReferredBy"))'
                                   @onkeydown='(e => HandleKeyDown(e, "ReferredBy"))'
                                   placeholder="Search doctor..." />
                           
                        </div>
                        @if (referralResults?.Any() == true)
                        {
                            <ul style="position:absolute;width:100%;z-index:1000;list-style:none;padding:0;margin:0;background:var(--bg-dropdown);border:1px solid var(--border-color);border-radius:5px;box-shadow:var(--shadow-dropdown);max-height:180px;overflow-y:auto;">
                                @for (int i = 0; i < referralResults.Count; i++)
                                {
                                    var dr = referralResults[i];
                                    <li style="padding:7px 12px;cursor:pointer;font-size:12px;border-bottom:1px solid var(--border-table);background:@(i == selectedReferralIndex ? "var(--bg-hover)" : "transparent");color:var(--text-primary);"
                                        @onclick='() => SelectReferralDoctor(dr, "ReferredBy")'>@dr.DoctorFullName</li>
                                }
                            </ul>
                        }
                    </div>
                    <div style="flex:1;position:relative;">
                        <span class="blbl">SECONDARY REFERRAL</span>
                        <div style="display:flex;align-items:center;border:1px solid #dde1e7;border-radius:5px;background:#fff;">
                            <input type="text" style="flex:1;border:none;outline:none;padding:5px 8px;font-size:12px;border-radius:5px;"
                                   @bind="billingModel.SecondReferredBy"
                                   @oninput='(e => OnInputChanged(e, "SecondReferredBy"))'
                                   @onkeydown='(e => HandleKeyDown(e, "SecondReferredBy"))'
                                   @onblur='(e => HandleSecondReferralBlur())'
                                   placeholder="Search doctor..." />
                           
                        </div>
                        @if (secondReferralResults?.Any() == true)
                        {
                            <ul style="position:absolute;width:100%;z-index:1000;list-style:none;padding:0;margin:0;background:var(--bg-dropdown);border:1px solid var(--border-color);border-radius:5px;box-shadow:var(--shadow-dropdown);max-height:180px;overflow-y:auto;">
                                @for (int i = 0; i < secondReferralResults.Count; i++)
                                {
                                    var dr2 = secondReferralResults[i];
                                    <li style="padding:7px 12px;cursor:pointer;font-size:12px;border-bottom:1px solid var(--border-table);background:@(i == selectedSecondReferralIndex ? "var(--bg-hover)" : "transparent");color:var(--text-primary);"
                                        @onclick='() => SelectReferralDoctor(dr2, "SecondReferredBy")'>@dr2.DoctorFullName</li>
                                }
                            </ul>
                        }
                    </div>
                </div>
                <div style="display:flex;gap:10px;margin-top:8px;padding-top:8px;border-top:1px dashed #eee;flex-wrap:wrap;">
                    <div style="flex:1;min-width:130px;">
                        <span class="blbl">MONTHLY ACCOUNT</span>
                        <select class="bsel" @bind="lrm.RICode">
                            <option value="0">-- Select --</option>
                            @foreach (var it in rcm){ <option value="@it.RICode">@it.Name</option> }
                        </select>
                    </div>
                    <div style="flex:1;min-width:130px;">
                        <span class="blbl">SCHEME</span>
                        <select class="bsel" @bind="lrm.FTCode">
                            <option value="0">-- Select --</option>
                            @foreach (var it in feetype){ <option value="@it.FTCode">@it.Name</option> }
                        </select>
                    </div>
                </div>
                <div style="display:flex;gap:10px;margin-top:8px;flex-wrap:wrap;">
                    <div style="flex:1;min-width:100px;">
                        <span class="blbl">ROOM NUMBER</span>
                        <input type="text" placeholder="101" class="binp" @bind="@lrm.RoomNo" style="width:100%;" />
                    </div>
                    <div style="flex:1.5;min-width:200px;">
                        <span class="blbl">HOSPITAL ID</span>
                        <div style="display:flex;gap:4px;">
                            <select class="bsel" style="flex:0 0 100px;" @bind="@lrm.FrontHospitalID">
                                <option value="MRD NO">MRD NO</option><option value="MRS No">MRS No</option>
                                <option value="HID">HID</option><option value="MRD">MRD</option>
                            </select>
                            <input type="text" class="binp" @bind="@lrm.HospitalID" placeholder="101" style="flex:1;min-width:0;" />
                        </div>
                    </div>
                    <div style="flex:1.5;min-width:200px;">
                        <span class="blbl">HOSPITAL PATIENT ID</span>
                        <div style="display:flex;gap:4px;">
                            <select class="bsel" style="flex:0 0 100px;" @bind="@lrm.FrontHospitalPatientId">
                                <option value="IP No">IP No</option><option value="OP No">OP No</option>
                                <option value="HID">HID</option><option value="OP">OP</option>
                            </select>
                            <input type="text" class="binp" @bind="@lrm.HospitalPatientID" placeholder="101" style="flex:1;min-width:0;" />
                        </div>
                    </div>
                </div>
            </EditForm>
        </div>

        @* TEST SELECTION & SERVICES CARD *@
        <div style="background:var(--bg-card);border:1px solid var(--border-card);border-radius:10px;box-shadow:var(--shadow-card);padding:12px;flex:1;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border-table);">
                <div style="display:flex;align-items:center;gap:8px;">
                    <i class="bi bi-ui-checks" style="color:var(--brand-accent);font-size:14px;"></i>
                    <span style="font-size:13px;font-weight:700;color:var(--text-primary);">TEST SELECTION &amp; SERVICES</span>
                </div>
                <div style="display:flex;gap:24px;">
                    <div style="text-align:center;">
                        <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;">COUNT</div>
                        <div style="font-size:22px;font-weight:700;color:var(--text-primary);">@addedTests.Count.ToString("D2")</div>
                    </div>
                    <div style="text-align:center;">
                        <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;">SAMPLES</div>
                        <div style="font-size:22px;font-weight:700;color:var(--brand-accent);">@addedTests.Count.ToString("D2")</div>
                    </div>
                </div>
            </div>

            <div style="display:flex;gap:8px;margin-bottom:10px;position:relative;">
                <div style="flex:1;position:relative;">
                    <i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#aaa;font-size:13px;pointer-events:none;"></i>
                    <input type="text" value="@searchtest"
                           @oninput="@(e => OnInputChanged(e, "Test"))"
                           @onkeydown="@(e => HandleKeyDown(e, "Test"))"
                           placeholder="Search by Test Name..."
                           style="width:100%;padding:7px 10px 7px 32px;border:1px solid #dde1e7;border-radius:6px;font-size:12px;" />
                    @if (testmaster?.Any() == true)
                    {
                        <ul style="position:absolute;top:100%;left:0;width:100%;max-height:180px;overflow-y:auto;margin:0;padding:0;list-style:none;border:1px solid var(--border-color);border-radius:6px;background:var(--bg-dropdown);z-index:1050;box-shadow:var(--shadow-dropdown);">
                            @for (int i = 0; i < testmaster.Count; i++)
                            {
                                var tst = testmaster[i];
                                <li style="padding:7px 12px;cursor:pointer;border-bottom:1px solid var(--border-table);display:flex;justify-content:space-between;font-size:12px;background:@(i == selectedTestIndex ? "var(--bg-hover)" : "transparent");color:var(--text-primary);"
                                    @onclick="@(() => SelectTestItem(tst, "Test"))">
