    private async Task GetBillAsync(string rid)
    {
        try{

            lrd.Clear(); // Clear previous test details before loading new ones

            var res = await apiData.GetObjectData<BillRequest>(token, $"request/EditBill?rid={rid}");
            if (res.Request_Master!=null || res.Request_Master.DCode>0)
            {
                lrm=res.Request_Master;
                lrd=res.Request_Details;
                customer = res.customer;
                pdm = res.Request_PatientDetails;
                var res1 = await http.GetAsync($"{AppSettings.BaseUrl}referral/getreferral?dcode={lrm.DCode}");
                if(res1.IsSuccessStatusCode)
                {
                    var tt= res1.Content.ReadAsStringAsync().Result;
                    var tt1 = JsonConvert.DeserializeObject<Doctor_Master>(tt);
                    billingModel.ReferredBy = tt1.DoctorFullName;
                    billingModel.SecondReferredBy = lrm.SecondDoctorName;

                }

                // Get all test codes from the details to fetch their names
                var testCodes = lrd.Select(d => d.TCode).ToList();
                var codesString = string.Join(",", testCodes);
                var editest = await apiData.GetMasterList<Test_Master>(token, $"request/testlistbytcode?tcode={Uri.EscapeDataString(codesString)}");


                // Populate addedTests from lrd for the UI
                addedTests = lrd.Select(d => new TestItem
                        {
                            TCode = d.TCode,
                            Name = editest.Where(t => t.TCode == d.TCode)?.Select(x=>x.Name).FirstOrDefault() ?? "Unknown Test",
                            Amount = Convert.ToDouble(d.TestAmount),
                            DiscountPercent = d.TestAmount > 0 ? Convert.ToDouble((d.Discount / d.TestAmount) * 100) : 0,
                            DiscountAmount = Convert.ToDouble(d.Discount)
                        }).ToList();

                CalculateAmounts();

                StateHasChanged();
            }

        }catch(Exception ex)
        {
            errorMessage = ex.Message.ToString();
        }

    }



