    private void HandleSalutationChange(ChangeEventArgs e)
    {
        var salutation = e.Value?.ToString() ?? "";

        // Check if empty option is selected (the second empty option in the dropdown)
        if (salutation == "" && customer.NameTitile != "")
        {
            // Switch to custom salutation input
            isCustomSalutation = true;
            customer.NameTitile = "";
            return;
        }

        if (salutation == "Other")
        {
            isCustomSalutation = true;
            customer.NameTitile = "";
            return;
        }

        isCustomSalutation = false;
        customer.NameTitile = salutation;

        switch (salutation)
        {
            case "Mr.":
                customer.Gender = "Male";
                break;
            case "Ms.":
            case "Mrs.":
                customer.Gender = "Female";
                break;
        }
    }

