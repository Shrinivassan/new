    private async Task LoadLRD()
    {

        foreach(var it in addedTests)
        {
            var chk = lrd.Where(x => x.TCode == it.TCode).ToList();
            if(chk==null || chk.Count==0)
            {
                var test=tmadded.Where(x=>x.TCode==it.TCode).FirstOrDefault();
                lrd.Add(new Lab_Request_Details()
                {
                    RequestDetailsID = Guid.NewGuid(),
                    TestSno = lrd.Count + 1,
                    TCode = Convert.ToInt32(test.TCode),
                    PackCode = test.PackCode,
                    TestAmount = test.Amount,
                    CommissionAmount = 0,
                    ReferalDiscount = 0,
                    Discount = 0,
                    Collection = 0,
                    IsInvestigation = test.Routine,
                    IsCulture = test.CultureReport,
                    IsTextReport = test.TextContent,
                    IsTestHavingResult = (!test.LockResult && !test.OutLab),
                    ResultStatus = false,
                    IsLockResult = test.LockResult,
                    IsOthers = test.OutLab,
                    RequestStatus = false,
                    IsPrinted = false,
                    CommissionPaid = 0,
                    SpecialDiscount = 0,
                    NewAmount = 0,
                    NewTCode = 0,
                    IsAuthorized1 = false,
                    IsAddSpecial = false,
                    IsRemovedSpecial = false,
                    StandardPrice = test.Amount,
                    CommissionType = "",
                    FTCommissionPer = 0,
                    FTCommissionAmount = 0,
                    RunningCost = 0,
                    IsManualCommission = false,
                    IsPack = test.IsPackage,
                    ResultEnteredBy = 0,
                    ResultAuthorizedBy = 0,
                    IsSelect = false,
                    CommissionPaymentMode = "Not Generated",
                    CommissionChequeName = "",
                    IsCommissionPaid = false,
                    CommissionGeneratedDate = DateTime.Today,
                    IsSampleCollected = false,
                    IsSampleReceived = false,
                    IsDelivered = false,
                    IsInventoryPosted = false,
                    PerformedCount = 0,
                    IsAuthorized2 = false,
                    IsUploaded = false,
                    ResultAuthorizedBy2 = 0,
                    IsWorkListPrinted = false,
                    Qty = 1,
                    TestRate = test.Amount,
                    RefundAmount = 0,
                    ResultEnteredDate = null,
                    FirstAuthorizeDate = null,
                    SecondAuthorizeDate = null
                });
            }
            else
            {
                
            }
        }
        var addedTestCodes = addedTests.Select(t => t.TCode).ToHashSet();
        lrd = lrd.Where(x => addedTestCodes.Contains(x.TCode)).ToList();
        lrd = lrd.GroupBy(x => new { x.RequestGUID, x.TCode }).Select(g => g.First()).ToList();
       
        foreach(var it in lrd)
        {
            it.RequestGUID = lrm.RequestGUID;
            if (it.RequestDetailsID == Guid.Empty)
            {
                it.RequestDetailsID = Guid.NewGuid();
            }
            it.DeliveredMode = string.IsNullOrEmpty(it.DeliveredMode) ? "" : it.DeliveredMode;
        }
    }

    BillSaveResponse bsr = new();
    private async Task SaveBilling()
    {
        try
        {
          
            if (!isapproved)
            {
                errorMessage = "You do not have permission to perform this action.";
                StateHasChanged();
                return;
            }

            if (string.IsNullOrWhiteSpace(customer.Name))
            {
                errorMessage = "Please Enter Patient Name";
                StateHasChanged();
                return;
            }

            if (string.IsNullOrWhiteSpace(billingModel.ReferredBy))
            {
                errorMessage = "Please Enter Referral Doctor";
                StateHasChanged();
                return;
            }

            
            if (!addedTests.Any())
            {
                errorMessage = "Please add at least one test before saving.";
                StateHasChanged();
                return;
            }

            if (lrm.PaidAmount > lrm.TotalAmount)
            {
                errorMessage = "Paid amount cannot be greater than the Nett amount.";
                StateHasChanged();
                return;
            }

            // Ensure defaults for branch/counter/billno/feetype
            if (lrm.BNCode == 0 && billnomaster.Any()) lrm.BNCode = billnomaster[0].BNCode;
            if (lrm.CNTCode == 0 && counters.Any()) lrm.CNTCode = counters[0].CNTCode;
            if (lrm.EnteredBHCode == 0)
            {
                if (int.TryParse(billingModel.Branch, out var bh)) lrm.EnteredBHCode = bh;
                else if (branch.Any()) lrm.EnteredBHCode = branch[0].BHCode;
            }
            if (lrm.FTCode == 0 && feetype.Any()) lrm.FTCode = feetype[0].FTCode;

            await this.LoadCustomerData();
            await this.LoadLRM();
            await this.LoadLRD();

            // Validate RequestGUID before proceeding
            if (string.IsNullOrWhiteSpace(lrm.RequestGUID))
            {
                errorMessage = "RequestGUID is empty. Cannot proceed with save.";
                StateHasChanged();
                return;
            }

            // Ensure RequestSnoPrint is populated from RequestSno if empty
            if (string.IsNullOrWhiteSpace(lrm.RequestSnoPrint) && lrm.RequestSno > 0)
            {
                lrm.RequestSnoPrint = lrm.RequestSno.ToString();
            }

            // Ensure CUSTID is valid - if 0, it means customer hasn't been saved yet
            if (customer.CUSTID == 0)
            {
                customer.CUSTID = 0; // Will be auto-generated by backend, but log this

            }

            // Ensure lrm.CUSTID matches customer.CUSTID
            if (lrm.CUSTID != customer.CUSTID)
            {
                lrm.CUSTID = customer.CUSTID;
            }

            // Ensure all Request_PatientDetails have the RequestGUID populated
            if (pdm != null && pdm.Count > 0)
            {
                foreach (var item in pdm)
                {
                    if (string.IsNullOrWhiteSpace(item.RequestGUID))
                    {
                        item.RequestGUID = lrm.RequestGUID;
                    }
                }
            }
            else
            {
                // Initialize as empty list if null
                pdm = new List<RequestPatientDetails>();
            }

            // Prepare payload
            // Build required prenatal request form (reqfrom) with minimal valid defaults
            var reqForm = new RequestForm
            {
                ID = Guid.NewGuid(),
                CustID = customer.CUSTID,
                RequestGUID = Guid.TryParse(lrm.RequestGUID, out var rg) ? rg : Guid.NewGuid(),
                Weight = 0,
                Height = 0,
                Smoking = false,
                PassiveSmoking = false,
                Ethnicity = "Unknown",
                LMP = DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd"),
                LMPStatus = "Unknown",
                EDD = DateTime.Now.AddMonths(8).ToString("yyyy-MM-dd"),
                IsNatural = true,
                IsAssisted = false,
                IsSelfEgg = true,
                DonotEgg = false,
                ProcedureType = "OPD",
                DonorAge = "0",
                DonorDOB = DateTime.Now.AddYears(-30),
                ExtractionDate = DateTime.Now,
                TransferDate = DateTime.Now,
                DateOfUltraSound = DateTime.Now,
                IsSingle = true,
                IsTwin = false,
                Chorionicity = "Unknown",
                CRL1 = 0,
                NT1 = 0,
                NB1 = "NA",
                CRL2 = 0,
                NT2 = 0,
                NB2 = "NA",
                BPD = 0,
                HC = 0,
                AC = 0,
                FL = 0,
                ParityHistory = "NA",
                T21 = false,
                T18 = false,
                T13 = false,
                NTD = false,
                FamilyHistory = false,
                DiabeticIDDM = false,
                DiabeticGDM = false,
                Bleeding = false,
                FolicAcid = false,
                HCGDose = false,
                LastHCGDose = "NA",
                Screening = "NA",
                EnteredDate = DateTime.Now,
                UserCode = userAuthResult.UserCode > 0 ? userAuthResult.UserCode : 1
            };

            BillRequest saveData = new BillRequest
            {
                customer = customer,
                Request_Master = lrm, // This lrm object now correctly contains the RequestGUID
                Request_Details = lrd,
                reqfrom = reqForm,
                Request_PatientDetails = pdm ?? new List<RequestPatientDetails>()
            };

            // Validate payload structure before sending
            var validationError = ValidateBillPayload(saveData);
            if (!string.IsNullOrEmpty(validationError))
            {
                errorMessage = $"Payload validation failed: {validationError}";
                StateHasChanged();
                return;
            }

            // DEBUG: Show Payload on Screen

            StateHasChanged();

            // Create the lightweight bill summary object before the API call.
            // This ensures it's available to be added to the local list regardless of API success.

            var jsonContent = JsonConvert.SerializeObject(saveData, Formatting.Indented);
            Console.WriteLine("========== SAVEBILL PAYLOAD ==========");
            Console.WriteLine(jsonContent);
            Console.WriteLine("======================================");
            var content = new StringContent(jsonContent, System.Text.Encoding.UTF8, "application/json");

            try
            {
                var request = new HttpRequestMessage(HttpMethod.Post, $"{AppSettings.BaseUrl}Request/Savebill")
                {
                    Content = content
                };
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

                var httpResponse = await http.SendAsync(request);

                if (httpResponse.IsSuccessStatusCode || httpResponse.StatusCode == System.Net.HttpStatusCode.BadRequest)
                {
                    // NOTE: This API always returns 400 even on success (confirmed by logs).
                    // Bill IS saved to DB — verified by report generation using lrm.RequestGUID.
                    // We treat both 200 and 400 as a successful save.
                    var responseContent = await httpResponse.Content.ReadAsStringAsync();

                    // Try to extract bsr fields if present in response
                    try { bsr = JsonConvert.DeserializeObject<BillSaveResponse>(responseContent) ?? new BillSaveResponse(); }
                    catch { bsr = new BillSaveResponse(); }

                    // Prefer bsr.RequestSnoPrint if API ever returns it, else show lrm.RequestSnoPrint
                    string displayBillNo = !string.IsNullOrWhiteSpace(bsr?.RequestSnoPrint)
                                            ? bsr.RequestSnoPrint
                                            : (!string.IsNullOrWhiteSpace(lrm.RequestSnoPrint) ? lrm.RequestSnoPrint : "—");

                    Console.WriteLine($"[SaveBill] Status={httpResponse.StatusCode} | bsr.RequestSnoPrint={bsr?.RequestSnoPrint} | lrm.RequestGUID={lrm.RequestGUID}");

                    ShowSuccessMessage($"Bill saved successfully! Bill No: {displayBillNo}");
                    _ = NotificationService.ShowSuccess($"Bill saved successfully! Bill No: {displayBillNo}");
                    showPrintConfirmation = true;
                    StateHasChanged();
                }
                else
                {
                    var errorContent = await httpResponse.Content.ReadAsStringAsync();
                    Console.WriteLine($"API Error ({(int)httpResponse.StatusCode}): {errorContent}");
                    
                    // Try to parse error details
                    string errorDetails = errorContent;
                    try
                    {
                        dynamic errorJson = JsonConvert.DeserializeObject(errorContent);
                        errorDetails = errorJson?.ToString() ?? errorContent;
                        
                        // Check for specific error messages
                        if (errorJson?.message != null)
                        {
                            errorDetails = $"[{errorJson.message}] {errorDetails}";
                        }
                        if (errorJson?.error != null)
                        {
                            errorDetails = $"[{errorJson.error}] {errorDetails}";
                        }
                        if (errorJson?.errors != null)
                        {
                            errorDetails = $"[Validation Errors] {JsonConvert.SerializeObject(errorJson.errors)}";
                        }
                    }
                    catch { /* Use raw error content if not JSON */ }

                    errorMessage = $"Save failed ({(int)httpResponse.StatusCode}): {errorDetails}";
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Save request error: {ex.Message}";
                StateHasChanged();
            }
            finally
            {
                // This block executes regardless of API success or failure.
                // Always update the local session storage so the user sees the new bill.

                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task ClearForm()
    {
        // Preserve branch/counter/billno so next SID continues the sequence
        var preservedBranch = billingModel?.Branch;
        var preservedCounter = billingModel?.Counter;
        var preservedBN = billingModel?.BNCode;

        // Re-initialize the main data models to clear the form fields
        customer = new Customer_Master();
        lrm = new Lab_Request_Master();
        // Reset billingModel but keep branch/counter/bn
        billingModel = new BillingModel();
        if (!string.IsNullOrEmpty(preservedBranch)) billingModel.Branch = preservedBranch;
        if (!string.IsNullOrEmpty(preservedCounter)) billingModel.Counter = preservedCounter;
        if (!string.IsNullOrEmpty(preservedBN)) billingModel.BNCode = preservedBN;

        lrd.Clear();
        addedTests.Clear();

        // Reset UI state variables
        patientSearchQuery = "";
        searchtest = "";
        showPatientDropdown = false;

        isCustomSalutation = false;
        // Set default values for the new bill, similar to OnInitializedAsync
        lrm.RequestDatetime = DateTime.Now;
        lrm.CollectedDateTime = DateTime.Now.AddMinutes(14);
        lrm.RequestedDateTime = DateTime.Now.AddMinutes(9);
        billingModel.BillDate = DateTime.Now;
        billingModel.HomeCollectionBy = "In Lab";

        // Request next SID for preserved branch/counter/bn (await so UI updates on render cycle)
        try
        {
            if (!string.IsNullOrEmpty(billingModel.Branch) && !string.IsNullOrEmpty(billingModel.Counter) && !string.IsNullOrEmpty(billingModel.BNCode))
            {
                if (int.TryParse(billingModel.Branch, out var bh) && int.TryParse(billingModel.Counter, out var cnt) && int.TryParse(billingModel.BNCode, out var bn))
                {
                    await UpdateSID(Convert.ToString(lrm.RequestDatetime), bh, cnt, bn);
                }
            }
        }
        catch { }

        StateHasChanged();
    }

