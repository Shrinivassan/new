                                                    <span>@test.Amount.ToString("0.00")</span>
                                                }
                                            </td>
                                            <td style="padding:5px 8px;text-align:center;">
                                                <div>
                                                    <input type="number" style="width:55px;padding:3px;border:1px solid #dde1e7;border-radius:4px;text-align:center;"
                                                           @bind="test.DiscountPercent" @oninput="(e) => UpdateTestDiscount(test, e, true)" />
                                                    <div style="font-size:10px;color:#888;">@test.DiscountAmount.ToString("0.0")</div>
                                                </div>
                                            </td>
                                            <td style="padding:5px 8px;text-align:right;font-weight:600;">@test.Total.ToString("0.00")</td>
                                            <td style="padding:5px 8px;text-align:center;">
                                                <button type="button" @onclick="() => RemoveTest(test)" title="Remove"
                                                        style="background:none;border:none;color:#e53935;cursor:pointer;font-size:16px;padding:0;">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        idx++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </EditForm>

            @* HOME COLLECTION CARD *@
            <div style="margin-top:10px;padding-top:10px;border-top:1px solid var(--border-table);">
                @* Header toggle row *@
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:@(billingModel.IsHomeCollection ? "10px" : "0");padding:8px 10px;background:var(--bg-hover);border-radius:8px;transition:background .3s;">
                    <div style="display:flex;align-items:center;gap:8px;">
