    // Local fallback: store last SID per branch-counter-billno key and increment
    private string GetLocalSidKey(int bhcode, int cntcode, int bncode)
    {
        return $"localLastSID_{bhcode}_{cntcode}_{bncode}";
    }

    private async Task<int> GetNextLocalSID(int bhcode, int cntcode, int bncode)
    {
        try
        {
            var key = GetLocalSidKey(bhcode, cntcode, bncode);
            var stored = await _sessionStorage.GetAsync<int?>(key);
            int last = stored.Success && stored.Value.HasValue ? stored.Value.Value : 0;
            int next = last + 1;
            await SaveLocalLastSID(bhcode, cntcode, bncode, next);
            return next;
        }
        catch
        {
            // As a last resort, return timestamp-based small integer
            return (int)(DateTime.UtcNow.Ticks % 100000);
        }
    }

    private async Task SaveLocalLastSID(int bhcode, int cntcode, int bncode, int value)
    {
        try
        {
            var key = GetLocalSidKey(bhcode, cntcode, bncode);
            await _sessionStorage.SetAsync(key, value);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving local SID: {ex.Message}");
        }
    }

