    }

    private void UpdateTestDiscount(TestItem test, ChangeEventArgs e, bool isPercent)
    {
        if (billingModel == null)
        {
            return;
        }

        if (isPercent)
        {
            if (Double.TryParse(e.Value?.ToString(), out var discountPercent))
            {
                test.DiscountPercent = discountPercent;
                test.DiscountAmount = (test.Amount * test.DiscountPercent) / 100;
            }
        }
        else
        {
            if (Double.TryParse(e.Value?.ToString(), out var discountAmount))
            {
                test.DiscountAmount = discountAmount;
                test.DiscountPercent = (test.DiscountAmount / test.Amount) * 100;
            }
        }
        CalculateAmounts();
    }

    private void UpdateTestAmount(TestItem test)
    {
        // This method is no longer directly called by the input, but is kept for clarity
        // or if it's needed elsewhere. The @bind with oninput now handles the update.
        CalculateAmounts();
    }

