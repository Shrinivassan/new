    private async Task LoadRightsAsync()
    {
        IList<User_Rights> rights = (await _sessionStorage.GetAsync<IList<User_Rights>>("UserRights")).Value ?? new List<User_Rights>();
        if(rights!=null && rights.Count>0)
        {
