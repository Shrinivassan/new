    private void CalculateAgeFromDOB(DateTime birthDate)
    {
        if (customer == null || birthDate == default || birthDate == DateTime.MinValue || birthDate > DateTime.Today)
        {
            customer.AgeYears = 0;
            customer.AgeMonths = 0;
            customer.AgeDays = 0;
            return;
        }

        var today = DateTime.Today;

        // --- Years ---
        int years = today.Year - birthDate.Year;
        DateTime lastBirthday = birthDate.AddYears(years);
        if (lastBirthday > today)
        {
            years--;
            lastBirthday = birthDate.AddYears(years);
        }
        customer.AgeYears = years;

        // --- Months (remaining after full years) ---
        int months = (today.Year - lastBirthday.Year) * 12 + (today.Month - lastBirthday.Month);
        DateTime lastMonthDate = lastBirthday.AddMonths(months);
        if (lastMonthDate > today)
        {
            months--;
            lastMonthDate = lastBirthday.AddMonths(months);
        }
        if (months < 0) months = 0;
        customer.AgeMonths = months;

        // --- Days (remaining after full months) ---
        int days = (today - lastMonthDate).Days;
        if (days < 0) days = 0;
        customer.AgeDays = days;
    }

    private void UpdateDOBFromAge()
    {
        // When user manually enters Y/M/D, calculate and update the DOB field
        if (customer.AgeYears == 0 && customer.AgeMonths == 0 && customer.AgeDays == 0)
            return;

        try
        {
            var dob = DateTime.Today
                .AddYears(-customer.AgeYears)
                .AddMonths(-customer.AgeMonths)
                .AddDays(-customer.AgeDays);

            if (dob <= DateTime.Today && dob > DateTime.MinValue)
            {
                customer.DateOfBirth = dob;
                billingModel.DateOfBirth = dob;
            }
        }
        catch { /* ignore out-of-range */ }
    }

    // Compute an approximate DOB from provided age components (years, months, days).
    // Returns null when no meaningful age information is available.
    private DateTime? ComputeDOBFromAge(int years, int months, int days)
    {
        if (years == 0 && months == 0 && days == 0)
            return null;

        try
        {
            var dob = DateTime.Today.AddYears(-years).AddMonths(-months).AddDays(-days);
            // Sanity check: do not return a future date
            if (dob > DateTime.Today)
                return null;
            return dob;
        }
        catch
        {
            return null;
        }
    }

