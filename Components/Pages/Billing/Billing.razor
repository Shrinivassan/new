    private async Task HandleKeyDown(KeyboardEventArgs e, string type)
    {
        if (billingModel == null)
        {
            return;
        }

        if (type == "Test" && testmaster.Any())
        {
            if (e.Key == "ArrowDown")
            {
                selectedTestIndex = (selectedTestIndex + 1) % testmaster.Count;
            }
            else if (e.Key == "ArrowUp")
            {
                selectedTestIndex = (selectedTestIndex - 1 + testmaster.Count) % testmaster.Count;
            }
            else if (e.Key == "Enter" && selectedTestIndex >= 0)
            {
                await SelectTestItem(testmaster[selectedTestIndex], type);
            }
            await InvokeAsync(StateHasChanged);
        }
        else if (type == "ReferredBy" && referralResults.Any())
        {
            if (e.Key == "ArrowDown")
            {
                selectedReferralIndex = (selectedReferralIndex + 1) % referralResults.Count;
            }
            else if (e.Key == "ArrowUp")
            {
                selectedReferralIndex = (selectedReferralIndex - 1 + referralResults.Count) % referralResults.Count;
            }
            else if (e.Key == "Enter" && selectedReferralIndex >= 0)
            {
                SelectReferralDoctor(referralResults[selectedReferralIndex], type);
            }
        }
        else if (type == "SecondReferredBy" && secondReferralResults.Any())
        {
            if (e.Key == "ArrowDown")
            {
                selectedSecondReferralIndex = (selectedSecondReferralIndex + 1) % secondReferralResults.Count;
            }
            else if (e.Key == "ArrowUp")
            {
                selectedSecondReferralIndex = (selectedSecondReferralIndex - 1 + secondReferralResults.Count) % secondReferralResults.Count;
            }
            else if (e.Key == "Enter" && selectedSecondReferralIndex >= 0)
            {
                SelectReferralDoctor(secondReferralResults[selectedSecondReferralIndex], type);
            }
        }
        else if (type == "Area" && areaResults.Any())
        {
            if (e.Key == "ArrowDown")
            {
                selectedAreaIndex = (selectedAreaIndex + 1) % areaResults.Count;
            }
            else if (e.Key == "ArrowUp")
            {
                selectedAreaIndex = (selectedAreaIndex - 1 + areaResults.Count) % areaResults.Count;
            }
            else if (e.Key == "Enter" && selectedAreaIndex >= 0)
            {
                SelectArea(areaResults[selectedAreaIndex]);
            }
        }
    }

    private async Task SelectTestItem(Test_Master test, string type)
    {
        if (billingModel == null)
        {
            return;
        }

        if (test != null && !addedTests.Any(t => t.TCode == test.TCode))
        {
    
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var res = await http.GetAsync($"{appSettings.BaseUrl}request/TestFeeByName?FeeTypeCode={lrm.FTCode}&DCode={lrm.DCode}&TestName={Uri.EscapeUriString(test.Name)}");
            Double Testamount = test.Amount;
            if(res.IsSuccessStatusCode)
            {
                var tt=await res.Content.ReadAsStringAsync();
                var tt1=JsonConvert.DeserializeObject<dynamic>(tt);
                Testamount = tt1.FinalRate;
            }
            else
            {
                var tt = await res.Content.ReadAsStringAsync();

            }

            addedTests.Add(new TestItem
                {
                    TCode = test.TCode,
                    Name = test.Name,
                    Amount = Testamount,
                    DiscountPercent = 0,
                    DiscountAmount = 0
                });
            if (!tmadded.Any(x => x.TCode == test.TCode))
            {
                tmadded.Add(test);
            }

        }
        searchtest = "";
        testmaster.Clear();
        selectedTestIndex = -1;
        await InvokeAsync(StateHasChanged);
        CalculateAmounts();
    }



    private void RemoveTest(TestItem test)
    {
        if (billingModel == null)
