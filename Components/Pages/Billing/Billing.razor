                <span style="font-size:12px;font-weight:700;color:rgba(255,255,255,0.9);text-transform:uppercase;letter-spacing:1px;">NET PAYABLE</span>
                <span class="net-pay-blink" style="font-size:22px;"> @lrm.TotalAmount.ToString("0.00")</span>
            </div>
        </div>

        @* PAYMENT INTERFACE *@
        <EditForm Model="@lrm" OnValidSubmit="SaveBilling">
            <div style="background:linear-gradient(135deg,#3f51b5,#5c6bc0);border-radius:10px;padding:12px;color:#fff;box-shadow:0 2px 12px rgba(63,81,181,.3);">
                <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;opacity:.9;margin-bottom:10px;">PAYMENT INTERFACE</div>

              

                <div style="background:rgba(255,255,255,0.1);border-radius:8px;padding:7px 10px;margin-bottom:6px;display:flex;align-items:center;gap:6px;">
                    <span style="font-size:11px;font-weight:700;width:40px;opacity:.9;">CASH</span>
                    <InputNumber style="flex:1;padding:4px 6px;border:none;border-radius:5px;font-size:12px;font-weight:600;text-align:right;color:var(--text-primary);background:var(--bg-input);"
                                 @bind-Value="@lrm.PaidAmount" />
                    <i class="bi bi-check-circle-fill" style="color:var(--text-success);font-size:16px;flex-shrink:0;"></i>
                </div>

                <div style="margin-bottom:8px;">
                    <span style="font-size:10px;color:rgba(255,255,255,.7);display:block;margin-bottom:3px;text-transform:uppercase;">PAY MODE</span>
                    <select @bind="lrm.PMCode" style="width:100%;padding:5px 8px;border:none;border-radius:5px;font-size:12px;background:var(--bg-input);color:var(--text-primary);">
                        @foreach (var mode in paymode){ <option value="@mode.PMCode">@mode.Name</option> }
                    </select>
                </div>

        

  
            </div>

        </EditForm>

        @* SAVE / CLEAR BUTTONS — pinned to bottom *@
        <div style="display:flex;gap:6px;margin-top:10px;">
            <button type="button" @onclick="@(async () => await ClearForm())"
                    style="flex:1;padding:5px 8px;background:#e53935;color:#fff;border:none;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;box-shadow:0 2px 4px rgba(229,57,53,.35);transition:background .2s;">
                <i class="bi bi-arrow-counterclockwise"></i> CLEAR
            </button>
            <button type="button" @onclick="SaveBilling" disabled="@(!issave)"
                    style="flex:1;padding:5px 8px;background:#1976d2;color:#fff;border:none;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;letter-spacing:.5px;box-shadow:0 2px 4px rgba(25,118,210,.35);transition:background .2s;">
                <i class="bi bi-check-circle"></i>  SAVE
            </button>
        </div>
    </div>
</div>



@if (showDetailsModal)
{
    <div class="modal-overlay-blur" @onclick="() => showDetailsModal = false">
        <div class="details-card-modal" @onclick:stopPropagation="true">
            <div class="details-card-header" style="background:var(--bg-header); border-bottom:1px solid var(--border-table); display:flex; justify-content:space-between; align-items:center; padding:12px 16px;">
                <h6 style="margin:0;font-weight:700;font-size:14px;color:var(--text-on-brand);">Patient Details</h6>
                <button type="button" style="background:none;border:none;cursor:pointer;font-size:18px;color:var(--text-on-brand);display:flex;align-items:center;justify-content:center;" @onclick="() => showDetailsModal = false">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div style="padding:16px;max-height:60vh;overflow-y:auto;">
                @if (pdm != null && pdm.Count > 0)
                {
                    <table class="table table-sm table-borderless mb-0">
                        <thead><tr><th>Parameter</th><th>Value</th></tr></thead>
                        <tbody>
                            @foreach (var it in pdm)
                            {
                                <tr>
                                    <td style="vertical-align:middle;">@it.Name</td>
                                    <td><input type="text" @bind-value=@it.PDValue class="form-control form-control-sm" /></td>
