                                    <th style="padding:7px 8px;text-align:right;white-space:nowrap;">TOTAL AMT</th>
                                    <th style="padding:7px 8px;text-align:center;">ACTION</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!addedTests.Any())
                                {
                                    <tr><td colspan="6" style="padding:24px;text-align:center;color:var(--text-muted);">
