        @* BILL DATE & COLLECTED DATE *@
        <div style="background:var(--bg-card);border:1px solid var(--border-card);border-radius:12px;box-shadow:var(--shadow-card);overflow:hidden;">
            @* Card Header *@
            <div style="padding:6px 10px;display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--border-table);">
                <span style="background:var(--bg-hover);border-radius:50%;width:26px;height:26px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-calendar3" style="color:var(--brand-accent);font-size:14px;"></i>
                </span>
                <span style="font-size:13px;font-weight:700;color:var(--text-primary);">Dates</span>
            </div>
            @* Date Fields *@
            <div style="padding:8px 10px;display:flex;flex-direction:column;gap:6px;">
                <EditForm Model="@lrm">
                    @* BILL DATE *@
                    <div style="border-left:3px solid var(--brand-accent);background:var(--bg-hover);border-radius:0 6px 6px 0;padding:5px 8px 5px 10px;">
                        <div style="font-size:10px;font-weight:700;color:var(--brand-accent);letter-spacing:.5px;text-transform:uppercase;margin-bottom:3px;display:flex;align-items:center;gap:4px;">
                            <i class="bi bi-file-earmark-text" style="font-size:11px;"></i> Bill Date
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;background:var(--bg-input);border:1px solid var(--border-input);border-radius:6px;padding:2px 6px;">
                            <i class="bi bi-calendar-check" style="color:var(--brand-accent);font-size:13px;flex-shrink:0;"></i>
                            <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="@lrm.RequestDatetime" @bind-Value:format="yyyy-MM-ddTHH:mm"
                                       style="flex:1;border:none;outline:none;font-size:12px;font-weight:600;color:var(--text-primary);background:transparent;min-width:0;" />
                        </div>
                    </div>
                    @* COLLECTED DATE *@
                    <div style="border-left:3px solid var(--text-success);background:var(--bg-badge-paid);border-radius:0 6px 6px 0;padding:5px 8px 5px 10px;">
                        <div style="font-size:10px;font-weight:700;color:var(--text-success);letter-spacing:.5px;text-transform:uppercase;margin-bottom:3px;display:flex;align-items:center;gap:4px;">
                            <i class="bi bi-droplet-half" style="font-size:11px;"></i> Collected Date
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;background:var(--bg-input);border:1px solid var(--border-input);border-radius:6px;padding:2px 6px;">
                            <i class="bi bi-calendar2-check" style="color:var(--text-success);font-size:13px;flex-shrink:0;"></i>
                            <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="@lrm.CollectedDateTime" @bind-Value:format="yyyy-MM-ddTHH:mm"
                                       style="flex:1;border:none;outline:none;font-size:12px;font-weight:600;color:var(--text-primary);background:transparent;min-width:0;" />
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>

        @* COLLECTION BY *@
        <!-- <div style="background:#fff;border-radius:10px;box-shadow:0 1px 6px rgba(0,0,0,.08);padding:12px;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid #eee;">
                <div style="display:flex;align-items:center;gap:6px;">
                    <i class="bi bi-building" style="color:#bbb;font-size:13px;"></i>
                    <span style="font-size:10px;font-weight:700;color:#999;text-transform:uppercase;letter-spacing:.5px;">COLLECTION BY</span>
                </div>
                <div style="width:36px;height:20px;background:#e0e0e0;border-radius:10px;cursor:pointer;display:flex;align-items:center;padding:2px;">
                    <div style="width:16px;height:16px;background:#fff;border-radius:50%;box-shadow:0 1px 3px rgba(0,0,0,.2);"></div>
                </div>
            </div>
            <div class="mb2">
                <span class="blbl">STAFF</span>
                <select class="bsel" @bind="lrm.CTCode">
                    <option value="0">-- Select --</option>
                    @foreach (var c in collectorResults){ <option value="@c.CTCode">@c.Name</option> }
                </select>
            </div>
            <div class="mb2">
                <span class="blbl">AREA</span>
                <div style="display:flex;gap:5px;">
                    <input type="text" class="binp" style="flex:1;" @bind-value="billingModel.AreaName"
                           @oninput='(e => OnInputChanged(e, "Area"))' placeholder="Area" />
                    <InputNumber class="binp" style="width:55px;" @bind-Value="billingModel.Charge" @bind-Value:after="CalculateAmounts" placeholder="" />
                </div>
            </div>
        </div> -->

        @* FINANCIAL SUMMARY *@
        <div style="background:var(--bg-card);border:1px solid var(--border-card);border-radius:10px;box-shadow:var(--shadow-card);padding:12px;">
            <div style="font-size:10px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--border-table);">FINANCIAL SUMMARY</div>

            <div style="margin-bottom:10px;background:var(--bg-badge-paid);border-radius:6px;padding:6px 8px;">
                <div style="font-size:11px;color:var(--text-success);font-weight:600;">Bill Amount (@addedTests.Count Tests)</div>
                <div style="font-size:16px;font-weight:700;color:var(--text-success);">@lrm.RequestAmount.ToString("0.00")</div>
            </div>

            <EditForm Model="@lrm">
                <div style="margin-bottom:8px;">
                    <div style="font-size:10px;color:#999;text-transform:uppercase;margin-bottom:4px;">GENERAL CONCESSION &nbsp;% &nbsp;VAL</div>
                    <div style="display:flex;gap:4px;">
                        <InputNumber class="binp" style="flex:1;text-align:right;color:#4caf50;font-weight:600;" @bind-Value="@lrm.OurDisPercentage" @bind-Value:after="() => UpdateOverallDiscount(true, false)" />
                        <InputNumber class="binp" style="flex:1;text-align:right;color:#4caf50;font-weight:600;" @bind-Value="@lrm.OurDiscount" @bind-Value:after="() => UpdateOverallDiscount(false, false)" />
                    </div>
                </div>
                <div style="margin-bottom:8px;">
                    <div style="font-size:10px;color:#999;text-transform:uppercase;margin-bottom:4px;">REFFERAL CONCESSION &nbsp;% &nbsp;VAL</div>
                    <div style="display:flex;gap:4px;">
                        <InputNumber class="binp" style="flex:1;text-align:right;color:#4caf50;font-weight:600;" @bind-Value="@lrm.ReferalPercentage" @bind-Value:after="() => UpdateOverallDiscount(true, true)" />
                        <InputNumber class="binp" style="flex:1;text-align:right;color:#4caf50;font-weight:600;" @bind-Value="@lrm.ReferalDiscount" @bind-Value:after="() => UpdateOverallDiscount(false, true)" />
                    </div>
                </div>
            </EditForm>

            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;padding:6px 8px;border-top:1px dashed var(--border-table);background:var(--bg-badge-pending);border-radius:6px;">
