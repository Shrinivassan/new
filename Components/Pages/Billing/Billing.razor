            var rts = rights.Where(x => x.ModuleName == "Billing" && x.Department == "Reception").FirstOrDefault();
            if(rts!=null)
            {
                issave = rts.ToAdd;
                isedit=rts.ToEdit;
                isdelete = rts.ToDelete;
            }

            // isapproved = rights.Any(x => x.Department == "Lab" && x.ModuleName == "Authorize Lab Results" && x.ToAdd);
            // isauthorized = rights.Any(x => x.Department == "Lab" && x.ModuleName == "Authorize Lab Results 2" && x.ToAdd);

