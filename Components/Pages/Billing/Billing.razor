                            <i class="bi bi-house-door-fill" style="color:#fff;font-size:13px;"></i>
                        </span>
                        <div>
                            <div style="font-size:12px;font-weight:700;color:@(billingModel.IsHomeCollection ? "var(--brand-accent)" : "var(--text-secondary)");transition:color .3s;">HOME COLLECTION</div>
                            <div style="font-size:10px;color:var(--text-muted);">Enable for doorstep sample pickup</div>
                        </div>
                    </div>
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin:0;">
                        <input type="checkbox" id="homeCollectionCheck"
                               @bind-value="billingModel.IsHomeCollection"
                               @bind-value:after="HandleHomeCollectionToggle"
                               style="display:none;" />
                        @* Toggle pill *@
                        <div style="width:42px;height:22px;background:@(billingModel.IsHomeCollection ? "var(--brand-accent)" : "var(--text-muted)");border-radius:11px;position:relative;transition:background .3s;cursor:pointer;"
                             @onclick="async () => { billingModel.IsHomeCollection = !billingModel.IsHomeCollection; await HandleHomeCollectionToggle(); }">
                            <div style="position:absolute;top:3px;left:@(billingModel.IsHomeCollection ? "23px" : "3px");width:16px;height:16px;background:#fff;border-radius:50%;box-shadow:0 1px 4px rgba(0,0,0,.25);transition:left .25s;"></div>
                        </div>
                        <span style="font-size:11px;font-weight:700;color:@(billingModel.IsHomeCollection ? "var(--brand-accent)" : "var(--text-muted)");">@(billingModel.IsHomeCollection ? "ON" : "OFF")</span>
                    </label>
                </div>

                @* Fields - only visible when enabled *@
                @if (billingModel.IsHomeCollection)
                {
                    <div style="display:flex;gap:8px;flex-wrap:wrap;background:var(--bg-hover);border:1px solid var(--brand-accent);border-radius:8px;padding:10px;">
                        <div style="flex:1;min-width:120px;">
