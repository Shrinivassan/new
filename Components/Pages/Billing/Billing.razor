                                        <li style="padding:6px 10px;cursor:pointer;font-size:12px;border-bottom:1px solid var(--border-table);background:@(i == selectedAreaIndex ? "var(--bg-hover)" : "transparent");color:var(--text-primary);"
                                            @onclick="() => SelectArea(area)">
                                            <i class="bi bi-geo"></i> @area.AreaName &nbsp;<i class="bi bi-cash"></i> @area.HomeCollectionCharge
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                        <div style="width:80px;">
                            <span class="blbl" style="color:var(--brand-accent);">CHARGE </span>
                            <InputNumber class="binp" style="text-align:right;font-weight:700;color:var(--brand-accent);" @bind-Value="billingModel.Charge" @bind-Value:after="CalculateAmounts" />
                        </div>
                    </div>
                }
            </div>


        </div>
    </div>

    @* === RIGHT: COLLECTION BY + FINANCIAL SUMMARY + PAYMENT === *@
