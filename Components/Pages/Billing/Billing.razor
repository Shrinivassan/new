    private void OnInputChanged(ChangeEventArgs e, string type)
    {
        if (billingModel == null)
        {
            return;
        }

        var searchTerm = e.Value?.ToString() ?? string.Empty;

        debounceTimer?.Stop();
        debounceTimer?.Dispose();
        debounceTimer = new System.Timers.Timer(300);
        debounceTimer.AutoReset = false;

        if (type == "Test")
        {
            searchtest = searchTerm;
            debounceTimer.Elapsed += async (_, __) =>
            {
                await InvokeAsync(SearchTests);
            };
        }
        else if (type == "ReferredBy" || type == "SecondReferredBy")
        {
            debounceTimer.Elapsed += async (_, __) =>
            {
                await InvokeAsync(() => SearchReferralDoctors(searchTerm, type));
            };
        }
        else if (type == "Area")
        {
            debounceTimer.Elapsed += async (_, __) =>
            {
                await InvokeAsync(() => SearchAreas(searchTerm));
            };
        }
        else if (type == "Collector")
        {
            // This is now a dropdown, so debouncing is not needed for collectors.
        }

        debounceTimer.Start();
    }

